---
// Sticky bottom action bar — mobile only.
// Desktop uses SideRail; this is its mobile counterpart.
const PHONE = "tel:+15126076232";
const ORDER =
  "https://online.skytab.com/75fd37a0da5766d1bf27a245fba50884/order-settings";
---

<div class="mobile-bar" aria-label="Quick actions">
  <a class="mbar-btn mbar-call" href={PHONE}>
    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"></path>
    </svg>
    <span>Call</span>
  </a>
  <a class="mbar-btn mbar-order" href={ORDER} target="_blank" rel="noopener">
    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M3 6h18l-2 13H5L3 6z"></path>
      <path d="M3 6 2 2H0"></path>
      <path d="M16 10a4 4 0 0 1-8 0"></path>
    </svg>
    <span>Order Online</span>
  </a>
</div>

<style>
  .mobile-bar {
    display: none;
  }

  /* Mobile + small tablet only — matches SideRail's 1099px cutoff */
  @media (max-width: 1099px) {
    .mobile-bar {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 50;
      display: grid;
      grid-template-columns: 1fr 1.4fr;
      gap: 0;
      background: var(--ink);
      box-shadow: 0 -6px 20px rgba(0, 0, 0, 0.22);
      padding-bottom: env(safe-area-inset-bottom, 0);
    }

    .mbar-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 9px;
      padding: 16px 12px;
      font-family: var(--font-display);
      font-size: 1.05rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      line-height: 1;
    }

    .mbar-call {
      background: var(--ink);
      color: var(--cream);
    }

    .mbar-call:active {
      background: #3a2418;
    }

    .mbar-order {
      background: var(--lime);
      color: var(--ink);
      box-shadow: inset 3px 0 0 var(--lime-shadow);
    }

    .mbar-order:active {
      background: var(--lime-shadow);
    }

    .mbar-btn svg {
      flex-shrink: 0;
    }
  }
</style>
