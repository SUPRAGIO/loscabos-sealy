---
export interface Props {
  eyebrow?: string;
  title: string;
  sub?: string;
  align?: "center" | "left";
  stackSub?: boolean;
}

const { eyebrow, title, sub, align = "center", stackSub = false } = Astro.props;

// When stackSub is true, split sub into sentences and render each on its own line.
const subSentences = stackSub && sub
  ? sub.match(/[^.!?]+[.!?]+(\s+|$)/g)?.map((s) => s.trim()) ?? [sub]
  : null;
---

<header class:list={["sec-title", `align-${align}`]}>
  <div class="ornament" aria-hidden="true">
    <svg viewBox="0 0 80 12" class="wavy" preserveAspectRatio="none">
      <path
        d="M0 6 Q 10 0 20 6 T 40 6 T 60 6 T 80 6"
        fill="none"
        stroke="var(--orange)"
        stroke-width="2"
        stroke-linecap="round"
      ></path>
    </svg>

    <svg viewBox="0 0 40 28" class="sombrero" aria-hidden="true">
      <!-- brim -->
      <ellipse cx="20" cy="22" rx="18" ry="3.5" fill="var(--orange)"></ellipse>
      <!-- crown -->
      <path
        d="M8 22 C 9 10 13 5 20 5 C 27 5 31 10 32 22 Z"
        fill="var(--orange-dark)"
      ></path>
      <!-- band -->
      <path
        d="M9.5 19 C 14 17 26 17 30.5 19"
        stroke="var(--cream)"
        stroke-width="1.5"
        fill="none"
        stroke-linecap="round"
      ></path>
      <!-- top dot -->
      <circle cx="20" cy="6.5" r="1.5" fill="var(--cream)"></circle>
    </svg>

    <svg viewBox="0 0 80 12" class="wavy" preserveAspectRatio="none">
      <path
        d="M0 6 Q 10 0 20 6 T 40 6 T 60 6 T 80 6"
        fill="none"
        stroke="var(--orange)"
        stroke-width="2"
        stroke-linecap="round"
      ></path>
    </svg>
  </div>

  {eyebrow && <span class="eyebrow-script">{eyebrow}</span>}

  <h2 class="display-title">{title}</h2>

  {sub && (
    subSentences ? (
      <p class="sec-sub stacked">
        {subSentences.map((s) => <span>{s}</span>)}
      </p>
    ) : (
      <p class="sec-sub">{sub}</p>
    )
  )}
</header>

<style>
  .sec-title {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    margin-bottom: 48px;
  }

  .sec-title.align-left {
    align-items: flex-start;
    text-align: left;
  }

  .ornament {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 4px;
  }

  .wavy {
    width: 80px;
    height: 12px;
  }

  .sombrero {
    width: 38px;
    height: 26px;
  }

  .display-title {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 5vw, 4rem);
    line-height: 0.95;
    letter-spacing: 0.01em;
    color: var(--ink);
    text-transform: uppercase;
    margin: 4px 0 0;
  }

  .sec-sub {
    color: var(--muted);
    max-width: 60ch;
    margin: 14px auto 0;
    font-size: 1.05rem;
    line-height: 1.6;
    text-align: center;
  }

  .align-left .sec-sub {
    text-align: left;
  }

  .sec-sub.stacked span {
    display: block;
  }

  .align-left .sec-sub {
    margin-left: 0;
    margin-right: 0;
  }
</style>
