---
const drinkImg = "/watermelon-margarita.jpg";
---

<section class="section bienvenidos">
  <div class="container bienv-grid">
    <!-- Left: framed image -->
    <div class="bienv-visual">
      <div class="frame">
        <img src={drinkImg} alt="Fresh watermelon margarita with salt rim, lime wedge, and watermelon garnish on a Los Cabos bar top" />
      </div>
    </div>

    <!-- Right: copy -->
    <div class="bienv-copy">
      <span class="eyebrow-script">¡Salúd!</span>

      <div class="diamonds lime" aria-hidden="true">
        <span></span><span></span><span></span>
      </div>

      <h2 class="bienv-title">
        Pull up a<br />chair, amigo.
      </h2>

      <p>
        Twelve flavored margs from strawberry to jalapeño cucumber. Top
        shelf builds with Patrón, Herradura, and Don Julio. House
        specialties like the Texas Two Step, Ranch Water, and a
        Chambord Marg you'll want to text your friends about. Frozen
        cervezas, ice cold micheladas, and house wines by the glass.
        Going big? Order the marg by the half gallon or full gallon to
        go. The bar's open. The seat's yours.
      </p>

      <a class="btn btn-primary" href="/bar">See the Bar</a>
    </div>
  </div>
</section>

<style>
  .bienvenidos {
    background: var(--cream);
  }

  .bienv-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 70px;
    align-items: center;
  }

  @media (max-width: 900px) {
    .bienv-grid {
      grid-template-columns: 1fr;
      gap: 50px;
    }
  }

  /* LEFT: visual */
  .bienv-visual {
    position: relative;
    padding: 30px 20px 20px 30px;
  }

  .frame {
    position: relative;
    aspect-ratio: 4 / 5;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow:
      0 18px 40px rgba(0, 0, 0, 0.18),
      0 4px 12px rgba(0, 0, 0, 0.08);
    border: 6px solid #fff;
  }

  .frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* RIGHT: copy */
  .bienv-copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .bienv-copy .eyebrow-script {
    color: var(--orange);
  }

  .bienv-copy .diamonds {
    margin: 8px 0 14px;
  }

  .bienv-title {
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 6vw, 4.5rem);
    line-height: 0.92;
    text-transform: uppercase;
    margin: 0 0 18px;
    color: var(--ink);
  }

  .bienv-copy p {
    color: var(--muted);
    font-size: 1.05rem;
    line-height: 1.7;
    max-width: 50ch;
    margin: 0 0 26px;
  }
</style>
