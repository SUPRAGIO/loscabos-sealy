---
const path = Astro.url.pathname.replace(/\/$/, "") || "/";

const navItems = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About Us" },
  { href: "/menu", label: "Menu" },
  { href: "/blog", label: "Blog" },
  { href: "/catering", label: "Catering" },
];

function isActive(href: string) {
  if (href === "/") return path === "/";
  return path === href || path.startsWith(href + "/");
}
---

<header class="site-header" id="siteHeader">
  <div class="header-inner">
    <a href="/" class="logo" aria-label="Los Cabos Mexican Grill — Home">
      <img src="/logo.png" alt="Los Cabos Mexican Grill" />
    </a>

    <nav class="primary-nav" aria-label="Primary">
      <ul>
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={["nav-link", { active: isActive(item.href) }]}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="header-actions">
      <a
        class="social-btn"
        href="https://www.facebook.com/profile.php?id=61571457067942"
        target="_blank"
        rel="noopener"
        aria-label="Facebook"
      >
        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
          <path d="M22 12.07C22 6.51 17.52 2 12 2S2 6.51 2 12.07c0 5.02 3.66 9.18 8.44 9.93v-7.03H7.9v-2.9h2.54V9.85c0-2.51 1.49-3.9 3.77-3.9 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56v1.87h2.78l-.45 2.9h-2.34V22c4.78-.75 8.45-4.91 8.45-9.93z"></path>
        </svg>
      </a>

      <a
        class="social-btn"
        href="https://www.instagram.com/loscabossealy"
        target="_blank"
        rel="noopener"
        aria-label="Instagram"
      >
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
        </svg>
      </a>

      <a
        class="social-btn"
        href="https://www.tiktok.com/@loscabossealy"
        target="_blank"
        rel="noopener"
        aria-label="TikTok"
      >
        <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true">
          <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5.8 20.1a6.34 6.34 0 0 0 10.86-4.43V8.85a8.16 8.16 0 0 0 4.77 1.52V6.93a4.85 4.85 0 0 1-1.84-.24z"></path>
        </svg>
      </a>

      <a class="shop-now" href="https://online.skytab.com/75fd37a0da5766d1bf27a245fba50884/order-settings" target="_blank" rel="noopener">Order Online</a>
    </div>
  </div>
</header>

<script>
  // Hide top nav when scrolling down, show when scrolling up.
  // Always show within ~80px of the top of the page.
  (() => {
    const header = document.getElementById("siteHeader");
    if (!header) return;

    let lastY = window.scrollY;
    let ticking = false;
    const SHOW_THRESHOLD = 80;
    const DELTA = 6;

    function update() {
      const y = window.scrollY;
      const goingDown = y > lastY + DELTA;
      const goingUp = y < lastY - DELTA;

      if (y < SHOW_THRESHOLD) {
        header.classList.remove("is-hidden");
      } else if (goingDown) {
        header.classList.add("is-hidden");
      } else if (goingUp) {
        header.classList.remove("is-hidden");
      }

      lastY = y;
      ticking = false;
    }

    window.addEventListener(
      "scroll",
      () => {
        if (!ticking) {
          window.requestAnimationFrame(update);
          ticking = true;
        }
      },
      { passive: true }
    );
  })();
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: #fff;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
    transition: transform 280ms ease;
    will-change: transform;
  }

  .site-header.is-hidden {
    transform: translateY(-100%);
  }

  .header-inner {
    width: min(1280px, 96vw);
    margin: 0 auto;
    /* True optical centering: side columns share equal minimum width
       and grow equally, forcing the middle nav into the geometric center. */
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 18px;
    padding: 14px 0;
  }

  .logo {
    justify-self: start;
  }

  .header-actions {
    justify-self: end;
  }

  .logo img {
    height: 64px;
    width: auto;
    display: block;
    object-fit: contain;
  }

  .primary-nav {
    display: flex;
    justify-content: center;
  }

  .primary-nav ul {
    display: flex;
    gap: 28px;
    align-items: center;
  }

  .nav-link {
    font-family: var(--font-display);
    font-size: 1.05rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink);
    padding: 6px 2px;
    position: relative;
    transition: color 150ms ease;
  }

  .nav-link:hover {
    color: var(--orange);
  }

  .nav-link.active {
    color: var(--orange);
  }

  .nav-link.active::after {
    content: "";
    position: absolute;
    left: 50%;
    bottom: -6px;
    transform: translateX(-50%);
    width: 6px;
    height: 6px;
    background: var(--orange);
    border-radius: 50%;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .social-btn {
    width: 34px;
    height: 34px;
    border-radius: 999px;
    background: #3a2a1e;
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background 150ms ease, transform 150ms ease;
  }

  .social-btn:hover {
    background: var(--orange);
    transform: translateY(-1px);
  }

  .shop-now {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #b6e600;
    color: var(--ink);
    font-family: var(--font-display);
    font-size: 1rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 11px 22px;
    border-radius: 4px;
    box-shadow: 0 6px 0 #8eb800;
    margin-left: 6px;
    transition: transform 120ms ease, box-shadow 120ms ease;
  }

  .shop-now:hover {
    transform: translateY(2px);
    box-shadow: 0 4px 0 #8eb800;
  }

  .shop-now:active {
    transform: translateY(6px);
    box-shadow: 0 0 0 #8eb800;
  }

  /* Responsive: hide nav under 1100px */
  @media (max-width: 1099px) {
    .header-inner {
      grid-template-columns: auto auto;
      justify-content: space-between;
    }
    .logo {
      justify-self: start;
    }
    .header-actions {
      justify-self: end;
    }
    .primary-nav {
      display: none;
    }
  }

  /* Hide socials under 540px, keep logo + Order Online */
  @media (max-width: 540px) {
    .social-btn {
      display: none;
    }
    .header-inner {
      gap: 8px;
    }
    .logo img {
      height: 52px;
    }
    .shop-now {
      padding: 9px 12px;
      font-size: 0.85rem;
      letter-spacing: 0.06em;
    }
  }
</style>
