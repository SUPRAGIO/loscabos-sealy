---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <!-- Top "newsletter" / brand band -->
  <section class="footer-cta">
    <div class="footer-cta-pattern" aria-hidden="true"></div>
    <div class="container footer-cta-inner">
      <div class="cta-copy">
        <span class="eyebrow-script">From our familia, to your inbox</span>
        <h3>Stay in the loop, amigo.</h3>
        <p>
          The occasional friendly email — new menu drops, holiday hours, the
          stuff worth knowing. No spam, ever.
        </p>
      </div>

      <form
        class="cta-form"
        name="newsletter"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        action="/?subscribed=true"
      >
        <input type="hidden" name="form-name" value="newsletter" />
        <p class="hp" aria-hidden="true">
          <label>Don't fill this out: <input name="bot-field" /></label>
        </p>
        <input
          type="email"
          name="email"
          required
          placeholder="you@email.com"
          aria-label="Email address"
        />
        <button class="btn btn-dark" type="submit">Sign Me Up</button>
      </form>
    </div>
  </section>

  <!-- Main footer -->
  <div class="footer-main">
    <div class="container footer-grid">
      <!-- Brand column -->
      <div class="footer-brand">
        <a href="/" class="footer-logo" aria-label="Los Cabos Mexican Grill — Home">
          <img src="/logo.png" alt="Los Cabos Mexican Grill" />
        </a>
        <p>
          Family owned Tex Mex in Sealy, TX. Sizzling fajitas, hand
          shaken margaritas, fresh salsa daily, and a table that's
          always got room for one more.
        </p>
        <div class="footer-socials">
          <a href="https://www.facebook.com/profile.php?id=61571457067942" target="_blank" rel="noopener" aria-label="Facebook">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
              <path d="M22 12.07C22 6.51 17.52 2 12 2S2 6.51 2 12.07c0 5.02 3.66 9.18 8.44 9.93v-7.03H7.9v-2.9h2.54V9.85c0-2.51 1.49-3.9 3.77-3.9 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56v1.87h2.78l-.45 2.9h-2.34V22c4.78-.75 8.45-4.91 8.45-9.93z"></path>
            </svg>
          </a>
          <a href="https://www.instagram.com/loscabossealy" target="_blank" rel="noopener" aria-label="Instagram">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
          </a>
          <a href="https://www.tiktok.com/@loscabossealy" target="_blank" rel="noopener" aria-label="TikTok">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
              <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5.8 20.1a6.34 6.34 0 0 0 10.86-4.43V8.85a8.16 8.16 0 0 0 4.77 1.52V6.93a4.85 4.85 0 0 1-1.84-.24z"></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Visit -->
      <div class="footer-col">
        <h4>Visit</h4>
        <p>
          6027 FM 3538<br />
          Sealy, TX 77474
        </p>
        <p>
          <a href="tel:+15126076232">(512) 607-6232</a><br />
          <a href="mailto:hola@loscabossealy.com">hola@loscabossealy.com</a>
        </p>
      </div>

      <!-- Hours -->
      <div class="footer-col">
        <h4>Hours</h4>
        <ul class="hours">
          <li><span>Sun — Wed</span><span>11A — 9P</span></li>
          <li><span>Thu — Sat</span><span>11A — 10P</span></li>
        </ul>
      </div>

      <!-- Explore -->
      <div class="footer-col">
        <h4>Explore</h4>
        <ul class="links">
          <li><a href="/menu">Menu</a></li>
          <li><a href="/about">About Us</a></li>
          <li><a href="/catering">Catering</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><a href="https://online.skytab.com/75fd37a0da5766d1bf27a245fba50884/order-settings" target="_blank" rel="noopener">Order Online</a></li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="footer-bar">
    <div class="container footer-bar-inner">
      <span>© {year} Los Cabos Mexican Grill. All rights reserved.</span>
    </div>
  </div>

  <!-- Powered-by credit -->
  <div class="footer-credit">
    <div class="container">
      <a
        href="https://suprareachmarketing.com"
        target="_blank"
        rel="noopener"
        class="credit-link"
      >
        Powered by <strong>SupraReach Marketing</strong>
      </a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 0;
  }

  /* ===== Top CTA / newsletter band ===== */
  .footer-cta {
    background: var(--orange);
    color: #fff;
    padding: 60px 0;
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }

  .footer-cta-pattern {
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      45deg,
      rgba(255, 255, 255, 0.06) 0,
      rgba(255, 255, 255, 0.06) 2px,
      transparent 2px,
      transparent 14px
    );
    pointer-events: none;
    z-index: 0;
  }

  .footer-cta-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  @media (max-width: 820px) {
    .footer-cta-inner {
      grid-template-columns: 1fr;
      gap: 28px;
    }
  }

  .cta-copy .eyebrow-script {
    color: #fff7ec;
    font-size: 1.4rem;
  }

  .cta-copy h3 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    text-transform: uppercase;
    letter-spacing: 0.01em;
    line-height: 1;
    margin: 6px 0 12px;
    color: #fff;
  }

  .cta-copy p {
    color: rgba(255, 255, 255, 0.92);
    line-height: 1.6;
    margin: 0;
    max-width: 44ch;
  }

  .cta-form {
    display: flex;
    gap: 10px;
    background: #fff;
    padding: 8px;
    border-radius: 10px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);
  }

  .cta-form input[type="email"] {
    flex: 1;
    border: 0;
    outline: 0;
    padding: 14px 16px;
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--ink);
    background: transparent;
  }

  .cta-form .btn {
    white-space: nowrap;
  }

  .hp {
    position: absolute;
    left: -9999px;
  }

  /* ===== Main footer body ===== */
  .footer-main {
    background: var(--teal-dark);
    color: var(--cream);
    padding: 70px 0 50px;
    position: relative;
  }

  /* Subtle decorative top edge */
  .footer-main::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 6px;
    background:
      linear-gradient(90deg, var(--orange) 0 16%, transparent 16% 20%,
                            var(--lime) 20% 36%, transparent 36% 40%,
                            var(--teal) 40% 56%, transparent 56% 60%,
                            var(--red) 60% 76%, transparent 76% 80%,
                            var(--orange) 80% 100%);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    gap: 40px;
  }

  @media (max-width: 1000px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 36px;
    }
  }

  @media (max-width: 560px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }
  }

  .footer-brand {
    max-width: 360px;
  }

  .footer-logo img {
    height: 80px;
    width: auto;
    margin-bottom: 18px;
    display: block;
  }

  .footer-brand p {
    color: rgba(255, 247, 236, 0.78);
    line-height: 1.65;
    margin: 0 0 22px;
  }

  .footer-socials {
    display: flex;
    gap: 10px;
  }

  .footer-socials a {
    width: 38px;
    height: 38px;
    border-radius: 999px;
    background: rgba(255, 247, 236, 0.08);
    color: var(--cream);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background 150ms ease, color 150ms ease, transform 150ms ease;
  }

  .footer-socials a:hover {
    background: var(--orange);
    color: #fff;
    transform: translateY(-2px);
  }

  .footer-col h4 {
    font-family: var(--font-display);
    font-size: 1.4rem;
    letter-spacing: 0.08em;
    color: var(--orange);
    margin: 0 0 18px;
    text-transform: uppercase;
    position: relative;
    padding-bottom: 12px;
  }

  .footer-col h4::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 28px;
    height: 3px;
    background: var(--lime);
    border-radius: 2px;
  }

  .footer-col p,
  .footer-col li {
    color: rgba(255, 247, 236, 0.78);
    line-height: 1.7;
  }

  .footer-col p {
    margin: 0 0 12px;
  }

  .footer-col a {
    color: rgba(255, 247, 236, 0.78);
    transition: color 150ms ease, padding-left 150ms ease;
  }

  .footer-col a:hover {
    color: var(--orange);
  }

  .hours li {
    display: flex;
    justify-content: space-between;
    border-bottom: 1px dashed rgba(255, 247, 236, 0.15);
    padding: 8px 0;
  }

  .hours li:last-child {
    border-bottom: 0;
  }

  .hours li span:first-child {
    font-family: var(--font-display);
    letter-spacing: 0.06em;
    color: var(--cream);
    font-size: 0.95rem;
  }

  .hours li span:last-child {
    color: rgba(255, 247, 236, 0.7);
    font-size: 0.95rem;
  }

  .links {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .links a {
    display: inline-block;
    padding: 4px 0;
  }

  .links a:hover {
    padding-left: 8px;
  }

  /* ===== Bottom bar ===== */
  .footer-bar {
    background: #073841;
    color: rgba(255, 247, 236, 0.6);
    padding: 18px 0;
    border-top: 1px solid rgba(255, 247, 236, 0.08);
  }

  /* ===== SupraReach credit ===== */
  .footer-credit {
    background: #052930;
    padding: 14px 0;
    text-align: center;
    border-top: 1px solid rgba(255, 247, 236, 0.06);
  }

  .credit-link {
    font-family: var(--font-display);
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 247, 236, 0.5);
    transition: color 150ms ease;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .credit-link strong {
    color: rgba(255, 247, 236, 0.85);
    font-weight: 400;
    transition: color 150ms ease;
  }

  .credit-link:hover {
    color: var(--orange);
  }

  .credit-link:hover strong {
    color: var(--orange);
  }

  .footer-bar-inner {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: 14px;
    font-size: 0.85rem;
  }

  @media (max-width: 700px) {
    .footer-bar-inner {
      justify-content: center;
      text-align: center;
    }
  }
</style>
