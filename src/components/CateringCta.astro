---
import SectionTitle from "@/components/SectionTitle.astro";
---

<section class="section catering-cta">
  <div class="container catering-grid">
    <div class="catering-copy">
      <SectionTitle
        eyebrow="Bigger crew? Bigger plates."
        title="Catering for the whole familia."
        align="left"
      />
      <p>
        Birthdays, graduations, weddings, soccer wrap ups, the office
        lunch you actually want to attend. Real food, hot and on time,
        for crews of 25 or more. Free delivery inside city limits.
      </p>

      <ul class="catering-list">
        <li>
          <span class="cat-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </span>
          <div>
            <strong>Famous Fajita Buffet</strong>
            <span>Beef and chicken fajitas, cheese enchiladas, rice, beans, guac, pico, homemade tortillas, chips and salsa. The full Cabos spread.</span>
          </div>
        </li>
        <li>
          <span class="cat-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </span>
          <div>
            <strong>Taco & Enchilada Buffet</strong>
            <span>Cheese enchiladas, chicken quesadillas, build your own crispy tacos, rice, beans, chips and salsa. Crowd friendly and a hit with the kids.</span>
          </div>
        </li>
        <li>
          <span class="cat-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </span>
          <div>
            <strong>Fajitas by the Pound</strong>
            <span>Beef, chicken, or veggie. Meat only, your sides. Plus enchilada trays, quesadilla trays, gallons of salsa, guac, queso, and more.</span>
          </div>
        </li>
      </ul>

      <div class="catering-buttons">
        <a class="btn btn-primary" href="/catering">Get a Quote</a>
        <a class="btn btn-ghost" href="tel:+15126076232">Call (512) 607-6232</a>
      </div>
    </div>

    <div class="catering-visual">
      <video
        class="catering-video"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        poster="/catering-loop-poster.jpg"
        aria-hidden="true"
      >
        <source src="/catering-loop.webm" type="video/webm" />
        <source src="/catering-loop.mp4" type="video/mp4" />
      </video>
    </div>
  </div>
</section>

<style>
  .catering-cta {
    background: var(--cream);
  }

  .catering-grid {
    display: grid;
    grid-template-columns: 1fr 1.05fr;
    gap: 70px;
    align-items: center;
  }

  @media (max-width: 950px) {
    .catering-grid {
      grid-template-columns: 1fr;
      gap: 50px;
    }
  }

  .catering-copy p {
    color: var(--muted);
    font-size: 1.05rem;
    line-height: 1.7;
    max-width: 56ch;
    margin: 0 0 28px;
  }

  .catering-list {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin: 0 0 32px;
  }

  .catering-list li {
    display: grid;
    grid-template-columns: 24px 1fr;
    gap: 14px;
    align-items: start;
  }

  .cat-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 3px;
  }

  .cat-icon svg {
    width: 24px;
    height: 24px;
    display: block;
    color: var(--lime-shadow);
  }

  .catering-list strong {
    display: block;
    font-family: var(--font-display);
    font-size: 1.25rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--ink);
    line-height: 1.1;
  }

  .catering-list span {
    display: block;
    color: var(--muted);
    font-size: 0.95rem;
    margin-top: 4px;
    line-height: 1.5;
  }

  .catering-buttons {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .catering-visual {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius);
    border: 6px solid #fff;
    box-shadow: var(--shadow);
    overflow: hidden;
    background: #1a0f08;
  }

  .catering-visual img,
  .catering-visual .catering-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Reduced-motion: skip the loop, show the poster */
  @media (prefers-reduced-motion: reduce) {
    .catering-visual .catering-video {
      display: none;
    }
    .catering-visual {
      background-image: url("/catering-loop-poster.jpg");
      background-size: cover;
      background-position: center;
    }
  }

</style>
