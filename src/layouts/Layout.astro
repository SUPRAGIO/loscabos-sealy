  <title>{title}</title>
  <style is:global>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{--bg:#FBF7F2;--bg2:#F5EFE6;--nav-bg:#1A1410;--orange:#F4621F;--orange-dk:#D94E0E;--gold:#C8860A;--text-head:#1C1410;--text-body:#4A3728;--text-muted:#9E8472;--border:rgba(74,55,40,0.12);--nav-h:76px}
    html{scroll-behavior:smooth;overflow-x:hidden}
    body{background:var(--bg);font-family:'Barlow',sans-serif;font-size:16px;line-height:1.6}
    img{max-width:100%;height:auto;display:block}
    a{color:inherit}
    .order-bar{position:fixed;top:0;left:0;right:0;height:38px;background:var(--orange);display:flex;align-items:center;justify-content:center;gap:14px;z-index:300;font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:12px;letter-spacing:0.12em;text-transform:uppercase}
    .order-bar span{color:rgba(255,255,255,0.82)}
    .order-bar a{color:white;text-decoration:none;background:rgba(0,0,0,0.22);padding:3px 14px;border-radius:20px;border:1px solid rgba(255,255,255,0.28)}
    nav{position:fixed;top:38px;left:0;right:0;height:var(--nav-h);background:var(--nav-bg);display:flex;align-items:center;justify-content:space-between;padding:0 40px;z-index:200;border-bottom:1px solid rgba(244,98,31,0.2);box-shadow:0 4px 24px rgba(0,0,0,0.6)}
    .nav-brand{display:flex;align-items:center;gap:12px;text-decoration:none;padding:8px 0}
    .nav-logo{height:60px;width:auto;display:block}
    .nav-location{font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:11px;letter-spacing:0.25em;text-transform:uppercase;color:rgba(255,255,255,0.45)}
    .nav-links{display:flex;align-items:center;gap:32px}
    .nav-links a{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:13px;letter-spacing:0.12em;text-transform:uppercase;color:rgba(255,255,255,0.65);text-decoration:none}
    .btn-nav-order{background:var(--orange);color:white !important;font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:13px;letter-spacing:0.12em;text-transform:uppercase;padding:10px 24px;border-radius:3px;text-decoration:none}
    .nav-hamburger{display:none;background:none;border:none;cursor:pointer;padding:4px;flex-direction:column;gap:5px}
    .nav-hamburger span{display:block;width:24px;height:2px;background:white;border-radius:2px}
    .mob-drawer{display:none;position:fixed;inset:0;background:var(--nav-bg);z-index:500;flex-direction:column;align-items:center;justify-content:center;gap:32px}
    .mob-drawer.open{display:flex}
    .mob-drawer-close{position:absolute;top:20px;right:20px;background:none;border:none;color:white;font-size:32px;cursor:pointer}
    .mob-drawer a{font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:32px;letter-spacing:0.1em;text-transform:uppercase;color:white;text-decoration:none}
    .mob-order-big{background:var(--orange);color:white !important;padding:16px 48px;border-radius:4px;font-size:20px !important}
    .mob-bar{display:none;position:fixed;bottom:0;left:0;right:0;z-index:400;height:56px}
    .mob-bar a{display:flex;align-items:center;justify-content:center;height:100%;width:50%;font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:14px;letter-spacing:0.12em;text-transform:uppercase;text-decoration:none}
    .mob-order{background:var(--orange);color:white}
    .mob-call{background:var(--nav-bg);color:white;border-top:1px solid rgba(255,255,255,0.1)}
    .btn-primary{background:var(--orange);color:white;font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:15px;letter-spacing:0.12em;text-transform:uppercase;padding:15px 36px;border-radius:3px;text-decoration:none;border:none;cursor:pointer;display:inline-block;box-shadow:0 2px 12px rgba(244,98,31,0.3)}
    .btn-outline{background:transparent;color:white;font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:15px;letter-spacing:0.12em;text-transform:uppercase;padding:14px 32px;border-radius:3px;text-decoration:none;border:2px solid rgba(255,255,255,0.4);display:inline-block}
    .btn-ghost{background:transparent;color:white;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:15px;letter-spacing:0.1em;text-transform:uppercase;padding:14px 28px;border-radius:3px;text-decoration:none;border:1.5px solid rgba(255,255,255,0.25);display:inline-flex;align-items:center;justify-content:center;gap:8px}
    .section-eyebrow{font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:11px;letter-spacing:0.3em;text-transform:uppercase;color:var(--orange);margin-bottom:8px}
    .section-heading{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:clamp(38px,5vw,56px);line-height:0.95;text-transform:uppercase;color:var(--text-head);margin-bottom:20px}
    footer{background:var(--nav-bg);border-top:2px solid var(--orange);padding:28px 60px;display:grid;grid-template-columns:1fr auto 1fr;align-items:center}
    .footer-logo{height:48px;width:auto;display:block}
    .footer-links{display:flex;gap:40px;list-style:none;justify-content:center;align-items:center;margin:0;padding:0}
    .footer-links a{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:13px;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.55);text-decoration:none}
    .footer-copy{font-size:12px;color:var(--text-muted);font-family:'Barlow',sans-serif;text-align:right;white-space:nowrap}
    @media(max-width:768px){
      nav{padding:0 14px;height:58px;top:36px}
      .nav-logo{height:44px}
      .nav-links{display:none}
      .nav-hamburger{display:flex}
      .order-bar{height:36px;font-size:11px}
      .order-bar span{display:none}
      footer{grid-template-columns:1fr;justify-items:center;gap:20px;padding:28px 20px}
      .footer-copy{text-align:center}
      .footer-links{gap:24px;flex-wrap:wrap;justify-content:center}
      .mob-bar{display:flex}
    }
  
@media(max-width:768px){
  .announce-bar{font-size:11px;padding:8px 12px;gap:8px;flex-wrap:wrap;text-align:center;}
  .announce-bar .btn-announce{font-size:10px;padding:5px 12px;}
  nav{padding:0 16px;height:56px;top:34px;}
  .nav-logo{height:40px;}
  .nav-links{gap:12px;}
  .nav-links a{font-size:11px;letter-spacing:.06em;}
  .btn-nav-order{font-size:11px;padding:8px 14px;}
  .site-footer{padding:40px 20px 32px;}
  .footer-inner{gap:20px;}
  .footer-tagline{font-size:14px;}
  .footer-nav{gap:12px;flex-wrap:wrap;}
  .footer-nav a{font-size:12px;}
  .footer-bottom{flex-direction:column;gap:6px;font-size:10px;}
}
