<style>
/* ===================== */
/* MOBILE NUCLEAR RESET  */
/* ===================== */
html, body {
  overflow-x: hidden;
  max-width: 100vw;
  width: 100%;
}
* { box-sizing: border-box; }
img, video { max-width: 100%; height: auto; display: block; }

@media (max-width: 768px) {

  /* ---- GLOBAL ---- */
  body { font-size: 15px; }
  section, .section, [class*="section"] {
    width: 100% !important;
    max-width: 100vw !important;
    padding-left: 20px !important;
    padding-right: 20px !important;
    overflow: hidden !important;
  }
  div[style*="max-width"] { max-width: 100% !important; width: 100% !important; }
  div[style*="width:720px"], div[style*="width: 720px"],
  div[style*="width:960px"], div[style*="width: 960px"],
  div[style*="width:700px"], div[style*="width: 700px"],
  div[style*="width:860px"], div[style*="width: 860px"] {
    width: 100% !important;
    max-width: 100% !important;
  }

  /* ---- NAV ---- */
  nav { padding: 0 16px !important; height: 56px !important; }
  .nav-logo { height: 38px !important; }
  .nav-links { gap: 10px !important; }
  .nav-links a { font-size: 11px !important; letter-spacing: .04em !important; }
  .btn-nav-order { font-size: 11px !important; padding: 7px 12px !important; }

  /* ---- ANNOUNCE BAR ---- */
  .announce-bar { font-size: 11px !important; padding: 7px 12px !important; gap: 6px !important; }
  .btn-announce { font-size: 10px !important; padding: 5px 10px !important; }

  /* ---- HERO ---- */
  .hero { min-height: 80vh !important; padding-top: 94px !important; }
  .hero-content {
    display: flex !important;
    flex-direction: column !important;
    padding: 0 20px 40px !important;
    width: 100% !important;
    gap: 20px !important;
  }
  .hero-headline { font-size: clamp(48px, 14vw, 72px) !important; line-height: .9 !important; }
  .hero-ctas { flex-direction: column !important; gap: 10px !important; width: 100% !important; }
  .hero-ctas a { width: 100% !important; text-align: center !important; padding: 14px !important; font-size: 14px !important; }
  .hero-info-card { display: none !important; }

  /* ---- MENU CTA ---- */
  .menu-cta-banner { min-height: 280px !important; }
  .menu-cta-content { padding: 36px 20px !important; max-width: 100% !important; }
  .menu-cta-heading { font-size: clamp(36px, 11vw, 56px) !important; }
  .menu-cta-sub { font-size: 14px !important; }
  .menu-cta-btn { width: 100% !important; text-align: center !important; padding: 14px !important; }

  /* ---- FEATURED DISHES ---- */
  .featured-section { padding: 48px 20px !important; }
  .featured-grid { grid-template-columns: 1fr !important; gap: 16px !important; }
  .featured-card { width: 100% !important; }
  .featured-img { height: 200px !important; }
  .featured-name { font-size: 20px !important; color: #1C1410 !important; }
  .featured-desc { font-size: 14px !important; color: #2A1F18 !important; }
  .btn-secondary-menu { width: 100% !important; text-align: center !important; margin-top: 24px !important; }

  /* ---- CATERING ---- */
  #catering { padding: 0 !important; }
  #catering > div {
    display: flex !important;
    flex-direction: column !important;
    width: 100% !important;
  }
  #catering > div > div {
    padding: 40px 20px !important;
    width: 100% !important;
    max-width: 100% !important;
  }
  .catering-cta-phone { font-size: 28px !important; }
  .catering-cta-btn { width: 100% !important; }
  .catering-desc, .catering-intro { color: #2A1F18 !important; font-size: 15px !important; }
  .step-title { color: #1C1410 !important; font-size: 16px !important; }
  .step-desc { color: #2A1F18 !important; }

  /* ---- REVIEWS ---- */
  .reviews-section { padding: 48px 20px !important; }
  .reviews-inner { max-width: 100% !important; padding: 0 !important; }
  .reviews-grid { grid-template-columns: 1fr !important; gap: 16px !important; }
  .review-card { padding: 20px !important; }
  .review-text { font-size: 14px !important; color: #f5f0ea !important; }
  .review-name { font-size: 13px !important; }
  .reviews-score-row { flex-direction: column !important; gap: 8px !important; }
  .reviews-score { font-size: 48px !important; }

  /* ---- FIND US ---- */
  .find-us-section { padding: 48px 20px !important; }
  .find-us-grid { grid-template-columns: 1fr !important; gap: 24px !important; }
  .find-us-info { width: 100% !important; }
  .info-label { color: rgba(255,255,255,0.6) !important; font-size: 11px !important; }
  .info-value { color: white !important; font-size: 15px !important; }
  .info-value a { color: #F4621F !important; }
  .map-embed { height: 220px !important; width: 100% !important; }

  /* ---- MENU TABS ---- */
  .menu-tabs {
    overflow-x: auto !important;
    flex-wrap: nowrap !important;
    justify-content: flex-start !important;
    padding-bottom: 8px !important;
    -webkit-overflow-scrolling: touch !important;
    scrollbar-width: none !important;
    width: 100% !important;
  }
  .menu-tabs::-webkit-scrollbar { display: none !important; }
  .tab-btn {
    white-space: nowrap !important;
    font-size: 11px !important;
    padding: 8px 12px !important;
    flex-shrink: 0 !important;
  }

  /* ---- MENU CARDS ---- */
  .menu-section { padding: 40px 16px !important; }
  .tc-grid { grid-template-columns: repeat(2, 1fr) !important; gap: 10px !important; justify-content: center !important; }
  .tc-card { width: 100% !important; }
  .tc-img { height: 120px !important; }
  .tc-body { padding: 10px !important; }
  .tc-name { font-size: 12px !important; color: #1C1410 !important; }
  .tc-desc { font-size: 11px !important; color: #4A3728 !important; }
  .tc-btn { font-size: 11px !important; padding: 8px !important; }

  /* ---- SECTION HEADINGS ---- */
  .section-heading { font-size: clamp(28px, 9vw, 44px) !important; color: #1C1410 !important; }
  .section-eyebrow { font-size: 11px !important; color: #F4621F !important; }

  /* ---- FOOTER ---- */
  .site-footer { padding: 40px 20px 32px !important; }
  .footer-tagline { font-size: 14px !important; }
  .footer-nav { gap: 12px !important; flex-wrap: wrap !important; justify-content: center !important; }
  .footer-nav a { font-size: 12px !important; }
  .footer-bottom { flex-direction: column !important; gap: 8px !important; font-size: 10px !important; text-align: center !important; }
  .footer-social { gap: 20px !important; }
  .footer-legal { font-size: 10px !important; }
}

@media (max-width: 390px) {
  .tc-grid { grid-template-columns: 1fr !important; }
  .hero-headline { font-size: clamp(40px, 13vw, 60px) !important; }
  .nav-links a { font-size: 10px !important; }
  .btn-nav-order { display: none !important; }
}
</style>
</head>
