---
export interface Props {
  title?: string;
  description?: string;
}
const { title = "Los Cabos Mexican Grill → Sealy, TX", description = "Sizzling fajitas, hand-crafted margaritas, and scratch-made Tex-Mex in Sealy, TX." } = Astro.props;
