<style>
html{overflow-x:hidden;max-width:100vw;}
body{overflow-x:hidden;max-width:100vw;position:relative;width:100%;}
*{box-sizing:border-box;}
img,video{max-width:100%;}
/* Cream background text contrast fixes */
.section-heading{color:#1C1410;}
.section-eyebrow{color:#F4621F;}
.featured-name{color:#1C1410;}
.featured-desc{color:#2A1F18;}
.featured-price{color:#F4621F;}
.catering-desc{color:#2A1F18;}
.step-desc{color:#2A1F18;}
