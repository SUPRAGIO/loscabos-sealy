  <title>{title}</title>

  <style is:global>
    /* ============================================================
       GLOBAL RESET + TOKENS
       ============================================================ */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --orange: #F4621F;
      --orange-dk: #D94E0E;
      --dark: #1A1410;
      --cream: #FBF7F2;
      --cream2: #F5EFE6;
      --text: #1C1410;
      --text-body: #4A3728;
      --text-muted: #9E8472;
      /* Chrome height: announce=32px, nav=58px on mobile */
      --chrome-h: 90px;
    }
    html { scroll-behavior: smooth; overflow-x: hidden; }
    body {
      background: var(--cream);
      font-family: 'Barlow', sans-serif;
      font-size: 16px;
      line-height: 1.6;
      overflow-x: hidden;
      max-width: 100vw;
    }
    img, video { max-width: 100%; height: auto; display: block; }
    a { color: inherit; }

    /* ============================================================
       ANNOUNCE BAR  (mobile-first)
       ============================================================ */
    .announce-bar {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 300;
      height: 32px;
      background: var(--orange);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 11px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #fff;
      padding: 0 12px;
    }
    .announce-bar span { color: rgba(255,255,255,0.82); }
    .announce-bar a {
      color: #fff;
      text-decoration: none;
      background: rgba(0,0,0,0.22);
      padding: 2px 12px;
      border-radius: 20px;
      border: 1px solid rgba(255,255,255,0.28);
      white-space: nowrap;
    }

    /* ============================================================
       NAV  (mobile-first)
       ============================================================ */
    nav {
      position: fixed;
      top: 32px; left: 0; right: 0;
      z-index: 200;
      height: 58px;
      background: var(--dark);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 16px;
      border-bottom: 1px solid rgba(244,98,31,0.2);
    }
    .nav-brand { display: flex; align-items: center; gap: 10px; text-decoration: none; }
    .nav-logo { height: 40px; width: auto; display: block; }
    .nav-location { display: none; }
    .nav-links { display: none !important; }
    .nav-hamburger {
      display: flex;
      background: none;
      border: none;
      cursor: pointer;
      padding: 4px;
      flex-direction: column;
      gap: 5px;
    }
    .nav-hamburger span { display: block; width: 24px; height: 2px; background: #fff; border-radius: 2px; }
    .btn-nav-order { display: none; }

    /* Mobile drawer */
    .mob-drawer {
      display: none;
      position: fixed;
      inset: 0;
      background: var(--dark);
      z-index: 500;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 32px;
    }
    .mob-drawer.open { display: flex; }
    .mob-drawer-close {
      position: absolute;
      top: 20px; right: 20px;
      background: none;
      border: none;
      color: #fff;
      font-size: 36px;
      cursor: pointer;
      line-height: 1;
    }
    .mob-drawer a {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 800;
      font-size: 32px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #fff;
      text-decoration: none;
    }
    .mob-order-big {
      background: var(--orange);
      color: #fff;
      padding: 16px 48px;
      border-radius: 4px;
      font-size: 20px;
    }

    /* Sticky bottom bar — mobile only */
    .mob-bar {
      display: flex;
      position: fixed;
      bottom: 0; left: 0; right: 0;
      z-index: 400;
      height: 52px;
    }
    .mob-bar a {
      display: flex;
      align-items: center;
      justify-content: center;
      height: 100%;
      width: 50%;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 800;
      font-size: 14px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      text-decoration: none;
    }
    .mob-order { background: var(--orange); color: #fff; }
    .mob-call { background: var(--dark); color: #fff; border-top: 1px solid rgba(255,255,255,0.1); }

    /* ============================================================
       SHARED BUTTON STYLES  (mobile-first, no desktop overrides needed here)
       ============================================================ */
    .btn-primary {
      display: inline-block;
      background: var(--orange);
      color: #fff;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 800;
      font-size: 14px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 14px 28px;
      border-radius: 4px;
      text-decoration: none;
      border: none;
      cursor: pointer;
      transition: background 0.2s;
    }
    .btn-primary:hover { background: var(--orange-dk); }
    .btn-outline {
      display: inline-block;
      background: transparent;
      color: #fff;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 800;
      font-size: 14px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 13px 24px;
      border-radius: 4px;
      text-decoration: none;
      border: 2px solid rgba(255,255,255,0.4);
      transition: border-color 0.2s;
    }
    .btn-outline:hover { border-color: #fff; }
    .btn-ghost {
      display: inline-block;
      background: transparent;
      color: #fff;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 14px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 13px 24px;
      border-radius: 4px;
      text-decoration: none;
      border: 1.5px solid rgba(255,255,255,0.25);
      transition: border-color 0.2s;
    }
    .btn-ghost:hover { border-color: rgba(255,255,255,0.6); }

    /* ============================================================
       FOOTER
       ============================================================ */
    .site-footer {
      background: #0f0d0b;
      color: rgba(255,255,255,0.45);
      font-family: 'Barlow', sans-serif;
      font-size: 13px;
      text-align: center;
      padding: 48px 20px 80px; /* 80px bottom = mob-bar clearance */
      border-top: 1px solid rgba(255,255,255,0.08);
      width: 100%;
      display: flex;
      justify-content: center;
    }
    .footer-inner {
      max-width: 860px;
      width: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 24px;
    }
    .footer-tagline { font-size: 14px; color: rgba(255,255,255,0.6); max-width: 480px; line-height: 1.6; margin: 0; }
    .footer-social { display: flex; gap: 20px; align-items: center; justify-content: center; }
    .footer-social a { color: rgba(255,255,255,0.5); transition: color 0.2s; display: flex; }
    .footer-social a:hover { color: var(--orange); }
    .footer-nav { display: flex; gap: 16px; flex-wrap: wrap; justify-content: center; align-items: center; }
    .footer-nav a {
      color: rgba(255,255,255,0.55);
      text-decoration: none;
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 700;
      font-size: 12px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      transition: color 0.2s;
    }
    .footer-nav a:hover { color: var(--orange); }
    .footer-legal {
      max-width: 640px;
      width: 100%;
      display: flex;
      flex-direction: column;
      gap: 6px;
      color: rgba(255,255,255,0.3);
      font-size: 11px;
      line-height: 1.6;
      border-top: 1px solid rgba(255,255,255,0.08);
      padding-top: 20px;
    }
    .footer-legal p { margin: 0; }
    .footer-bottom {
      width: 100%;
      display: flex;
      flex-direction: column;
      gap: 6px;
      justify-content: center;
      align-items: center;
      border-top: 1px solid rgba(255,255,255,0.08);
      padding-top: 18px;
      font-size: 10px;
      color: rgba(255,255,255,0.3);
    }
    .footer-bottom a { color: var(--orange); text-decoration: none; font-family: 'Barlow Condensed', sans-serif; font-weight: 800; }

    /* ============================================================
       DESKTOP UPGRADES  (min-width: 768px)
       ============================================================ */
    @media (min-width: 768px) {
      :root { --chrome-h: 114px; }

      .announce-bar { height: 36px; font-size: 12px; }
      .announce-bar span { display: inline; }

      nav { top: 36px; height: 78px; padding: 0 40px; }
      .nav-logo { height: 52px; }
      .nav-location {
        display: block;
        font-family: 'Barlow Condensed', sans-serif;
        font-weight: 700;
        font-size: 12px;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.45);
      }
      .nav-links {
        display: none !important;
      }
      .nav-links a {
        font-family: 'Barlow Condensed', sans-serif;
        font-weight: 700;
        font-size: 13px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.7);
        text-decoration: none;
        transition: color 0.2s;
      }
      .nav-links a:hover { color: #fff; }
      .btn-nav-order {
        display: none;
        background: var(--orange);
        color: #fff;
        font-family: 'Barlow Condensed', sans-serif;
        font-weight: 800;
        font-size: 13px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding: 10px 24px;
        border-radius: 4px;
        text-decoration: none;
        transition: background 0.2s;
        white-space: nowrap;
      }
      .btn-nav-order:hover { background: var(--orange-dk); }
      .nav-hamburger { display: flex; }

      .mob-bar { display: none; }

      .site-footer { padding: 60px 40px 40px; }
      .footer-tagline { font-size: 15px; }
      .footer-nav { gap: 32px; }
      .footer-nav a { font-size: 13px; }
      .footer-bottom { flex-direction: row; gap: 24px; font-size: 11px; }
    }
  </style>
</head>
<body>
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-PJMMSBX5" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

  <div class="announce-bar">
    <span>Order online &rarr; ready in 15 minutes.</span>
    <a href="https://online.skytab.com/75fd37a0da5766d1bf27a245fba50884" target="_blank" rel="noopener">ORDER PICKUP</a>
  </div>

  <nav>
    <a href="/" class="nav-brand">
      <img src="/images/logo.png" alt="Los Cabos Mexican Grill" class="nav-logo" />
      <span class="nav-location">Sealy</span>
    </a>
    <div class="nav-links">
      <a href="/">Home</a>
        <a href="/menu">Menu</a>
      <a href="/#catering">Catering</a>
      <a href="/#find-us">Find Us</a>
      <a href="https://online.skytab.com/75fd37a0da5766d1bf27a245fba50884" target="_blank" rel="noopener" class="btn-nav-order">Order Now</a>
    </div>
    <button class="nav-hamburger" onclick="document.getElementById('mobDrawer').classList.add('open')" aria-label="Open menu">
      <span></span><span></span><span></span>
    </button>
  </nav>

  <div class="mob-drawer" id="mobDrawer">
    <button class="mob-drawer-close" onclick="document.getElementById('mobDrawer').classList.remove('open')">&times;</button>
    <a href="/" onclick="document.getElementById('mobDrawer').classList.remove('open')">Home</a>
  <a href="/menu" onclick="document.getElementById('mobDrawer').classList.remove('open')">Menu</a>
    <a href="/#catering" onclick="document.getElementById('mobDrawer').classList.remove('open')">Catering</a>
    <a href="/#find-us" onclick="document.getElementById('mobDrawer').classList.remove('open')">Find Us</a>
    <a href="https://online.skytab.com/75fd37a0da5766d1bf27a245fba50884" target="_blank" rel="noopener" class="mob-order-big">Order Online</a>
  </div>

  <slot />

  <div class="mob-bar">
    <a href="https://online.skytab.com/75fd37a0da5766d1bf27a245fba50884" target="_blank" rel="noopener" class="mob-order">Order Online</a>
    <a href="tel:+15126076232" class="mob-call">Call Now</a>
  </div>

  <script>
    window.dataLayer = window.dataLayer || [];
    function fireOrderEvent(label) {
      window.dataLayer.push({ event: 'order_now_click', event_category: 'Outbound', event_label: label, value: 1 });
      if (typeof gtag !== 'undefined') {
        gtag('event', 'order_now_click', { event_category: 'Outbound', event_label: label, value: 1 });
      }
    }
    document.addEventListener('DOMContentLoaded', function () {
      document.querySelectorAll('a[href*="skytab"]').forEach(function (link) {
        link.addEventListener('click', function () {
          var label = 'Order Now';
          var body = link.closest('.featured-body');
          if (body) { var n = body.querySelector('.featured-name'); if (n) label = n.textContent.trim(); }
          var btn = link.closest('.hero-ctas, nav');
          if (btn) label = link.textContent.trim() + ' (Nav/Hero)';
          fireOrderEvent(label);
        });
      });
    });
  </script>

  <footer class="site-footer">
    <div class="footer-inner">
      <div>
        <img src="/images/logo.png" alt="Los Cabos Mexican Grill" style="height:72px;width:auto;" />
      </div>
      <p class="footer-tagline">Sizzling fajitas.<br>Hand-crafted margaritas.<br>Sealy&rsquo;s favorite Tex-Mex since day one.</p>
      <div class="footer-social">
        <a href="https://www.facebook.com/people/Los-Cabos-Mexican-Grill-Sealy/61571457067942/" target="_blank" rel="noopener" aria-label="Facebook">
          <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
        </a>
        <a href="https://www.instagram.com/loscabossealy/" target="_blank" rel="noopener" aria-label="Instagram">
          <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
        </a>
        <a href="https://www.tiktok.com/@loscabossealy" target="_blank" rel="noopener" aria-label="TikTok">
          <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.74a4.85 4.85 0 01-1.01-.05z"/></svg>
        </a>
      </div>
      <nav class="footer-nav">
        <a href="/">Home</a>
        <a href="/menu">Menu</a>
        <a href="/#catering">Catering</a>
        <a href="/#find-us">Find Us</a>
        <a href="https://online.skytab.com/75fd37a0da5766d1bf27a245fba50884/order-settings" target="_blank" rel="noopener">Order Online</a>
      </nav>
      <div class="footer-legal">
        <p>Menu prices and availability subject to change without notice.</p>
        <p>If you have a food allergy or dietary restriction, please inform your server before ordering.</p>
      </div>
      <div class="footer-bottom">
        <span>&copy; 2026 Los Cabos Mexican Grill &mdash; Sealy, TX. All rights reserved.</span>
        <span>POWERED BY <a href="https://suprareachmarketing.com" target="_blank" rel="noopener">SUPRAREACH MARKETING</a></span>
      </div>
    </div>
  </footer>
</body>
</html>