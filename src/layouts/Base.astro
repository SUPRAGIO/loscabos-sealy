---
import "@/styles/global.css";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import SideRail from "@/components/SideRail.astro";

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const SITE = "https://loscabossealy.com";
const BRAND = "Los Cabos Mexican Grill";

const {
  title = "Los Cabos Mexican Grill | Tex Mex Restaurant in Sealy, TX",
  description = "Family owned Tex Mex restaurant in Sealy, Texas. Sizzling fajitas, hand shaken margaritas, fresh salsa daily, lunch specials, and catering near I-10. Open daily at 11AM.",
  ogImage = "/sealy-storefront.jpg",
  noindex = false,
} = Astro.props;

const pathname = Astro.url.pathname;
const canonicalUrl = new URL(pathname, SITE).toString();
const fullOgImage = ogImage.startsWith("http") ? ogImage : `${SITE}${ogImage}`;

// Sitewide LocalBusiness schema — emitted on every page for max signal density.
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "MexicanRestaurant",
  "@id": `${SITE}/#restaurant`,
  name: BRAND,
  alternateName: ["Los Cabos Sealy", "Los Cabos Mexican Grill Sealy"],
  url: SITE,
  image: [
    `${SITE}/sealy-storefront.jpg`,
    `${SITE}/family-pack-spread.jpg`,
    `${SITE}/watermelon-margarita.jpg`,
  ],
  logo: `${SITE}/logo.png`,
  telephone: "+1-512-607-6232",
  email: "hola@loscabossealy.com",
  priceRange: "$$",
  description:
    "Family owned Tex Mex restaurant in Sealy, Texas serving sizzling fajitas, enchiladas, hand shaken margaritas, fresh salsa daily, lunch specials, family packs, and catering. Part of the family owned Los Cabos Mexican Grill family of restaurants in south central Texas.",
  servesCuisine: ["Tex-Mex", "Mexican"],
  paymentAccepted: ["Cash", "Credit Card", "Debit Card"],
  currenciesAccepted: "USD",
  acceptsReservations: false,
  address: {
    "@type": "PostalAddress",
    streetAddress: "6027 FM 3538",
    addressLocality: "Sealy",
    addressRegion: "TX",
    postalCode: "77474",
    addressCountry: "US",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: 29.7807,
    longitude: -96.1572,
  },
  hasMap: "https://www.google.com/maps/place/6027+FM-3538,+Sealy,+TX+77474",
  // Define our 15-mile delivery + dine-in service radius
  areaServed: {
    "@type": "GeoCircle",
    geoMidpoint: {
      "@type": "GeoCoordinates",
      latitude: 29.7807,
      longitude: -96.1572,
    },
    geoRadius: "24140", // 15 miles in meters
  },
  // Plus explicit city list for entity coverage
  serviceArea: [
    { "@type": "City", name: "Sealy", containedInPlace: "Austin County, TX" },
    { "@type": "City", name: "Brookshire", containedInPlace: "Waller County, TX" },
    { "@type": "City", name: "Bellville", containedInPlace: "Austin County, TX" },
    { "@type": "City", name: "Wallis", containedInPlace: "Austin County, TX" },
    { "@type": "City", name: "Cat Spring", containedInPlace: "Austin County, TX" },
    { "@type": "City", name: "San Felipe", containedInPlace: "Austin County, TX" },
    { "@type": "City", name: "Pattison", containedInPlace: "Waller County, TX" },
    { "@type": "City", name: "Simonton", containedInPlace: "Fort Bend County, TX" },
    { "@type": "City", name: "Industry", containedInPlace: "Austin County, TX" },
    { "@type": "City", name: "Kenney", containedInPlace: "Austin County, TX" },
  ],
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Sunday", "Monday", "Tuesday", "Wednesday"],
      opens: "11:00",
      closes: "21:00",
    },
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Thursday", "Friday", "Saturday"],
      opens: "11:00",
      closes: "22:00",
    },
  ],
  hasMenu: `${SITE}/menu`,
  potentialAction: [
    {
      "@type": "OrderAction",
      target: {
        "@type": "EntryPoint",
        urlTemplate:
          "https://online.skytab.com/75fd37a0da5766d1bf27a245fba50884/order-settings",
        actionPlatform: [
          "http://schema.org/DesktopWebPlatform",
          "http://schema.org/MobileWebPlatform",
        ],
      },
      deliveryMethod: ["http://purl.org/goodrelations/v1#DeliveryModePickUp"],
    },
  ],
  parentOrganization: {
    "@type": "FoodEstablishment",
    name: "Los Cabos Mexican Grill",
    url: "https://www.eatloscabos.com",
    founder: { "@type": "Person", name: "Isidro Sánchez" },
  },
  sameAs: [
    "https://www.instagram.com/loscabossealy",
    "https://www.tiktok.com/@loscabossealy",
    "https://www.facebook.com/profile.php?id=61571457067942",
  ],
};

// WebSite schema — gives Google sitelinks search box potential
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${SITE}/#website`,
  url: SITE,
  name: BRAND,
  publisher: { "@id": `${SITE}/#restaurant` },
  inLanguage: "en-US",
};

// Organization schema for entity disambiguation
const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": `${SITE}/#organization`,
  name: BRAND,
  url: SITE,
  logo: `${SITE}/logo.png`,
  sameAs: [
    "https://www.instagram.com/loscabossealy",
    "https://www.tiktok.com/@loscabossealy",
    "https://www.facebook.com/profile.php?id=61571457067942",
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="format-detection" content="telephone=yes" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    {!noindex && <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1" />}

    <link rel="canonical" href={canonicalUrl} />

    <!-- Geo meta (older but still indexed by some local engines) -->
    <meta name="geo.region" content="US-TX" />
    <meta name="geo.placename" content="Sealy" />
    <meta name="geo.position" content="29.7807;-96.1572" />
    <meta name="ICBM" content="29.7807, -96.1572" />

    <!-- Theme color for mobile browser chrome -->
    <meta name="theme-color" content="#ec6a26" />

    <!-- Google Search Console verification — paste your code below after verifying ownership -->
    <!-- <meta name="google-site-verification" content="YOUR_VERIFICATION_CODE_HERE" /> -->

    <!-- Google Tag Manager -->
    <script is:inline>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer','GTM-PJMMSBX5');
    </script>
    <!-- End Google Tag Manager -->

    <!-- Favicons -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
    <link rel="apple-touch-icon" sizes="512x512" href="/favicon-512.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="restaurant.restaurant" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={BRAND} />
    <meta property="og:image" content={fullOgImage} />
    <meta property="og:image:alt" content={`${BRAND} in Sealy, Texas`} />
    <meta property="og:locale" content="en_US" />
    <meta property="restaurant:contact_info:street_address" content="6027 FM 3538" />
    <meta property="restaurant:contact_info:locality" content="Sealy" />
    <meta property="restaurant:contact_info:region" content="TX" />
    <meta property="restaurant:contact_info:postal_code" content="77474" />
    <meta property="restaurant:contact_info:country_name" content="United States" />
    <meta property="restaurant:contact_info:phone_number" content="+1-512-607-6232" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullOgImage} />

    <!-- DNS prefetch + preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://online.skytab.com" />

    <!-- Fonts -->
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Pacifico&family=Inter:wght@300;400;500;600;700&display=swap"
    />

    <!-- Sitewide JSON-LD schema (LocalBusiness + WebSite + Organization) -->
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />

    <!-- Page-specific schema slot -->
    <slot name="head" />
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript>
      <iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-PJMMSBX5"
        height="0"
        width="0"
        style="display:none;visibility:hidden"
      ></iframe>
    </noscript>
    <!-- End Google Tag Manager (noscript) -->

    <Header />
    <SideRail />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
