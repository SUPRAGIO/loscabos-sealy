---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Catering Request — Los Cabos Mexican Grill | Sealy, TX" description="Request catering from Los Cabos Mexican Grill in Sealy, TX. Fajita buffets, enchiladas, and more for groups of 25+.">

<div class="cat-page">
  <div class="cat-wrap">

    <div class="cat-hdr">
      <img src="/images/logo.png" alt="Los Cabos Mexican Grill" class="cat-hdr-logo"/>
      <div class="cat-hdr-eyebrow">Events &amp; Catering</div>
      <h1 class="cat-hdr-h1">Build Your Catering Order</h1>
      <p class="cat-hdr-sub">Pick a buffet, load up the a la carte, tell us when &amp; where — we’ll call you back within 24 hours to confirm. Minimum 25 guests. Free delivery inside Sealy city limits.</p>
    </div>

    <div id="progress-bar" class="progress-bar">
      <div class="step-pip active" data-step="1"><div class="pip-circle">1</div><div class="pip-label">Event Details</div></div>
      <div class="pip-line"></div>
      <div class="step-pip" data-step="2"><div class="pip-circle">2</div><div class="pip-label">Build Your Menu</div></div>
      <div class="pip-line"></div>
      <div class="step-pip" data-step="3"><div class="pip-circle">3</div><div class="pip-label">Review &amp; Submit</div></div>
    </div>

    <form name="catering-request" method="POST" data-netlify="true" netlify-honeypot="bot-field" id="catering-form">
      <input type="hidden" name="form-name" value="catering-request"/>
      <p class="hp"><label>Don’t fill this out: <input name="bot-field"/></label></p>
      <input type="hidden" name="selected-package" id="hidden-package"/>
      <input type="hidden" name="selected-addons" id="hidden-addons"/>
      <input type="hidden" name="estimated-total" id="hidden-total"/>

      <div id="step-1" class="form-step">
        <div class="form-card">
          <h2 class="form-section-title">Tell Us About Your Event</h2>
          <div class="form-grid">
            <div class="form-group"><label>Your Name *</label><input type="text" name="name" required placeholder="Full name"/></div>
            <div class="form-group"><label>Phone Number *</label><input type="tel" name="phone" required placeholder="(512) 000-0000"/></div>
            <div class="form-group"><label>Email Address *</label><input type="email" name="email" required placeholder="you@email.com"/></div>
            <div class="form-group"><label>Event Date *</label><input type="date" name="event-date" required/></div>
            <div class="form-group"><label>Start Time *</label><input type="time" name="start-time" required/></div>
            <div class="form-group"><label>Estimated Guest Count *</label><input type="number" name="guests" required min="25" placeholder="Minimum 25"/></div>
            <div class="form-group full-width"><label>Event Location / Address *</label><input type="text" name="location" required placeholder="Full address or venue name"/></div>
            <div class="form-group"><label>Event Type</label><select name="event-type"><option value="">Select event type</option><option>Birthday Party</option><option>Corporate Event</option><option>Wedding Reception</option><option>Wedding Rehearsal Dinner</option><option>Family Reunion</option><option>Quinceñera</option><option>Graduation Party</option><option>Anniversary</option><option>Company Picnic</option><option>Church Event</option><option>Holiday Party</option><option>Other</option></select></div>
            <div class="form-group"><label>Service Style *</label><select name="service-style" required><option value="">How should we serve?</option><option>Full-Service On-Site (we cook &amp; serve)</option><option>Drop-Off &amp; Setup (hot trays, sternos, chafers)</option><option>Delivery Only</option><option>Pick-Up at Restaurant</option></select></div>
          </div>
          <div class="form-group full-width" style="margin-top:16px;"><label>How’d you hear about us?</label><select name="referral"><option value="">Select one</option><option>Google Search</option><option>Facebook / Instagram</option><option>Friend or Family</option><option>Catered an event I attended</option><option>Drove by the restaurant</option><option>Other</option></select></div>
          <div style="text-align:right;margin-top:28px;"><button type="button" class="btn-next" onclick="goToStep(2)">Next: Build Your Menu &rarr;</button></div>
        </div>
      </div>

      <div id="step-2" class="form-step" style="display:none;">
        <div class="form-card">
          <h2 class="form-section-title">Pick Your Buffet Package</h2>
          <p class="form-section-sub">All buffets include plates &amp; plasticware. Free delivery inside Sealy city limits. Prices are per person. Need something custom? Call <a href="tel:+15126076232" class="inline-tel">(512) 607-6232</a>.</p>
          <div class="package-grid">

            <label class="package-card">
              <input type="radio" name="package" value="Our Famous Fajita Buffet - $17.95/person" required data-price="17.95"/>
              <div class="package-inner">
                <div class="package-ribbon">Most Popular</div>
                <div class="package-price">$17.95<span>/person</span></div>
                <div class="package-name">Our Famous Fajita Buffet</div>
                <ul class="package-includes"><li>Beef &amp; Chicken Fajitas</li><li>Cheese Enchiladas</li><li>Rice &amp; Beans</li><li>Guacamole, Pico de Gallo &amp; Sour Cream</li><li>Shredded Cheese &amp; Homemade Tortillas</li><li>Chips &amp; Salsa</li></ul>
              </div>
            </label>

            <label class="package-card">
              <input type="radio" name="package" value="Taco & Enchilada Buffet - $12.99/person" data-price="12.99"/>
              <div class="package-inner">
                <div class="package-price">$12.99<span>/person</span></div>
                <div class="package-name">Taco &amp; Enchilada Buffet</div>
                <ul class="package-includes"><li>Cheese Enchiladas</li><li>Chicken Quesadillas</li><li>Build-Your-Own Crispy Tacos</li><li>Ground Beef, Lettuce, Tomatoes, Shredded Cheese &amp; Sour Cream</li><li>Rice &amp; Beans</li><li>Chips &amp; Salsa</li></ul>
              </div>
            </label>

            <label class="package-card">
              <input type="radio" name="package" value="American Country Buffet - $13.99/person" data-price="13.99"/>
              <div class="package-inner">
                <div class="package-price">$13.99<span>/person</span></div>
                <div class="package-name">American Country Buffet</div>
                <div class="pkg-pick"><label>Pick your main:</label><select name="american-main" class="pkg-select"><option value="">Choose one</option><option>Chicken Fried Steak (plus 2 sides)</option><option>Chicken w/ White Country Gravy (plus 2 sides)</option><option>Hamburger Steak w/ Grilled Onions &amp; Brown Gravy (plus 2 sides)</option></select></div>
                <div class="pkg-pick"><label>Side #1:</label><select name="american-side-1" class="pkg-select"><option value="">Choose a side</option><option>Green Beans</option><option>Mashed Potatoes</option><option>Mixed Vegetables</option><option>Corn</option><option>Fries</option><option>Dinner Salad w/ Ranch Dressing</option></select></div>
                <div class="pkg-pick"><label>Side #2:</label><select name="american-side-2" class="pkg-select"><option value="">Choose a side</option><option>Green Beans</option><option>Mashed Potatoes</option><option>Mixed Vegetables</option><option>Corn</option><option>Fries</option><option>Dinner Salad w/ Ranch Dressing</option></select></div>
                </div>
            </label>

            <label class="package-card">
              <input type="radio" name="package" value="Chicken & Pasta Buffet - $14.99/person" data-price="14.99"/>
              <div class="package-inner">
                <div class="package-price">$14.99<span>/person</span></div>
                <div class="package-name">Chicken &amp; Pasta Buffet</div>
                <ul class="package-includes"><li>Grilled Chicken Breast</li><li>Fettuccini Pasta w/ Toasted Garlic Bread</li></ul>
                <div class="pkg-pick"><label>Pick a side:</label><select name="pasta-side" class="pkg-select"><option value="">Choose a side</option><option>Green Beans</option><option>Broccoli</option><option>Mixed Vegetables</option><option>Corn</option></select></div>
                <div class="pkg-pick"><label>Pick a salad:</label><select name="pasta-salad" class="pkg-select"><option value="">Choose a salad</option><option>Caesar Salad</option><option>Dinner Salad w/ Ranch</option><option>Dinner Salad w/ Italian</option></select></div>
              </div>
            </label>

            <label class="package-card package-card-wide">
              <input type="radio" name="package" value="Tenderloin Buffet - $23.99/person" data-price="23.99"/>
              <div class="package-inner">
                <div class="package-ribbon ribbon-premium">Premium</div>
                <div class="package-price">$23.99<span>/person</span></div>
                <div class="package-name">Tenderloin Buffet</div>
                <ul class="package-includes"><li>Tenderloin Tips w/ Brown Gravy &amp; Mashed Potatoes</li><li>Plus 1 side of your choice</li></ul>
                <div class="pkg-pick"><label>Pick an extra side:</label><select name="tenderloin-side" class="pkg-select"><option value="">Choose a side</option><option>Green Beans</option><option>Mixed Vegetables</option><option>Corn</option><option>Fries</option></select></div>
                <div class="pkg-pick"><label>Pick a salad:</label><select name="tenderloin-salad" class="pkg-select"><option value="">Choose a salad</option><option>Caesar Salad</option><option>Dinner Salad w/ Ranch</option><option>Dinner Salad w/ Italian</option></select></div>
              </div>
            </label>

            <label class="package-card package-card-custom">
              <input type="radio" name="package" value="Custom - A la Carte Only" data-price="0"/>
              <div class="package-inner">
                <div class="package-name">Custom Order Only</div>
                <p class="package-custom-desc">Skip the buffet and just order a la carte trays and gallons below. We’ll call you to work out the details.</p>
              </div>
            </label>

          </div>
        </div>

        <div class="form-card">
          <h2 class="form-section-title">Fajitas by the Pound</h2>
          <p class="form-section-sub">Meat only. Rough rule of thumb: plan on ~1/3 lb per guest. Add your own tortillas below.</p>
          <div class="qty-row">
            <div class="qty-info"><div class="qty-name">Beef Fajitas</div><div class="qty-price">$19.99 / lb</div></div>
            <div class="qty-ctrl"><button type="button" class="qty-btn" data-action="dec">&minus;</button><input type="number" class="qty-input" name="qty-beef-fajita" data-item="Beef Fajitas" data-price="19.99" min="0" value="0"/><button type="button" class="qty-btn" data-action="inc">+</button><span class="qty-unit">lb</span></div>
          </div>
          <div class="qty-row">
            <div class="qty-info"><div class="qty-name">Chicken Fajitas</div><div class="qty-price">$17.99 / lb</div></div>
            <div class="qty-ctrl"><button type="button" class="qty-btn" data-action="dec">&minus;</button><input type="number" class="qty-input" name="qty-chicken-fajita" data-item="Chicken Fajitas" data-price="17.99" min="0" value="0"/><button type="button" class="qty-btn" data-action="inc">+</button><span class="qty-unit">lb</span></div>
          </div>
          <div class="qty-row">
            <div class="qty-info"><div class="qty-name">Vegetable Fajitas</div><div class="qty-price">$17.99 / lb</div></div>
            <div class="qty-ctrl"><button type="button" class="qty-btn" data-action="dec">&minus;</button><input type="number" class="qty-input" name="qty-veg-fajita" data-item="Vegetable Fajitas" data-price="17.99" min="0" value="0"/><button type="button" class="qty-btn" data-action="inc">+</button><span class="qty-unit">lb</span></div>
          </div>
        </div>

        <div class="form-card">
          <h2 class="form-section-title">Enchilada Trays (serves ~30)</h2>
          <div class="qty-row">
            <div class="qty-info"><div class="qty-name">Enchiladas — pick a style</div><div class="qty-price">Starts at $55.00 per tray</div></div>
            <div class="qty-ctrl qty-ctrl-wide">
              <select class="pkg-select qty-variant" name="enchilada-style"><option value="">Style — choose filling</option><option data-price="55">Ground Beef</option><option data-price="55">Cheese</option><option data-price="55">Shredded Chicken</option><option data-price="60">Enchiladas Verdes (green chicken)</option><option data-price="60">Enchiladas Tomatillos (green cheese)</option><option data-price="80">Enchiladas al Carbon</option></select>
              <button type="button" class="qty-btn" data-action="dec">&minus;</button><input type="number" class="qty-input" name="qty-enchilada-tray" data-item="Enchilada Tray" min="0" value="0"/><button type="button" class="qty-btn" data-action="inc">+</button><span class="qty-unit">trays</span>
            </div>
          </div>
        </div>

        <div class="form-card">
          <h2 class="form-section-title">Quesadilla &amp; Other Trays (serves ~30)</h2>
          <div class="qty-row">
            <div class="qty-info"><div class="qty-name">Cheese Quesadilla</div><div class="qty-price">$55.00 / tray</div></div>
            <div class="qty-ctrl"><button type="button" class="qty-btn" data-action="dec">&minus;</button><input type="number" class="qty-input" name="qty-cheese-ques" data-item="Cheese Quesadilla Tray" data-price="55" min="0" value="0"/><button type="button" class="qty-btn" data-action="inc">+</button><span class="qty-unit">trays</span></div>
          </div>
          <div class="qty-row">
            <div class="qty-info"><div class="qty-name">Spinach Quesadilla</div><div class="qty-price">$65.00 / tray</div></div>
            <div class="qty-ctrl"><button type="button" class="qty-btn" data-action="dec">&minus;</button><input type="number" class="qty-input" name="qty-spinach-ques" data-item="Spinach Quesadilla Tray" data-price="65" min="0" value="0"/><button type="button" class="qty-btn" data-action="inc">+</button><span class="qty-unit">trays</span></div>
          </div>
          <div class="qty-row">
            <div class="qty-info"><div class="qty-name">Fajita Quesadilla</div><div class="qty-price">$70.00 / tray</div></div>
            <div class="qty-ctrl qty-ctrl-wide">
              <select class="pkg-select qty-variant" name="fajita-ques-meat"><option value="">Choose: beef or chicken</option><option>Beef</option><option>Chicken</option></select>
              <button type="button" class="qty-btn" data-action="dec">&minus;</button><input type="number" class="qty-input" name="qty-fajita-ques" data-item="Fajita Quesadilla Tray" data-price="70" min="0" value="0"/><button type="button" class="qty-btn" data-action="inc">+</button><span class="qty-unit">trays</span>
            </div>
          </div>
          <div class="qty-row">
            <div class="qty-info"><div class="qty-name">Shrimp Quesadilla</div><div class="qty-price">$75.00 / tray</div></div>
            <div class="qty-ctrl"><button type="button" class="qty-btn" data-action="dec">&minus;</button><input type="number" class="qty-input" name="qty-shrimp-ques" data-item="Shrimp Quesadilla Tray" data-price="75" min="0" value="0"/><button type="button" class="qty-btn" data-action="inc">+</button><span class="qty-unit">trays</span></div>
          </div>
          <div class="qty-row">
            <div class="qty-info"><div class="qty-name">Crispy Tacos</div><div class="qty-price">$55.00 / tray</div></div>
            <div class="qty-ctrl qty-ctrl-wide">
              <select class="pkg-select qty-variant" name="crispy-taco-meat"><option value="">Choose filling</option><option>Ground Beef</option><option>Shredded Chicken</option></select>
              <button type="button" class="qty-btn" data-action="dec">&minus;</button><input type="number" class="qty-input" name="qty-crispy-taco" data-item="Crispy Taco Tray" data-price="55" min="0" value="0"/><button type="button" class="qty-btn" data-action="inc">+</button><span class="qty-unit">trays</span>
            </div>
          </div>
          <div class="qty-row">
            <div class="qty-info"><div class="qty-name">Fried Burritos</div><div class="qty-price">$55.00 / tray</div></div>
            <div class="qty-ctrl qty-ctrl-wide">
              <select class="pkg-select qty-variant" name="fried-burrito-meat"><option value="">Choose filling</option><option>Ground Beef</option><option>Shredded Chicken</option></select>
              <button type="button" class="qty-btn" data-action="dec">&minus;</button><input type="number" class="qty-input" name="qty-fried-burrito" data-item="Fried Burrito Tray" data-price="55" min="0" value="0"/><button type="button" class="qty-btn" data-action="inc">+</button><span class="qty-unit">trays</span>
            </div>
          </div>
        </div>

        <div class="form-card">
          <h2 class="form-section-title">Sides, Desserts &amp; Extras</h2>
          <div class="qty-row">
            <div class="qty-info"><div class="qty-name">Rice &amp; Beans</div><div class="qty-price">$80.00 — serves 30</div></div>
            <div class="qty-ctrl"><button type="button" class="qty-btn" data-action="dec">&minus;</button><input type="number" class="qty-input" name="qty-rice-beans" data-item="Rice & Beans (30ppl)" data-price="80" min="0" value="0"/><button type="button" class="qty-btn" data-action="inc">+</button><span class="qty-unit">orders</span></div>
          </div>
          <div class="qty-row">
            <div class="qty-info"><div class="qty-name">Rice Only</div><div class="qty-price">$45.00 — serves 30</div></div>
            <div class="qty-ctrl"><button type="button" class="qty-btn" data-action="dec">&minus;</button><input type="number" class="qty-input" name="qty-rice-only" data-item="Rice Only (30ppl)" data-price="45" min="0" value="0"/><button type="button" class="qty-btn" data-action="inc">+</button><span class="qty-unit">orders</span></div>
          </div>
          <div class="qty-row">
            <div class="qty-info"><div class="qty-name">Beans Only</div><div class="qty-price">$45.00 — serves 30</div></div>
            <div class="qty-ctrl"><button type="button" class="qty-btn" data-action="dec">&minus;</button><input type="number" class="qty-input" name="qty-beans-only" data-item="Beans Only (30ppl)" data-price="45" min="0" value="0"/><button type="button" class="qty-btn" data-action="inc">+</button><span class="qty-unit">orders</span></div>
          </div>
          <div class="qty-row">
            <div class="qty-info"><div class="qty-name">Sopapillas</div><div class="qty-price">$49.00 / tray of 30</div></div>
            <div class="qty-ctrl"><button type="button" class="qty-btn" data-action="dec">&minus;</button><input type="number" class="qty-input" name="qty-sopapillas" data-item="Sopapillas Tray" data-price="49" min="0" value="0"/><button type="button" class="qty-btn" data-action="inc">+</button><span class="qty-unit">trays</span></div>
          </div>
          <div class="qty-row">
            <div class="qty-info"><div class="qty-name">Flan</div><div class="qty-price">$49.00 / tray of 30</div></div>
            <div class="qty-ctrl"><button type="button" class="qty-btn" data-action="dec">&minus;</button><input type="number" class="qty-input" name="qty-flan" data-item="Flan Tray" data-price="49" min="0" value="0"/><button type="button" class="qty-btn" data-action="inc">+</button><span class="qty-unit">trays</span></div>
          </div>
          <div class="qty-row">
            <div class="qty-info"><div class="qty-name">Tortillas</div><div class="qty-price">$9.95 / dozen — flour or corn</div></div>
            <div class="qty-ctrl qty-ctrl-wide">
              <select class="pkg-select qty-variant" name="tortilla-type"><option value="">Flour or corn?</option><option>Flour</option><option>Corn</option><option>Mixed (half &amp; half)</option></select>
              <button type="button" class="qty-btn" data-action="dec">&minus;</button><input type="number" class="qty-input" name="qty-tortillas" data-item="Tortillas (dozen)" data-price="9.95" min="0" value="0"/><button type="button" class="qty-btn" data-action="inc">+</button><span class="qty-unit">dozen</span>
            </div>
          </div>
          <div class="qty-row">
            <div class="qty-info"><div class="qty-name">Tamales</div><div class="qty-price">$10.99 / dozen</div></div>
            <div class="qty-ctrl"><button type="button" class="qty-btn" data-action="dec">&minus;</button><input type="number" class="qty-input" name="qty-tamales" data-item="Tamales (dozen)" data-price="10.99" min="0" value="0"/><button type="button" class="qty-btn" data-action="inc">+</button><span class="qty-unit">dozen</span></div>
          </div>
        </div>

        <div class="form-card">
          <h2 class="form-section-title">Salsas, Guac &amp; Queso — by the Gallon</h2>
          <div class="qty-row">
            <div class="qty-info"><div class="qty-name">Pico de Gallo</div><div class="qty-price">$35.00 / gal</div></div>
            <div class="qty-ctrl"><button type="button" class="qty-btn" data-action="dec">&minus;</button><input type="number" class="qty-input" name="qty-pico" data-item="Pico de Gallo (gal)" data-price="35" min="0" value="0"/><button type="button" class="qty-btn" data-action="inc">+</button><span class="qty-unit">gal</span></div>
          </div>
          <div class="qty-row">
            <div class="qty-info"><div class="qty-name">Red Salsa</div><div class="qty-price">$35.00 / gal</div></div>
            <div class="qty-ctrl"><button type="button" class="qty-btn" data-action="dec">&minus;</button><input type="number" class="qty-input" name="qty-red-salsa" data-item="Red Salsa (gal)" data-price="35" min="0" value="0"/><button type="button" class="qty-btn" data-action="inc">+</button><span class="qty-unit">gal</span></div>
          </div>
          <div class="qty-row">
            <div class="qty-info"><div class="qty-name">Green Salsa</div><div class="qty-price">$40.00 / gal</div></div>
            <div class="qty-ctrl"><button type="button" class="qty-btn" data-action="dec">&minus;</button><input type="number" class="qty-input" name="qty-green-salsa" data-item="Green Salsa (gal)" data-price="40" min="0" value="0"/><button type="button" class="qty-btn" data-action="inc">+</button><span class="qty-unit">gal</span></div>
          </div>
          <div class="qty-row">
            <div class="qty-info"><div class="qty-name">Guacamole</div><div class="qty-price">$70.00 / gal</div></div>
            <div class="qty-ctrl"><button type="button" class="qty-btn" data-action="dec">&minus;</button><input type="number" class="qty-input" name="qty-guac" data-item="Guacamole (gal)" data-price="70" min="0" value="0"/><button type="button" class="qty-btn" data-action="inc">+</button><span class="qty-unit">gal</span></div>
          </div>
          <div class="qty-row">
            <div class="qty-info"><div class="qty-name">Guacamole Mexicano</div><div class="qty-price">$85.00 / gal</div></div>
            <div class="qty-ctrl"><button type="button" class="qty-btn" data-action="dec">&minus;</button><input type="number" class="qty-input" name="qty-guac-mex" data-item="Guacamole Mexicano (gal)" data-price="85" min="0" value="0"/><button type="button" class="qty-btn" data-action="inc">+</button><span class="qty-unit">gal</span></div>
          </div>
          <div class="qty-row">
            <div class="qty-info"><div class="qty-name">Chili con Queso</div><div class="qty-price">$70.00 / gal</div></div>
            <div class="qty-ctrl"><button type="button" class="qty-btn" data-action="dec">&minus;</button><input type="number" class="qty-input" name="qty-queso" data-item="Chili con Queso (gal)" data-price="70" min="0" value="0"/><button type="button" class="qty-btn" data-action="inc">+</button><span class="qty-unit">gal</span></div>
          </div>
        </div>

        <div class="form-card">
          <h2 class="form-section-title">Service Add-Ons</h2>
          <label class="toggle-row">
            <input type="checkbox" name="iced-tea" value="Iced Tea Service ($1.50/person)"/>
            <div class="toggle-info"><div class="toggle-name">Iced Tea Service</div><div class="toggle-sub">Sweet &amp; unsweet. Includes ice, cups &amp; lemon.</div></div>
            <div class="toggle-price">$1.50 / person</div>
          </label>
          <label class="toggle-row">
            <input type="checkbox" name="margarita-machine" value="Margarita Machine Rental"/>
            <div class="toggle-info"><div class="toggle-name">Margarita Machine Rental</div><div class="toggle-sub">Frozen margaritas for your crew. Call for pricing &amp; availability.</div></div>
            <div class="toggle-price">Call for pricing</div>
          </label>
          <label class="toggle-row">
            <input type="checkbox" name="sternos" value="Sternos & Chafers"/>
            <div class="toggle-info"><div class="toggle-name">Sternos &amp; Chafers</div><div class="toggle-sub">Keep everything hot at your venue. Recommended for drop-off orders.</div></div>
            <div class="toggle-price">Included w/ setup</div>
          </label>
        </div>

        <div class="form-card">
          <h2 class="form-section-title">Custom Requests or Special Notes</h2>
          <label style="display:block;font-family:'Barlow Condensed',sans-serif;font-size:13px;letter-spacing:.08em;text-transform:uppercase;color:#4A3728;margin-bottom:6px;">Tell us anything we should know</label>
          <textarea name="notes" rows="4" placeholder="Dietary restrictions, allergies, setup timing, specific dish requests, dessert ideas, decor — whatever you need."></textarea>
          <p style="font-family:'Barlow',sans-serif;font-size:13px;color:#6b5a4a;margin-top:10px;">Want something we didn’t list? Just write it in. We’ll work it out when we call you back.</p>
        </div>

        <div class="step-nav">
          <button type="button" class="btn-back" onclick="goToStep(1)">&larr; Back</button>
          <div class="live-total">Estimated total: <strong id="live-total">$0.00</strong></div>
          <button type="button" class="btn-next" onclick="goToStep(3)">Review My Request &rarr;</button>
        </div>
      </div>

      <div id="step-3" class="form-step" style="display:none;">
        <div class="form-card">
          <h2 class="form-section-title">Review Your Request</h2>
          <div id="review-content" class="review-content"></div>
          <div class="review-note"><p><strong>Heads up:</strong> Prices shown are per-person / per-unit and subject to change. We’ll confirm availability and final pricing when we call you back within 24 hours.</p></div>
          <div class="step-nav">
            <button type="button" class="btn-back" onclick="goToStep(2)">&larr; Edit Menu</button>
            <button type="submit" class="btn-submit">Send Catering Request &#10003;</button>
          </div>
        </div>
      </div>

    </form>

    <div id="success-msg" class="success-msg" style="display:none;">
      <div class="success-icon">&#10003;</div>
      <h2>Request Received!</h2>
      <p>Thanks — we’ll call you back within 24 hours to confirm your event details and finalize pricing.</p>
      <p>Questions? Call us at <a href="tel:+15126076232">(512) 607-6232</a>.</p>
    </div>

  </div>
</div>

<style>
