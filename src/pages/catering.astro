<script is:inline>
  document.addEventListener('click', function(e){
    var btn = e.target.closest('.qty-btn');
    if (!btn) return;
    var row = btn.closest('.qty-ctrl');
    var input = row ? row.querySelector('.qty-input') : null;
    if (!input) return;
    var val = parseInt(input.value) || 0;
    if (btn.dataset.action === 'inc') val++;
    else if (val > 0) val--;
    input.value = val;
    updateLiveTotal();
  });

  document.addEventListener('input', function(e){
    if (e.target.matches('.qty-input, .qty-variant, input[name=guests], input[name=package], input[name=iced-tea], .pkg-select')) {
      updateLiveTotal();
    }
  });
  document.addEventListener('change', function(e){
    if (e.target.matches('input[type=radio][name=package], input[type=checkbox]')) updateLiveTotal();
  });

  function parseEnchiladaPrice(){
    var sel = document.querySelector('select[name=enchilada-style]');
    if (!sel || !sel.value) return 55;
    var opt = sel.options[sel.selectedIndex];
    return parseFloat(opt.dataset.price || 55);
  }

  function updateLiveTotal(){
    var total = 0;
    var pkg = document.querySelector('input[name=package]:checked');
    var guestsEl = document.querySelector('input[name=guests]');
    var guests = guestsEl ? (parseInt(guestsEl.value) || 0) : 0;
    if (pkg && pkg.dataset.price) total += parseFloat(pkg.dataset.price) * guests;
    var tea = document.querySelector('input[name=iced-tea]');
    if (tea && tea.checked) total += 1.5 * guests;
    document.querySelectorAll('.qty-input').forEach(function(inp){
      var qty = parseInt(inp.value) || 0;
      if (qty <= 0) return;
      var price = parseFloat(inp.dataset.price || 0);
      if (inp.name === 'qty-enchilada-tray') price = parseEnchiladaPrice();
      total += qty * price;
    });
    var el = document.getElementById('live-total');
    if (el) el.textContent = '$' + total.toFixed(2);
    var hidden = document.getElementById('hidden-total');
    if (hidden) hidden.value = total.toFixed(2);
  }

  function goToStep(n){
    if (n === 2) {
      var required = ['name','phone','email','event-date','start-time','guests','location','service-style'];
      for (var i=0; i<required.length; i++){
        var el = document.querySelector('[name='+required[i]+']');
        if (!el || !el.value) { alert('Please fill in all required fields in Step 1.'); if (el) el.focus(); return; }
      }
      if (parseInt(document.querySelector('[name=guests]').value) < 25) { alert('Minimum guest count is 25.'); return; }
    }
    if (n === 3) {
      var pkg = document.querySelector('input[name=package]:checked');
      if (!pkg) { alert('Please pick a buffet package (or choose Custom Order Only).'); return; }
      buildReview();
    }
    document.querySelectorAll('.form-step').forEach(function(s){ s.style.display='none'; });
    document.getElementById('step-'+n).style.display='block';
    document.querySelectorAll('.step-pip').forEach(function(p,i){
      p.classList.remove('active','done');
      if (i+1===n) p.classList.add('active');
      if (i+1<n) p.classList.add('done');
    });
    window.scrollTo({top:0, behavior:'smooth'});
  }

  function buildReview(){
    var get = function(n){ var e=document.querySelector('[name='+n+']'); return e?e.value:''; };
    var pkg = document.querySelector('input[name=package]:checked');
    var pkgVal = pkg ? pkg.value : 'None';
    var guests = parseInt(get('guests')) || 0;

    var picks = [];
    ['american-main','american-side-1','american-side-2','pasta-side','pasta-salad','tenderloin-side','tenderloin-salad'].forEach(function(n){
      var v = get(n); if (v) picks.push(v);
    });

    var addons = [];
    document.querySelectorAll('.qty-input').forEach(function(inp){
      var qty = parseInt(inp.value) || 0;
      if (qty <= 0) return;
      var name = inp.dataset.item;
      var price = parseFloat(inp.dataset.price || 0);
      if (inp.name === 'qty-enchilada-tray') {
        var style = get('enchilada-style') || 'style TBD';
        name = 'Enchilada Tray (' + style + ')';
        price = parseEnchiladaPrice();
      }
      if (inp.name === 'qty-fajita-ques' && get('fajita-ques-meat')) name += ' ('+get('fajita-ques-meat')+')';
      if (inp.name === 'qty-crispy-taco' && get('crispy-taco-meat')) name += ' ('+get('crispy-taco-meat')+')';
      if (inp.name === 'qty-fried-burrito' && get('fried-burrito-meat')) name += ' ('+get('fried-burrito-meat')+')';
      if (inp.name === 'qty-tortillas' && get('tortilla-type')) name += ' ('+get('tortilla-type')+')';
      addons.push({name: name, qty: qty, price: price, sub: qty*price});
    });

    var toggles = [];
    document.querySelectorAll('input[type=checkbox][name]').forEach(function(c){
      if (c.checked && c.name !== 'bot-field') toggles.push(c.value);
    });

    document.getElementById('hidden-package').value = pkgVal + (picks.length ? ' [' + picks.join(', ') + ']' : '');
    document.getElementById('hidden-addons').value = addons.map(function(a){return a.qty+' x '+a.name+' (@$'+a.price.toFixed(2)+')';}).concat(toggles).join(' | ') || 'None';

    var html = '';
    html += '<h3>Event Details</h3><ul>';
    html += '<li><strong>Name:</strong> '+get('name')+'</li>';
    html += '<li><strong>Phone:</strong> '+get('phone')+'</li>';
    html += '<li><strong>Email:</strong> '+get('email')+'</li>';
    html += '<li><strong>Date:</strong> '+get('event-date')+' at '+get('start-time')+'</li>';
    html += '<li><strong>Location:</strong> '+get('location')+'</li>';
    html += '<li><strong>Guests:</strong> '+guests+'</li>';
    if (get('event-type')) html += '<li><strong>Event Type:</strong> '+get('event-type')+'</li>';
    html += '<li><strong>Service:</strong> '+get('service-style')+'</li>';
    html += '</ul>';
    html += '<h3>Buffet Package</h3><p>'+pkgVal+'</p>';
    if (picks.length) html += '<ul>'+picks.map(function(p){return '<li>'+p+'</li>';}).join('')+'</ul>';
    if (addons.length) {
      html += '<h3>A la Carte</h3><ul>';
      addons.forEach(function(a){ html += '<li>'+a.qty+' x '+a.name+' — $'+a.sub.toFixed(2)+'</li>'; });
      html += '</ul>';
    }
    if (toggles.length) { html += '<h3>Service Add-Ons</h3><ul>'+toggles.map(function(t){return '<li>'+t+'</li>';}).join('')+'</ul>'; }
    if (get('notes')) html += '<h3>Notes</h3><p>'+get('notes')+'</p>';

    var total = 0;
    if (pkg && pkg.dataset.price) total += parseFloat(pkg.dataset.price) * guests;
    var tea = document.querySelector('input[name=iced-tea]');
    if (tea && tea.checked) total += 1.5 * guests;
    addons.forEach(function(a){ total += a.sub; });
    html += '<div class="review-total">Estimated total: <span>$'+total.toFixed(2)+'</span></div>';
    document.getElementById('review-content').innerHTML = html;
  }

  document.getElementById('catering-form').addEventListener('submit', async function(e){
    e.preventDefault();
    var data = new FormData(this);
    try {
      await fetch('/', { method:'POST', headers:{'Content-Type':'application/x-www-form-urlencoded'}, body: new URLSearchParams(data).toString() });
      document.getElementById('catering-form').style.display='none';
      document.getElementById('progress-bar').style.display='none';
      document.getElementById('success-msg').style.display='block';
      window.scrollTo({top:0, behavior:'smooth'});
    } catch(err) { alert('Something went wrong. Please call us at (512) 607-6232.'); }
  });
</script>

</Layout>
