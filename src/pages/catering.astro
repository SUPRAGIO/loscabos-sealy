---
import Base from "@/layouts/Base.astro";
import SectionTitle from "@/components/SectionTitle.astro";

const packs = [
  {
    name: "Famous Fajita Buffet",
    tagline: "The Cabos signature",
    desc: "Beef and chicken fajitas, cheese enchiladas, rice and beans, guacamole, pico de gallo, sour cream, shredded cheese, homemade tortillas, chips and salsa. The full spread.",
    pop: true,
  },
  {
    name: "Taco & Enchilada Buffet",
    tagline: "Crowd pleaser",
    desc: "Cheese enchiladas, chicken quesadillas, build your own crispy tacos with all the fixings, rice and beans, chips and salsa. Easy to love, easy to feed.",
    pop: false,
  },
  {
    name: "Chicken & Pasta Buffet",
    tagline: "A different lane",
    desc: "Grilled chicken breast, fettuccine pasta, toasted garlic bread. Choice of side and choice of Caesar or dinner salad with ranch or Italian.",
    pop: false,
  },
  {
    name: "Tenderloin Buffet",
    tagline: "Stepping it up",
    desc: "Tenderloin tips with brown gravy, mashed potatoes, plus one side. Choice of Caesar or dinner salad with ranch or Italian. The plate that closes the deal.",
    pop: false,
  },
  {
    name: "American Country Buffet",
    tagline: "Down home",
    desc: "Choice of chicken fried steak, country chicken with white gravy, or hamburger steak with grilled onions and brown gravy. Two sides plus a dinner salad.",
    pop: false,
  },
  {
    name: "By the Pound, by the Tray",
    tagline: "Build your own",
    desc: "Beef, chicken, or veggie fajitas by the pound. Trays of enchiladas, quesadillas, crispy tacos, fried burritos. Gallons of pico, guac, salsa, queso. Dozens of tortillas and tamales.",
    pop: false,
  },
];
---

<Base
  title="Catering in Sealy, TX | Los Cabos Mexican Grill | Fajita Buffets"
  description="Tex Mex catering in Sealy, Brookshire, Bellville TX. Fajita Buffets, Tenderloin, by the pound. Free delivery in city limits. 25 person minimum."
>
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow-script">Catering & big tables</span>
      <h1>Feed the whole crew.</h1>
      <p>
        Birthdays, graduations, weddings, work lunches, soccer wrap ups,
        Sunday after church. We've cooked for all of it. Tell us the head
        count and the day — we'll bring the fiesta.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionTitle
        eyebrow="Six ways to feed a room"
        title="Pick your spread."
        sub="Free delivery inside city limits. Custom menus on request. Add iced tea service, margarita machine rentals, sopapillas, flan, tamales — whatever the occasion calls for."
      />

      <div class="packs">
        {
          packs.map((p) => (
            <article class:list={["pack", { pop: p.pop }]}>
              {p.pop && <span class="pop-tag">Most ordered</span>}
              <span class="serves">{p.tagline}</span>
              <h3>{p.name}</h3>
              <p>{p.desc}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section catering-form-section">
    <div class="container form-grid">
      <div>
        <SectionTitle
          eyebrow="Tell us about your event"
          title="Get a quote, fast."
          align="left"
          sub="We'll get back to you within one business day. Promise."
        />
        <ul class="contact-list">
          <li><strong>Call:</strong> <a href="tel:+15126076232">(512) 607-6232</a></li>
          <li><strong>Email:</strong> <a href="mailto:catering@loscabossealy.com">catering@loscabossealy.com</a></li>
          <li><strong>Minimum:</strong> 25 people. Smaller crew? Grab a <a href="/family-packs">family pack</a>.</li>
          <li><strong>Delivery:</strong> Free inside Sealy city limits.</li>
          <li><strong>Lead time:</strong> 72 hours preferred. Tighter? Call us — we'll figure it out.</li>
        </ul>
      </div>

      <form
        class="cater-form"
        name="catering"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        action="/catering?sent=true"
      >
        <input type="hidden" name="form-name" value="catering" />
        <p class="hp">
          <label>Don't fill this out: <input name="bot-field" /></label>
        </p>

        <div class="field-row">
          <div class="field">
            <label for="name">Your name</label>
            <input id="name" name="name" type="text" required />
          </div>
          <div class="field">
            <label for="phone">Phone</label>
            <input id="phone" name="phone" type="tel" required />
          </div>
        </div>

        <div class="field">
          <label for="email">Email</label>
          <input id="email" name="email" type="email" required />
        </div>

        <div class="field-row">
          <div class="field">
            <label for="event-date">Event date</label>
            <input id="event-date" name="event-date" type="date" required />
          </div>
          <div class="field">
            <label for="head-count">Head count <span class="field-hint">(25 minimum)</span></label>
            <input id="head-count" name="head-count" type="number" min="25" placeholder="25+" required />
          </div>
        </div>

        <div class="field">
          <label for="package">Package interest</label>
          <select id="package" name="package">
            <option>Famous Fajita Buffet</option>
            <option>Taco & Enchilada Buffet</option>
            <option>Chicken & Pasta Buffet</option>
            <option>Tenderloin Buffet</option>
            <option>American Country Buffet</option>
            <option>By the Pound / By the Tray</option>
            <option>Custom — let's talk</option>
          </select>
        </div>

        <fieldset class="field addons-field">
          <legend>Add ons <span class="field-hint">(pick any)</span></legend>
          <div class="addons-grid">
            <label class="addon">
              <input type="checkbox" name="add-ons[]" value="Iced Tea Service" />
              <span>Iced Tea Service</span>
            </label>
            <label class="addon">
              <input type="checkbox" name="add-ons[]" value="Margarita Machine Rental" />
              <span>Margarita Machine Rental</span>
            </label>
            <label class="addon">
              <input type="checkbox" name="add-ons[]" value="Chips & Salsa Trays" />
              <span>Chips & Salsa Trays</span>
            </label>
            <label class="addon">
              <input type="checkbox" name="add-ons[]" value="Chips & Queso Trays" />
              <span>Chips & Queso Trays</span>
            </label>
            <label class="addon">
              <input type="checkbox" name="add-ons[]" value="Guacamole Bowl" />
              <span>Guacamole Bowl</span>
            </label>
            <label class="addon">
              <input type="checkbox" name="add-ons[]" value="Tamales" />
              <span>Tamales</span>
            </label>
            <label class="addon">
              <input type="checkbox" name="add-ons[]" value="Sopapillas" />
              <span>Sopapillas</span>
            </label>
            <label class="addon">
              <input type="checkbox" name="add-ons[]" value="Flan" />
              <span>Flan</span>
            </label>
            <label class="addon">
              <input type="checkbox" name="add-ons[]" value="Churros" />
              <span>Churros</span>
            </label>
            <label class="addon">
              <input type="checkbox" name="add-ons[]" value="Setup & Serve Staff" />
              <span>Setup & Serve Staff</span>
            </label>
          </div>
        </fieldset>

        <div class="field">
          <label for="notes">Anything else?</label>
          <textarea id="notes" name="notes" placeholder="Allergies, vibe, location, dreams..."></textarea>
        </div>

        <button type="submit" class="btn btn-primary">Send Inquiry</button>
      </form>
    </div>
  </section>
</Base>

<style>
  .packs {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  @media (max-width: 1100px) {
    .packs {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .packs {
      grid-template-columns: 1fr;
    }
  }

  /* When the popular pack lifts -8px, the row neighbors look orphaned —
     reset the lift on smaller breakpoints so rows stay tidy */
  @media (max-width: 1100px) {
    .pack.pop {
      transform: none;
    }
    .pack.pop:hover {
      transform: translateY(-4px);
    }
  }

  .pack {
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: var(--radius);
    padding: 32px 28px 30px;
    box-shadow: var(--shadow-soft);
    position: relative;
    transition: transform 200ms ease, box-shadow 200ms ease;
    display: flex;
    flex-direction: column;
  }

  .pack.pop {
    background: var(--ink);
    color: var(--cream);
    transform: translateY(-8px);
    border: 0;
  }

  .pack.pop h3 {
    color: var(--cream);
  }

  .pack.pop p {
    color: rgba(255, 247, 236, 0.78);
  }

  .pack.pop .serves {
    color: var(--orange);
  }

  .pack:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow);
  }

  .pack.pop:hover {
    transform: translateY(-12px);
  }

  .pop-tag {
    position: absolute;
    top: -12px;
    left: 28px;
    background: var(--orange);
    color: #fff;
    font-family: var(--font-display);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 5px 14px;
    border-radius: 999px;
    box-shadow: 0 3px 0 rgba(0, 0, 0, 0.2);
  }

  .pack h3 {
    font-family: var(--font-display);
    font-size: 1.85rem;
    text-transform: uppercase;
    margin: 0 0 6px;
    color: var(--ink);
  }

  .serves {
    font-family: var(--font-display);
    color: var(--orange);
    letter-spacing: 0.08em;
    font-size: 0.85rem;
    text-transform: uppercase;
  }

  .pack p {
    color: var(--muted);
    margin: 14px 0 18px;
    line-height: 1.6;
    flex: 1;
  }

  /* Form */
  .catering-form-section {
    background: #fbeed8;
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 60px;
    align-items: flex-start;
  }

  @media (max-width: 900px) {
    .form-grid {
      grid-template-columns: 1fr;
    }
  }

  .contact-list {
    margin-top: 12px;
  }

  .contact-list li {
    margin-bottom: 10px;
    color: var(--muted);
  }

  .contact-list a {
    color: var(--orange);
  }

  .cater-form {
    background: #fff;
    border-radius: var(--radius);
    padding: 30px;
    box-shadow: var(--shadow-soft);
    border: 1px solid rgba(0, 0, 0, 0.06);
  }

  .hp {
    display: none;
  }

  .field-hint {
    font-weight: 400;
    color: var(--muted);
    font-size: 0.85rem;
    margin-left: 6px;
  }

  /* ===== Add-ons fieldset ===== */
  .addons-field {
    border: 0;
    padding: 0;
    margin: 0 0 18px;
  }

  .addons-field legend {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.95rem;
    color: var(--ink);
    margin-bottom: 12px;
    padding: 0;
  }

  .addons-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
  }

  @media (max-width: 540px) {
    .addons-grid {
      grid-template-columns: 1fr;
    }
  }

  .addon {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 14px;
    background: #fff;
    border: 1px solid rgba(42, 26, 16, 0.15);
    border-radius: 10px;
    cursor: pointer;
    transition: border-color 150ms ease, background 150ms ease;
    font-size: 0.95rem;
    color: var(--ink);
    user-select: none;
  }

  .addon:hover {
    border-color: var(--orange);
    background: rgba(232, 106, 38, 0.04);
  }

  .addon input[type="checkbox"] {
    appearance: none;
    width: 18px;
    height: 18px;
    border: 2px solid rgba(42, 26, 16, 0.3);
    border-radius: 4px;
    cursor: pointer;
    margin: 0;
    flex-shrink: 0;
    transition: border-color 150ms ease, background 150ms ease;
    position: relative;
  }

  .addon input[type="checkbox"]:checked {
    background: var(--orange);
    border-color: var(--orange);
  }

  .addon input[type="checkbox"]:checked::after {
    content: "";
    position: absolute;
    top: 1px;
    left: 4px;
    width: 4px;
    height: 9px;
    border: solid #fff;
    border-width: 0 2px 2px 0;
    transform: rotate(45deg);
  }

  .addon:has(input:checked) {
    border-color: var(--orange);
    background: rgba(232, 106, 38, 0.06);
  }

  .addon input[type="checkbox"]:focus-visible {
    outline: 2px solid var(--orange);
    outline-offset: 2px;
  }
</style>
