  .qty-btn { width: 32px; height: 32px; border-radius: 6px; border: 1.5px solid #d9ccb5; background: #fff; color: #1C1410; font-size: 18px; font-weight: 700; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.15s; padding: 0; }
  .qty-btn:hover { background: #F4621F; color: #fff; border-color: #F4621F; }
  .qty-input { width: 60px !important; text-align: center; padding: 6px 4px !important; font-weight: 700; font-size: 15px !important; }
  .qty-unit { font-family: 'Barlow Condensed', sans-serif; font-size: 13px; font-weight: 700; color: #8a7356; text-transform: uppercase; letter-spacing: .08em; }

  .toggle-row { display: flex; align-items: center; gap: 14px; padding: 14px; border: 1.5px solid #f0e6d6; border-radius: 8px; margin-bottom: 10px; cursor: pointer; transition: all 0.15s; }
  .toggle-row:hover { border-color: #d9ccb5; }
  .toggle-row input[type=checkbox] { width: 22px; height: 22px; cursor: pointer; accent-color: #F4621F; }
  .toggle-row:has(input:checked) { border-color: #F4621F; background: #FFFAF1; }
  .toggle-info { flex: 1; }
  .toggle-name { font-family: 'Barlow Condensed', sans-serif; font-weight: 800; font-size: 17px; color: #1C1410; text-transform: uppercase; }
  .toggle-sub { font-family: 'Barlow', sans-serif; font-size: 13px; color: #6b5a4a; margin-top: 2px; }
  .toggle-price { font-family: 'Barlow Condensed', sans-serif; font-weight: 800; font-size: 15px; color: #F4621F; text-transform: uppercase; letter-spacing: .08em; white-space: nowrap; }

  .step-nav { display: flex; justify-content: space-between; align-items: center; gap: 14px; flex-wrap: wrap; margin-top: 10px; padding: 16px 0 0; }
