---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Catering Request — Los Cabos Mexican Grill | Sealy, TX" description="Request catering from Los Cabos Mexican Grill in Sealy, TX. Fajita buffets, enchiladas, and more for groups of 25+.">

<div style="padding-top:114px;background:#f5f0ea;min-height:100vh;">
<div style="max-width:800px;margin:0 auto;padding:60px 40px;">

  <!-- Header -->
  <div style="text-align:center;margin-bottom:48px;">
    <img src="/images/logo.png" alt="Los Cabos Mexican Grill" style="height:72px;width:auto;margin-bottom:20px;"/>
    <div style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:13px;letter-spacing:.2em;text-transform:uppercase;color:#F4621F;margin-bottom:10px;">Events &amp; Catering</div>
    <h1 style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:clamp(40px,6vw,64px);color:#1C1410;line-height:1;text-transform:uppercase;margin-bottom:12px;">Catering Request</h1>
    <p style="font-family:'Barlow',sans-serif;font-size:16px;color:#4A3728;">Fill out the form below and we'll get back to you within 24 hours. Minimum 25 guests. Free delivery inside Sealy city limits.</p>
  </div>

  <!-- Progress Bar -->
  <div id="progress-bar" style="display:flex;align-items:center;justify-content:center;gap:0;margin-bottom:48px;">
    <div class="step-pip active" data-step="1">
      <div class="pip-circle">1</div>
      <div class="pip-label">Event Details</div>
    </div>
    <div class="pip-line"></div>
    <div class="step-pip" data-step="2">
      <div class="pip-circle">2</div>
      <div class="pip-label">Menu Selection</div>
    </div>
    <div class="pip-line"></div>
    <div class="step-pip" data-step="3">
      <div class="pip-circle">3</div>
      <div class="pip-label">Review &amp; Submit</div>
    </div>
  </div>

  <!-- FORM -->
  <form name="catering-request" method="POST" netlify netlify-honeypot="bot-field" id="catering-form">
    <input type="hidden" name="form-name" value="catering-request"/>
    <input type="hidden" name="bot-field"/>
    <input type="hidden" name="selected-package" id="hidden-package"/>
    <input type="hidden" name="selected-addons" id="hidden-addons"/>

    <!-- STEP 1: Event Details -->
    <div id="step-1" class="form-step">
      <div class="form-card">
        <h2 class="form-section-title">Tell Us About Your Event</h2>
        <div class="form-grid">
          <div class="form-group">
            <label>Your Name *</label>
            <input type="text" name="name" required placeholder="Full name"/>
          </div>
          <div class="form-group">
            <label>Phone Number *</label>
            <input type="tel" name="phone" required placeholder="(512) 000-0000"/>
          </div>
          <div class="form-group">
            <label>Email Address *</label>
            <input type="email" name="email" required placeholder="you@email.com"/>
          </div>
          <div class="form-group">
            <label>Event Date *</label>
            <input type="date" name="event-date" required/>
          </div>
          <div class="form-group">
            <label>Event Location / Address *</label>
            <input type="text" name="location" required placeholder="Address or venue name"/>
          </div>
          <div class="form-group">
            <label>Estimated Guest Count *</label>
            <input type="number" name="guests" required min="25" placeholder="Minimum 25"/>
          </div>
          <div class="form-group full-width">
            <label>Event Type</label>
            <select name="event-type">
              <option value="">Select event type</option>
              <option>Birthday Party</option>
              <option>Corporate Event</option>
              <option>Wedding Reception</option>
              <option>Family Reunion</option>
              <option>Graduation Party</option>
              <option>Company Picnic</option>
              <option>Church Event</option>
              <option>Other</option>
            </select>
          </div>
          <div class="form-group full-width">
            <label>Special Requests or Notes</label>
            <textarea name="notes" rows="3" placeholder="Dietary restrictions, setup needs, timing, etc."></textarea>
          </div>
        </div>
        <div style="text-align:right;margin-top:24px;">
          <button type="button" class="btn-next" onclick="goToStep(2)">Next: Choose Your Menu &rarr;</button>
        </div>
      </div>
    </div>

    <!-- STEP 2: Menu Selection -->
    <div id="step-2" class="form-step" style="display:none;">
      <div class="form-card">
        <h2 class="form-section-title">Choose Your Buffet Package</h2>
        <p style="font-family:'Barlow',sans-serif;font-size:14px;color:#4A3728;margin-bottom:24px;">All buffets include plates &amp; plasticware. Free delivery inside Sealy city limits.</p>

        <div class="package-grid">
          <label class="package-card">
            <input type="radio" name="package" value="Fajita Buffet - $17.95/person" required/>
            <div class="package-inner">
              <div class="package-price">$17.95<span>/person</span></div>
              <div class="package-name">Our Famous Fajita Buffet</div>
              <ul class="package-includes">
                <li>Beef &amp; Chicken Fajitas</li>
                <li>Cheese Enchiladas</li>
                <li>Rice &amp; Beans</li>
                <li>Guacamole</li>
                <li>Pico de Gallo &amp; Sour Cream</li>
                <li>Shredded Cheese</li>
                <li>Homemade Tortillas</li>
                <li>Chips &amp; Salsa</li>
              </ul>
            </div>
          </label>
          <label class="package-card">
            <input type="radio" name="package" value="Taco & Enchilada Buffet - $12.99/person"/>
            <div class="package-inner">
              <div class="package-price">$12.99<span>/person</span></div>
              <div class="package-name">Taco &amp; Enchilada Buffet</div>
              <ul class="package-includes">
                <li>Cheese Enchiladas</li>
                <li>Chicken Quesadillas</li>
                <li>Build-Your-Own Crispy Tacos</li>
                <li>Ground Beef, Lettuce, Tomatoes</li>
                <li>Shredded Cheese &amp; Sour Cream</li>
                <li>Rice &amp; Beans</li>
                <li>Chips &amp; Salsa</li>
              </ul>
            </div>
          </label>
          <label class="package-card">
            <input type="radio" name="package" value="American Country Buffet - $13.99/person"/>
            <div class="package-inner">
              <div class="package-price">$13.99<span>/person</span></div>
              <div class="package-name">American Country Buffet</div>
              <ul class="package-includes">
                <li>Choice of: Chicken Fried Steak, Chicken w/White Country Gravy, or Hamburger Steak w/Brown Gravy</li>
                <li>Plus 2 sides: Green Beans, Mashed Potatoes, Mixed Vegetables, Corn, or Fries</li>
                <li>Dinner Salad w/Ranch</li>
              </ul>
            </div>
          </label>
          <label class="package-card">
            <input type="radio" name="package" value="Chicken & Pasta Buffet - $14.99/person"/>
            <div class="package-inner">
              <div class="package-price">$14.99<span>/person</span></div>
              <div class="package-name">Chicken &amp; Pasta Buffet</div>
              <ul class="package-includes">
                <li>Grilled Chicken Breast</li>
                <li>Fettuccini Pasta w/Toasted Garlic Bread</li>
                <li>Choice of 1 side: Green Beans, Broccoli, Mixed Vegetables, or Corn</li>
                <li>Choice of 1 salad: Caesar or Dinner Salad</li>
              </ul>
            </div>
          </label>
          <label class="package-card package-card-wide">
            <input type="radio" name="package" value="Tenderloin Buffet - $23.99/person"/>
            <div class="package-inner">
              <div class="package-price">$23.99<span>/person</span></div>
              <div class="package-name">Tenderloin Buffet</div>
              <ul class="package-includes">
                <li>Tenderloin Tips w/Brown Gravy &amp; Mashed Potatoes</li>
                <li>Plus 1 side</li>
                <li>Choice of 1: Caesar Salad or Dinner Salad w/Ranch or Italian</li>
              </ul>
            </div>
          </label>
        </div>

        <h2 class="form-section-title" style="margin-top:40px;">Add-Ons &amp; &Agrave; la Carte</h2>
        <p style="font-family:'Barlow',sans-serif;font-size:14px;color:#4A3728;margin-bottom:20px;">Select any extras you'd like to add to your order.</p>
        <div class="addon-grid">
          <label class="addon-item"><input type="checkbox" name="addon" value="Iced Tea Service - $1.50/person"/> Iced Tea Service <span>$1.50/person</span></label>
          <label class="addon-item"><input type="checkbox" name="addon" value="Beef Fajitas by the Pound - $19.99"/> Beef Fajitas by the lb <span>$19.99</span></label>
          <label class="addon-item"><input type="checkbox" name="addon" value="Chicken Fajitas by the Pound - $17.99"/> Chicken Fajitas by the lb <span>$17.99</span></label>
          <label class="addon-item"><input type="checkbox" name="addon" value="Vegetable Fajitas by the Pound - $17.99"/> Veggie Fajitas by the lb <span>$17.99</span></label>
          <label class="addon-item"><input type="checkbox" name="addon" value="Tray (30) Enchiladas Ground Beef/Cheese/Chicken - $55.00"/> Tray (30) Enchiladas <span>$55.00</span></label>
          <label class="addon-item"><input type="checkbox" name="addon" value="Tray (30) Enchiladas Verdes - $60.00"/> Tray (30) Enchiladas Verdes <span>$60.00</span></label>
          <label class="addon-item"><input type="checkbox" name="addon" value="Tray (30) Enchiladas Tomatillos - $60.00"/> Tray (30) Enchiladas Tomatillos <span>$60.00</span></label>
          <label class="addon-item"><input type="checkbox" name="addon" value="Tray (30) Enchiladas al Carbon - $80.00"/> Tray (30) Enchiladas al Carbon <span>$80.00</span></label>
          <label class="addon-item"><input type="checkbox" name="addon" value="Tray (30) Cheese Quesadillas - $55.00"/> Tray (30) Cheese Quesadillas <span>$55.00</span></label>
          <label class="addon-item"><input type="checkbox" name="addon" value="Tray (30) Spinach Quesadillas - $65.00"/> Tray (30) Spinach Quesadillas <span>$65.00</span></label>
          <label class="addon-item"><input type="checkbox" name="addon" value="Tray (30) Fajita Quesadillas - $70.00"/> Tray (30) Fajita Quesadillas <span>$70.00</span></label>
          <label class="addon-item"><input type="checkbox" name="addon" value="Tray (30) Shrimp Quesadillas - $75.00"/> Tray (30) Shrimp Quesadillas <span>$75.00</span></label>
          <label class="addon-item"><input type="checkbox" name="addon" value="Tray (30) Crispy Tacos - $55.00"/> Tray (30) Crispy Tacos <span>$55.00</span></label>
          <label class="addon-item"><input type="checkbox" name="addon" value="Tray (30) Fried Burritos - $55.00"/> Tray (30) Fried Burritos <span>$55.00</span></label>
          <label class="addon-item"><input type="checkbox" name="addon" value="Rice & Beans (30 people) - $80.00"/> Rice &amp; Beans (30 people) <span>$80.00</span></label>
          <label class="addon-item"><input type="checkbox" name="addon" value="Rice Only (30 people) - $45.00"/> Rice Only (30 people) <span>$45.00</span></label>
          <label class="addon-item"><input type="checkbox" name="addon" value="Beans Only (30 people) - $45.00"/> Beans Only (30 people) <span>$45.00</span></label>
          <label class="addon-item"><input type="checkbox" name="addon" value="Tray (30) Sopapillas - $49.00"/> Tray (30) Sopapillas <span>$49.00</span></label>
          <label class="addon-item"><input type="checkbox" name="addon" value="Tray Flan - $49.00"/> Tray Flan <span>$49.00</span></label>
          <label class="addon-item"><input type="checkbox" name="addon" value="Dozen Tortillas Flour or Corn - $9.95"/> Dozen Tortillas <span>$9.95</span></label>
          <label class="addon-item"><input type="checkbox" name="addon" value="Dozen Tamales - $10.99"/> Dozen Tamales <span>$10.99</span></label>
          <label class="addon-item"><input type="checkbox" name="addon" value="Gallon Pico de Gallo - $35.00"/> Gallon Pico de Gallo <span>$35.00</span></label>
          <label class="addon-item"><input type="checkbox" name="addon" value="Gallon Guacamole - $70.00"/> Gallon Guacamole <span>$70.00</span></label>
          <label class="addon-item"><input type="checkbox" name="addon" value="Gallon Guacamole Mexicano - $85.00"/> Gallon Guacamole Mexicano <span>$85.00</span></label>
          <label class="addon-item"><input type="checkbox" name="addon" value="Gallon Red Salsa - $35.00"/> Gallon Red Salsa <span>$35.00</span></label>
          <label class="addon-item"><input type="checkbox" name="addon" value="Gallon Green Salsa - $40.00"/> Gallon Green Salsa <span>$40.00</span></label>
          <label class="addon-item"><input type="checkbox" name="addon" value="Gallon Chili con Queso - $70.00"/> Gallon Chili con Queso <span>$70.00</span></label>
          <label class="addon-item addon-item-full"><input type="checkbox" name="addon" value="Margarita Machine Rental - Call for pricing"/> Margarita Machine Rental <span>Call for pricing</span></label>
        </div>

        <div style="display:flex;justify-content:space-between;margin-top:32px;">
          <button type="button" class="btn-back" onclick="goToStep(1)">&larr; Back</button>
          <button type="button" class="btn-next" onclick="goToStep(3)">Review My Request &rarr;</button>
        </div>
      </div>
    </div>

    <!-- STEP 3: Review & Submit -->
    <div id="step-3" class="form-step" style="display:none;">
      <div class="form-card">
        <h2 class="form-section-title">Review Your Request</h2>
        <div id="review-content" style="font-family:'Barlow',sans-serif;font-size:15px;color:#1C1410;line-height:1.8;"></div>
        <div style="background:#fff3ed;border-left:4px solid #F4621F;padding:16px 20px;margin:24px 0;border-radius:0 8px 8px 0;">
          <p style="font-family:'Barlow',sans-serif;font-size:14px;color:#4A3728;margin:0;">Prices are per person and subject to change. We'll confirm availability and final pricing when we call you back within 24 hours.</p>
        </div>
        <div style="display:flex;justify-content:space-between;margin-top:24px;gap:12px;flex-wrap:wrap;">
          <button type="button" class="btn-back" onclick="goToStep(2)">&larr; Edit Menu</button>
          <button type="submit" class="btn-submit">Send Catering Request &#10003;</button>
        </div>
      </div>
    </div>

  </form>

  <!-- Success message -->
  <div id="success-msg" style="display:none;text-align:center;padding:60px 40px;">
    <div style="font-size:48px;margin-bottom:16px;">&#10003;</div>
    <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:36px;color:#1C1410;text-transform:uppercase;margin-bottom:12px;">Request Received!</h2>
    <p style="font-family:'Barlow',sans-serif;font-size:16px;color:#4A3728;margin-bottom:24px;">We'll call you back within 24 hours to confirm your event details and finalize pricing.</p>
    <p style="font-family:'Barlow',sans-serif;font-size:15px;color:#4A3728;">Questions? Call us at <a href="tel:+15126076232" style="color:#F4621F;font-weight:700;">(512) 607-6232</a></p>
  </div>

</div>
</div>

<style>
.form-step{}
.form-card{background:white;border-radius:16px;padding:40px;box-shadow:0 4px 24px rgba(0,0,0,.06);}
.form-section-title{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:24px;text-transform:uppercase;letter-spacing:.04em;color:#1C1410;margin-bottom:20px;}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.form-group{display:flex;flex-direction:column;gap:6px;}
.form-group.full-width{grid-column:1/-1;}
.form-group label{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:13px;text-transform:uppercase;letter-spacing:.08em;color:#1C1410;}
.form-group input,.form-group select,.form-group textarea{font-family:'Barlow',sans-serif;font-size:15px;color:#1C1410;padding:10px 14px;border:1.5px solid #ddd;border-radius:8px;background:white;outline:none;transition:border .2s;}
.form-group input:focus,.form-group select:focus,.form-group textarea:focus{border-color:#F4621F;}
.package-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.package-card{cursor:pointer;border:2px solid #e0dbd5;border-radius:12px;overflow:hidden;transition:border-color .2s;}
.package-card:has(input:checked){border-color:#F4621F;}
.package-card-wide{grid-column:1/-1;}
.package-card input{display:none;}
.package-inner{padding:20px;}
.package-price{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:32px;color:#F4621F;line-height:1;}
.package-price span{font-size:15px;font-weight:700;}
.package-name{font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:17px;text-transform:uppercase;color:#1C1410;margin:6px 0 10px;}
.package-includes{list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:4px;}
.package-includes li{font-family:'Barlow',sans-serif;font-size:13px;color:#4A3728;padding-left:14px;position:relative;}
.package-includes li::before{content:"•";position:absolute;left:0;color:#F4621F;}
.addon-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
.addon-item{display:flex;align-items:center;justify-content:space-between;gap:8px;padding:10px 14px;border:1.5px solid #e0dbd5;border-radius:8px;cursor:pointer;font-family:'Barlow',sans-serif;font-size:14px;color:#1C1410;transition:border-color .2s;}
.addon-item:has(input:checked){border-color:#F4621F;background:#fff8f5;}
.addon-item input{width:16px;height:16px;accent-color:#F4621F;flex-shrink:0;}
.addon-item span{font-weight:700;color:#F4621F;white-space:nowrap;margin-left:auto;padding-left:8px;}
.addon-item-full{grid-column:1/-1;}
.btn-next{background:#F4621F;color:white;font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:15px;letter-spacing:.1em;text-transform:uppercase;padding:14px 32px;border:none;border-radius:6px;cursor:pointer;}
.btn-next:hover{background:#D94E0E;}
.btn-back{background:transparent;color:#4A3728;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:14px;letter-spacing:.08em;text-transform:uppercase;padding:14px 24px;border:1.5px solid #ccc;border-radius:6px;cursor:pointer;}
.btn-submit{background:#1A1410;color:white;font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:15px;letter-spacing:.1em;text-transform:uppercase;padding:14px 40px;border:none;border-radius:6px;cursor:pointer;}
.btn-submit:hover{background:#F4621F;}
.step-pip{display:flex;flex-direction:column;align-items:center;gap:6px;}
.pip-circle{width:36px;height:36px;border-radius:50%;background:#ddd;color:#888;font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:16px;display:flex;align-items:center;justify-content:center;transition:all .3s;}
.step-pip.active .pip-circle{background:#F4621F;color:white;}
.step-pip.done .pip-circle{background:#1A1410;color:white;}
.pip-label{font-family:'Barlow',sans-serif;font-size:12px;color:#888;white-space:nowrap;}
.step-pip.active .pip-label{color:#F4621F;font-weight:700;}
.pip-line{flex:1;height:2px;background:#ddd;min-width:60px;margin-bottom:18px;}
@media(max-width:600px){
  .form-grid,.package-grid,.addon-grid{grid-template-columns:1fr;}
  .package-card-wide{grid-column:1;}
  .form-card{padding:24px 20px;}
}
</style>

<script>
function goToStep(n) {
  if(n === 2) {
    const name = document.querySelector('[name="name"]').value;
    const phone = document.querySelector('[name="phone"]').value;
    const email = document.querySelector('[name="email"]').value;
    const date = document.querySelector('[name="event-date"]').value;
    const loc = document.querySelector('[name="location"]').value;
    const guests = document.querySelector('[name="guests"]').value;
    if(!name||!phone||!email||!date||!loc||!guests){alert('Please fill in all required fields.');return;}
    if(parseInt(guests)<25){alert('Minimum guest count is 25.');return;}
  }
  if(n === 3) {
    const pkg = document.querySelector('[name="package"]:checked');
    if(!pkg){alert('Please select a buffet package.');return;}
    const addons = [...document.querySelectorAll('[name="addon"]:checked')].map(c=>c.value);
    document.getElementById('hidden-package').value = pkg.value;
    document.getElementById('hidden-addons').value = addons.join(' | ') || 'None';
    const name = document.querySelector('[name="name"]').value;
    const phone = document.querySelector('[name="phone"]').value;
    const email = document.querySelector('[name="email"]').value;
    const date = document.querySelector('[name="event-date"]').value;
    const loc = document.querySelector('[name="location"]').value;
    const guests = document.querySelector('[name="guests"]').value;
    const evtype = document.querySelector('[name="event-type"]').value;
    const notes = document.querySelector('[name="notes"]').value;
    document.getElementById('review-content').innerHTML =
      '<div style="display:grid;grid-template-columns:1fr 1fr;gap:8px 24px;margin-bottom:20px;">' +
      '<div><strong>Name:</strong> '+name+'</div>' +
      '<div><strong>Phone:</strong> '+phone+'</div>' +
      '<div><strong>Email:</strong> '+email+'</div>' +
      '<div><strong>Date:</strong> '+date+'</div>' +
      '<div><strong>Location:</strong> '+loc+'</div>' +
      '<div><strong>Guests:</strong> '+guests+'</div>' +
      (evtype?'<div><strong>Event Type:</strong> '+evtype+'</div>':'') +
      '</div>' +
      '<div style="border-top:1px solid #eee;padding-top:16px;margin-bottom:12px;"><strong>Package:</strong> '+pkg.value+'</div>' +
      (addons.length?'<div><strong>Add-ons:</strong><ul style='margin:8px 0 0 20px;'><li>'+addons.join('</li><li>')+'</li></ul></div>':'') +
      (notes?'<div style="margin-top:12px;"><strong>Notes:</strong> '+notes+'</div>':'');
  }
  document.querySelectorAll('.form-step').forEach(s=>s.style.display='none');
  document.getElementById('step-'+n).style.display='block';
  document.querySelectorAll('.step-pip').forEach((p,i)=>{
    p.classList.remove('active','done');
    if(i+1===n) p.classList.add('active');
    if(i+1<n) p.classList.add('done');
  });
  window.scrollTo({top:0,behavior:'smooth'});
}

document.getElementById('catering-form').addEventListener('submit', async function(e){
  e.preventDefault();
  const data = new FormData(this);
  try {
    await fetch('/', {method:'POST', headers:{'Content-Type':'application/x-www-form-urlencoded'}, body: new URLSearchParams(data).toString()});
    document.getElementById('catering-form').style.display='none';
    document.getElementById('progress-bar').style.display='none';
    document.getElementById('success-msg').style.display='block';
  } catch(err) {
    alert('Something went wrong. Please call us at (512) 607-6232.');
  }
});
</script>

</Layout>
