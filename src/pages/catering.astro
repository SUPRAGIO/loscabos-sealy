---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Catering in Sealy, TX — Los Cabos Mexican Grill & Steak House" description="Tex-Mex catering for any event in Sealy and surrounding areas — fajitas, enchiladas, tacos and more. 500+ events catered. Free delivery inside Sealy city limits. Book online or call (512) 607-6232.">

<div class="cat-sales">

  <!-- ===== HERO ===== -->
  <section class="sales-hero">
    <div class="sales-hero-overlay"></div>
    <img src="/images/cabosvan2.jpeg" alt="Los Cabos catering van at an event" class="sales-hero-bg" />
    <div class="sales-hero-inner">
      <div class="sales-hero-eyebrow">Catering · Sealy &amp; Surrounding Areas</div>
      <h1 class="sales-hero-h1">
        <span class="sh-line">WE CATER</span>
        <span class="sh-line">THE WHOLE</span>
        <span class="sh-line sh-accent">FIESTA</span>
      </h1>
      <p class="sales-hero-sub">Sizzling fajitas, stacked enchiladas, fresh pico &mdash; delivered hot, set up clean, gone in minutes. Weddings, offices, Quinceañeras, tailgates and family reunions from 25 to 500+ guests.</p>
      <div class="sales-hero-ctas">
        <a href="/catering/order" class="btn-primary sales-cta-main">Build Your Order &rarr;</a>
        <a href="tel:+15126076232" class="btn-outline sales-cta-alt">Call (512) 607-6232</a>
        <a href="/catering-menu.pdf" class="btn-ghost sales-cta-alt" download="Los-Cabos-Catering-Menu.pdf">&darr; Catering Menu (PDF)</a>
      </div>
      <div class="sales-hero-meta">
        <span>✓ 500+ events catered</span>
        <span>✓ 30-mile serving radius</span>
        <span>✓ Min. 25 guests</span>
        <span>✓ Free delivery inside Sealy</span>
      </div>
    </div>
  </section>

  <!-- ===== WHY LOS CABOS ===== -->
  <section class="sales-why">
    <div class="sales-container">
      <div class="sales-eyebrow">WHY TEXANS CHOOSE LOS CABOS</div>
      <h2 class="sales-h2">Catering that tastes like home &mdash; at scale</h2>
      <p class="sales-lede">We've been feeding Sealy, Katy, Brookshire, Bellville, Columbus, Houston and all of Austin County for years. Scratch kitchen. Honest prices. Real people answering the phone.</p>
      <div class="why-grid">
        <div class="why-card">
          <div class="why-icon">🔥</div>
          <h3>Fresh off the grill</h3>
          <p>Fajitas marinated in-house and seared on open flame. Enchiladas rolled to order. Guacamole mashed the morning of.</p>
        </div>
        <div class="why-card">
          <div class="why-icon">🚚</div>
          <h3>Delivery, setup, cleanup</h3>
          <p>We deliver, set up on chafers with sternos, and break it all down when you're done. You enjoy the party &mdash; that's the deal.</p>
        </div>
        <div class="why-card">
          <div class="why-icon">💬</div>
          <h3>Actual humans</h3>
          <p>Call (512) 607-6232 and you'll get someone who's been at this a while. Changes 48 hours out? No problem. We're flexible.</p>
        </div>
        <div class="why-card">
          <div class="why-icon">📋</div>
          <h3>Plates &amp; plasticware included</h3>
          <p>Every buffet package comes with plates, utensils and napkins. No trip to the dollar store. No awkward pile of fajitas with nothing to eat them on.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PACKAGES ===== -->
  <section class="sales-packages" id="packages">
    <div class="sales-container">
      <div class="sales-eyebrow">BUFFET PACKAGES</div>
      <h2 class="sales-h2">Pick a package. We handle the rest.</h2>
      <p class="sales-lede">Every package is per person and includes plates, plasticware, and free delivery inside Sealy city limits.</p>
      <div class="pkg-card-grid">
        <a href="/catering/order" class="pkg-card pkg-popular">
          <div class="pkg-ribbon">Most Popular</div>
          <div class="pkg-price">$17.95<span>/person</span></div>
          <div class="pkg-name">Our Famous Fajita Buffet</div>
          <ul class="pkg-includes">
            <li>Beef &amp; Chicken Fajitas</li>
            <li>Cheese Enchiladas</li>
            <li>Rice &amp; Beans</li>
            <li>Guacamole, Pico &amp; Sour Cream</li>
            <li>Homemade Tortillas</li>
            <li>Chips &amp; Salsa</li>
          </ul>
          <div class="pkg-cta">Build with this package &rarr;</div>
        </a>
        <a href="/catering/order" class="pkg-card">
          <div class="pkg-price">$12.99<span>/person</span></div>
          <div class="pkg-name">Taco &amp; Enchilada Buffet</div>
          <ul class="pkg-includes">
            <li>Cheese Enchiladas</li>
            <li>Chicken Quesadillas</li>
            <li>Build-Your-Own Crispy Tacos</li>
            <li>Rice &amp; Beans</li>
            <li>Chips &amp; Salsa</li>
          </ul>
          <div class="pkg-cta">Build with this package &rarr;</div>
        </a>
        <a href="/catering/order" class="pkg-card">
          <div class="pkg-price">$13.99<span>/person</span></div>
          <div class="pkg-name">American Country Buffet</div>
          <ul class="pkg-includes">
            <li>Choice of Chicken Fried Steak, Chicken w/ Country Gravy, or Hamburger Steak</li>
            <li>Plus 2 Sides (incl. Dinner Salad)</li>
          </ul>
          <div class="pkg-cta">Build with this package &rarr;</div>
        </a>
        <a href="/catering/order" class="pkg-card">
          <div class="pkg-price">$14.99<span>/person</span></div>
          <div class="pkg-name">Chicken &amp; Pasta Buffet</div>
          <ul class="pkg-includes">
            <li>Grilled Chicken Breast</li>
            <li>Fettuccini Pasta w/ Toasted Garlic Bread</li>
            <li>Choice of Side &amp; Salad</li>
          </ul>
          <div class="pkg-cta">Build with this package &rarr;</div>
        </a>
        <a href="/catering/order" class="pkg-card pkg-premium">
          <div class="pkg-ribbon pkg-ribbon-premium">Premium</div>
          <div class="pkg-price">$23.99<span>/person</span></div>
          <div class="pkg-name">Tenderloin Buffet</div>
          <ul class="pkg-includes">
            <li>Tenderloin Tips w/ Brown Gravy &amp; Mashed Potatoes</li>
            <li>Plus 1 Side of Your Choice</li>
            <li>Caesar or Dinner Salad</li>
          </ul>
          <div class="pkg-cta">Build with this package &rarr;</div>
        </a>
        <a href="/catering/order" class="pkg-card pkg-custom">
          <div class="pkg-price">Custom</div>
          <div class="pkg-name">A La Carte Only</div>
          <ul class="pkg-includes">
            <li>Skip the buffet and just order trays, gallons, and extras</li>
            <li>Fajitas by the pound, enchilada trays, quesadillas, desserts</li>
            <li>Pick what you want &mdash; we'll dial in the quantities</li>
          </ul>
          <div class="pkg-cta">Start a custom order &rarr;</div>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== À LA CARTE TEASER ===== -->
  <section class="sales-alc">
    <div class="sales-container">
      <div class="sales-eyebrow">À LA CARTE &amp; ADD-ONS</div>
      <h2 class="sales-h2">Load up on trays, gallons &amp; the good stuff</h2>
      <p class="sales-lede">Trays feed about 30 people. Gallons go a long way. Add-ons stretch your spread without stretching the budget.</p>
      <div class="alc-grid">
        <div class="alc-col">
          <h3>By the Pound</h3>
          <ul>
            <li>Beef Fajitas <span>$19.99/lb</span></li>
            <li>Chicken Fajitas <span>$17.99/lb</span></li>
            <li>Vegetable Fajitas <span>$17.99/lb</span></li>
          </ul>
        </div>
        <div class="alc-col">
          <h3>Enchilada Trays (30)</h3>
          <ul>
            <li>Classic (beef/cheese/chicken) <span>$55</span></li>
            <li>Verdes (green chicken) <span>$60</span></li>
            <li>Tomatillos (green cheese) <span>$60</span></li>
            <li>Al Carbon <span>$80</span></li>
          </ul>
        </div>
        <div class="alc-col">
          <h3>Quesadilla Trays (30)</h3>
          <ul>
            <li>Cheese <span>$55</span></li>
            <li>Spinach <span>$65</span></li>
            <li>Fajita (beef/chicken) <span>$70</span></li>
            <li>Shrimp <span>$75</span></li>
          </ul>
        </div>
        <div class="alc-col">
          <h3>Sides &amp; Desserts</h3>
          <ul>
            <li>Rice &amp; Beans (30) <span>$80</span></li>
            <li>Sopapillas / Flan tray <span>$49</span></li>
            <li>Tortillas (dozen) <span>$9.95</span></li>
            <li>Tamales (dozen) <span>$10.99</span></li>
          </ul>
        </div>
        <div class="alc-col">
          <h3>Gallons</h3>
          <ul>
            <li>Pico de Gallo <span>$35</span></li>
            <li>Red / Green Salsa <span>$35/$40</span></li>
            <li>Guacamole / Mexicano <span>$70/$85</span></li>
            <li>Chili con Queso <span>$70</span></li>
          </ul>
        </div>
        <div class="alc-col">
          <h3>Service Add-Ons</h3>
          <ul>
            <li>Iced Tea Service <span>$1.50/person</span></li>
            <li>Margarita Machine Rental <span>ask us</span></li>
            <li>Sternos &amp; Chafers <span>included</span></li>
          </ul>
        </div>
      </div>
      <div class="alc-cta-row">
        <a href="/catering-menu.pdf" class="btn-outline-dark" download="Los-Cabos-Catering-Menu.pdf">&darr; Download full menu (PDF)</a>
        <a href="/catering/order" class="btn-primary">Build your order &rarr;</a>
      </div>
    </div>
  </section>

  <!-- ===== EVENT TYPES ===== -->
  <section class="sales-events">
    <div class="sales-container">
      <div class="sales-eyebrow">WHAT WE CATER</div>
      <h2 class="sales-h2">If there's a reason to gather, we've fed it</h2>
      <div class="evt-grid">
        <div class="evt-tile">Weddings &amp; Rehearsal Dinners</div>
        <div class="evt-tile">Quinceañeras</div>
        <div class="evt-tile">Corporate Lunches</div>
        <div class="evt-tile">Birthday Parties</div>
        <div class="evt-tile">Graduations</div>
        <div class="evt-tile">Family Reunions</div>
        <div class="evt-tile">Church Events</div>
        <div class="evt-tile">Tailgates</div>
        <div class="evt-tile">Open Houses</div>
        <div class="evt-tile">Office Holiday Parties</div>
        <div class="evt-tile">Funerals &amp; Memorials</div>
        <div class="evt-tile">Just a Big Tuesday</div>
      </div>
    </div>
  </section>

  <!-- ===== TESTIMONIALS ===== -->
  <section class="sales-tst">
    <div class="sales-container">
      <div class="sales-eyebrow">WHAT OUR NEIGHBORS SAY</div>
      <h2 class="sales-h2">Real reviews. Real fiestas.</h2>
      <div class="tst-grid">
        <div class="tst-card">
          <div class="tst-stars">★★★★★</div>
          <p>"Catered our daughter's Quinceañera for 180 guests and everything showed up hot, on time, and beautiful. The fajitas disappeared in twenty minutes."</p>
          <div class="tst-who">&mdash; Maria G., Sealy</div>
        </div>
        <div class="tst-card">
          <div class="tst-stars">★★★★★</div>
          <p>"We use Los Cabos for our quarterly office lunches. It's stupid-easy to order, they set up, they clean up, and nobody in the office complains &mdash; which is a miracle."</p>
          <div class="tst-who">&mdash; Office Manager, Katy</div>
        </div>
        <div class="tst-card">
          <div class="tst-stars">★★★★★</div>
          <p>"Called two days before a memorial for 75 people. They made it work. Tenderloin buffet was honestly the best comfort we could've given our family that week."</p>
          <div class="tst-who">&mdash; Robert H., Bellville</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== HOW IT WORKS ===== -->
  <section class="sales-how">
    <div class="sales-container">
      <div class="sales-eyebrow">HOW IT WORKS</div>
      <h2 class="sales-h2">Three steps from hungry to fed</h2>
      <div class="how-steps">
        <div class="how-step">
          <div class="how-num">1</div>
          <h3>Tell us about your event</h3>
          <p>Date, head count, location, style. Takes two minutes online or one phone call.</p>
        </div>
        <div class="how-step">
          <div class="how-num">2</div>
          <h3>We quote &amp; confirm</h3>
          <p>Within 24 hours we'll call to walk through the menu, confirm pricing, and lock it in.</p>
        </div>
        <div class="how-step">
          <div class="how-num">3</div>
          <h3>Event day, we show up</h3>
          <p>Hot food, chafers on, plates stacked, guacamole fresh. You host. We handle the rest.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section class="sales-faq">
    <div class="sales-container">
      <div class="sales-eyebrow">QUESTIONS WE GET</div>
      <h2 class="sales-h2">Straight answers</h2>
      <div class="faq-list">
        <details class="faq-item">
          <summary>How far in advance do I need to book?</summary>
          <p>72 hours is the sweet spot. We'll try to make shorter notice work if we can &mdash; call (512) 607-6232 and we'll tell you straight.</p>
        </details>
        <details class="faq-item">
          <summary>What's the minimum head count?</summary>
          <p>25 guests for buffet packages. À la carte trays have no minimum.</p>
        </details>
        <details class="faq-item">
          <summary>Do you deliver outside Sealy?</summary>
          <p>Yes &mdash; up to 30 miles from Sealy. Free delivery inside Sealy city limits; modest delivery fee applies beyond that. Call us for a quote.</p>
        </details>
        <details class="faq-item">
          <summary>Is there a service fee or gratuity?</summary>
          <p>Posted prices are what you pay per person for the food. Full-service on-site staffing is available for an added fee &mdash; ask when we quote you.</p>
        </details>
        <details class="faq-item">
          <summary>Can I mix-and-match packages and à la carte?</summary>
          <p>Absolutely. The order builder lets you pick a buffet package and add trays, gallons, and extras on top. Or skip the buffet entirely and just order what you want.</p>
        </details>
        <details class="faq-item">
          <summary>Do you handle dietary restrictions?</summary>
          <p>Vegetable fajitas, cheese enchiladas, and sides-only options cover most. Tell us about serious allergies in the notes section and we'll call to confirm.</p>
        </details>
        <details class="faq-item">
          <summary>How do I pay?</summary>
          <p>We confirm payment when we confirm your order &mdash; card, check, or invoice for repeat corporate clients. Nothing's charged before you say yes.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- ===== FINAL CTA ===== -->
  <section class="sales-final">
    <div class="sales-final-inner">
      <h2 class="sales-final-h2">Let's feed your people.</h2>
      <p class="sales-final-sub">Start with our 2-minute order builder, or call us directly &mdash; whichever works.</p>
      <div class="sales-final-ctas">
        <a href="/catering/order" class="btn-primary sales-cta-xl">Build Your Order &rarr;</a>
        <a href="tel:+15126076232" class="btn-outline sales-cta-xl">Call (512) 607-6232</a>
      </div>
      <div class="sales-final-meta">
        <span>Serving Sealy &amp; a 30-mile radius · Free delivery inside Sealy city limits · 25 guest minimum · 500+ events catered</span>
      </div>
      <a href="/catering-menu.pdf" class="sales-final-dl" download="Los-Cabos-Catering-Menu.pdf">&darr; Or download the full menu PDF</a>
    </div>
  </section>

</div>


<style>
  :root { --orange: #E2721F; --orange-deep: #C25610; --orange-light: #F4621F; --bg-cream: #FBF5E9; --ink: #1A1410; }
  .cat-sales { background: var(--bg-cream); color: var(--ink); font-family: 'Inter', system-ui, sans-serif; }
  .sales-container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  .sales-eyebrow { font-family: 'Barlow Condensed', sans-serif; font-weight: 800; font-size: 13px; letter-spacing: 0.2em; color: var(--orange); text-transform: uppercase; margin-bottom: 12px; }
  .sales-h2 { font-family: 'Barlow Condensed', sans-serif; font-weight: 900; font-size: clamp(34px, 5vw, 56px); line-height: 1; letter-spacing: -0.01em; text-transform: uppercase; margin: 0 0 16px; color: var(--ink); }
  .sales-lede { font-size: 17px; line-height: 1.55; color: #4a3f34; max-width: 720px; margin: 0 0 40px; }

  /* ===== HERO ===== */
  .sales-hero { position: relative; min-height: 78vh; display: flex; align-items: center; overflow: hidden; padding: 140px 0 80px; color: #fff; }
  .sales-hero-bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0; }
  .sales-hero-overlay { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.75) 100%); z-index: 1; }
  .sales-hero-inner { position: relative; z-index: 2; max-width: 1000px; margin: 0 auto; padding: 0 24px; text-align: center; }
  .sales-hero-eyebrow { font-family: 'Barlow Condensed', sans-serif; font-weight: 800; letter-spacing: 0.2em; font-size: 13px; color: #ffd8b5; text-transform: uppercase; margin-bottom: 20px; }
  .sales-hero-h1 { font-family: 'Barlow Condensed', sans-serif; font-weight: 900; font-size: clamp(56px, 11vw, 130px); line-height: 0.92; letter-spacing: -0.02em; margin: 0 0 24px; text-transform: uppercase; text-shadow: 0 4px 24px rgba(0,0,0,0.5); }
  .sh-line { display: block; }
  .sh-accent { color: var(--orange-light); font-style: italic; }
  .sales-hero-sub { font-size: 18px; line-height: 1.5; max-width: 680px; margin: 0 auto 36px; color: rgba(255,255,255,0.9); text-shadow: 0 2px 8px rgba(0,0,0,0.5); }
  .sales-hero-ctas { display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; margin-bottom: 32px; }
  .sales-hero-meta { display: flex; flex-wrap: wrap; gap: 24px 28px; justify-content: center; font-size: 13px; color: rgba(255,255,255,0.85); letter-spacing: 0.02em; }


  /* ===== WHY ===== */
  .sales-why { padding: 80px 0; background: var(--bg-cream); }
  .why-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 24px; margin-top: 40px; }
  .why-card { background: #fff; border: 1px solid rgba(226,114,31,0.18); border-radius: 12px; padding: 28px 24px; box-shadow: 0 2px 12px rgba(0,0,0,0.04); transition: transform 0.2s, box-shadow 0.2s; }
  .why-card:hover { transform: translateY(-4px); box-shadow: 0 10px 28px rgba(0,0,0,0.08); }
  .why-icon { font-size: 32px; margin-bottom: 12px; }
  .why-card h3 { font-family: 'Barlow Condensed', sans-serif; font-weight: 800; font-size: 22px; text-transform: uppercase; letter-spacing: 0.02em; margin: 0 0 8px; color: var(--ink); }
  .why-card p { font-size: 15px; line-height: 1.55; color: #4a3f34; margin: 0; }

  /* ===== PACKAGES ===== */
  .sales-packages { padding: 80px 0; background: #fff; }
  .pkg-card-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; margin-top: 40px; }
  .pkg-card { position: relative; display: block; background: #fff; border: 2px solid rgba(226,114,31,0.25); border-radius: 14px; padding: 28px 24px 24px; text-decoration: none; color: var(--ink); transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s; overflow: hidden; }
  .pkg-card:hover { transform: translateY(-4px); border-color: var(--orange); box-shadow: 0 14px 32px rgba(0,0,0,0.1); }
  .pkg-popular { border-color: var(--orange); box-shadow: 0 6px 20px rgba(226,114,31,0.15); }
  .pkg-premium { background: linear-gradient(180deg, #fff 0%, #fef5e8 100%); border-color: #c08c30; }
  .pkg-custom { border-style: dashed; background: rgba(226,114,31,0.04); }
  .pkg-ribbon { position: absolute; top: 16px; right: -32px; transform: rotate(35deg); background: var(--orange); color: #fff; font-family: 'Barlow Condensed', sans-serif; font-weight: 800; letter-spacing: 0.14em; font-size: 12px; padding: 4px 40px; text-transform: uppercase; box-shadow: 0 3px 10px rgba(0,0,0,0.2); }
  .pkg-ribbon-premium { background: linear-gradient(135deg, #c08c30, #8a6420); }
  .pkg-price { font-family: 'Barlow Condensed', sans-serif; font-weight: 900; font-size: 40px; color: var(--orange); line-height: 1; margin-bottom: 6px; }
  .pkg-price span { font-size: 15px; color: #7a6d5f; font-weight: 600; }
  .pkg-name { font-family: 'Barlow Condensed', sans-serif; font-weight: 800; font-size: 22px; text-transform: uppercase; letter-spacing: 0.02em; margin-bottom: 14px; }
  .pkg-includes { list-style: none; padding: 0; margin: 0 0 18px; font-size: 14.5px; color: #4a3f34; }
  .pkg-includes li { padding: 5px 0 5px 20px; position: relative; line-height: 1.4; }
  .pkg-includes li::before { content: "✓"; color: var(--orange); font-weight: 800; position: absolute; left: 0; top: 5px; }
  .pkg-cta { font-family: 'Barlow Condensed', sans-serif; font-weight: 800; font-size: 14px; color: var(--orange-deep); letter-spacing: 0.14em; text-transform: uppercase; border-top: 1px solid rgba(226,114,31,0.18); padding-top: 14px; }


  /* ===== À LA CARTE ===== */
  .sales-alc { padding: 80px 0; background: var(--bg-cream); }
  .alc-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 20px; margin: 40px 0 32px; }
  .alc-col { background: #fff; border-radius: 12px; padding: 22px 22px 20px; border-left: 4px solid var(--orange); box-shadow: 0 2px 12px rgba(0,0,0,0.04); }
  .alc-col h3 { font-family: 'Barlow Condensed', sans-serif; font-weight: 800; font-size: 18px; text-transform: uppercase; letter-spacing: 0.08em; margin: 0 0 12px; color: var(--orange-deep); }
  .alc-col ul { list-style: none; padding: 0; margin: 0; }
  .alc-col li { display: flex; justify-content: space-between; align-items: baseline; padding: 7px 0; border-bottom: 1px dashed rgba(0,0,0,0.08); font-size: 14.5px; color: #4a3f34; gap: 12px; }
  .alc-col li:last-child { border-bottom: none; }
  .alc-col li span { font-weight: 700; color: var(--orange); white-space: nowrap; }
  .alc-cta-row { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; margin-top: 16px; }

  /* ===== EVENTS ===== */
  .sales-events { padding: 80px 0; background: #fff; }
  .evt-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 10px; margin-top: 32px; }
