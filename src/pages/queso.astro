---
import Base from "@/layouts/Base.astro";
import SectionTitle from "@/components/SectionTitle.astro";

const quesoTiers = [
  {
    name: "Chile con Queso",
    tagline: "The classic",
    sells:
      "Melty Monterey Jack and the smoke of fresh chile. Made to order, scoop after scoop. The dip every table starts with for a reason.",
    sizes: [
      { label: "Small (8 oz)", price: "$7.85" },
      { label: "Large (12 oz)", price: "$9.25" },
      { label: "Family (32 oz)", price: "$19.95" },
    ],
    pop: false,
  },
  {
    name: "Tex Mex Chile con Queso",
    tagline: "Loaded the Texas way",
    sells:
      "Same queso, plus seasoned ground beef stirred right in. Topped with fresh pico de gallo and guacamole. A dip that eats like a meal.",
    sizes: [
      { label: "Small", price: "$8.35" },
      { label: "Large", price: "$10.75" },
      { label: "Family (32 oz)", price: "$19.95" },
    ],
    pop: true,
  },
  {
    name: "Green or Red Salsa",
    tagline: "Pressed fresh every morning",
    sells:
      "Take a jar home. Tomatillo green or fire roasted red, made daily, no shortcuts. Goes on everything you put it on.",
    sizes: [
      { label: "Small (8 oz)", price: "$3.99" },
      { label: "Large (12 oz)", price: "$5.50" },
      { label: "Family (32 oz)", price: "$14.25" },
    ],
    pop: false,
  },
];

const breakdown = [
  {
    title: "Queso made to order",
    body: "Every order comes off the line hot, the way queso is supposed to. Stretchy, glossy, scoopable. Nothing sitting in a warmer waiting for you.",
  },
  {
    title: "Salsa pressed at sunrise",
    body: "Tomatoes, onions, lime, cilantro, peppers, salt. Pressed and seasoned every single morning. If it isn't made today, it doesn't make it to your table.",
  },
  {
    title: "Chips made in house",
    body: "Cut, cooked, and salted the right way every shift. Crisp, light, ready to do their job. The chips matter as much as the dip.",
  },
];
---

<Base
  title="Chips & Queso | Los Cabos Mexican Grill in Sealy, TX"
  description="Chile con queso and Tex Mex chile con queso made fresh at Los Cabos Sealy. Monterey Jack, fresh salsa, house chips. Small, large, family sizes."
>
  <!-- ===== Hero ===== -->
  <section class="queso-hero">
    <div class="queso-hero-content">
      <span class="eyebrow-script">The basics, done right</span>
      <h1>Chips & Queso</h1>
      <p class="hero-sub">
        <span>Real cheese. Fresh salsa.</span>
        <span>The dip that runs the table.</span>
      </p>
      <div class="hero-ctas">
        <a
          class="btn btn-primary"
          href="https://online.skytab.com/75fd37a0da5766d1bf27a245fba50884/order-settings"
          target="_blank"
          rel="noopener"
        >Order Online</a>
        <a class="btn btn-ghost hero-ghost" href="tel:+15126076232">Call to Order</a>
      </div>
    </div>
  </section>

  <!-- ===== Intro ===== -->
  <section class="section intro-section">
    <div class="container intro-inner">
      <SectionTitle
        eyebrow="Made to order"
        title="The dip that runs the table."
        sub="Every visit starts the same way. Chips down, queso poured, salsa pushed to the middle. Order one, share one, take some home."
        stackSub
      />
    </div>
  </section>

  <!-- ===== Queso + Salsa cards ===== -->
  <section class="section queso-cards-section">
    <div class="container">
      <div class="queso-grid">
        {
          quesoTiers.map((q) => (
            <article class:list={["queso-card", { pop: q.pop }]}>
              {q.pop && <span class="pop-badge">Most ordered</span>}
              <span class="queso-tag">{q.tagline}</span>
              <h3>{q.name}</h3>
              <p class="queso-pitch">{q.sells}</p>

              <ul class="size-list">
                {q.sizes.map((s) => (
                  <li>
                    <span class="size-label">{s.label}</span>
                    <span class="size-price">{s.price}</span>
                  </li>
                ))}
              </ul>
            </article>
          ))
        }
      </div>

      <p class="chips-note">
        <strong>Chips included.</strong> Every queso and salsa order
        comes with our house made chips. Salted, ready to scoop, plenty
        to share.
      </p>
    </div>
  </section>

  <!-- ===== Why it's different ===== -->
  <section class="section breakdown-section">
    <div class="container">
      <SectionTitle
        eyebrow="Why ours hits different"
        title="The whole table starts here."
      />

      <div class="breakdown-grid">
        {
          breakdown.map((b, i) => (
            <article class="breakdown-card">
              <div class="num">0{i + 1}</div>
              <h3>{b.title}</h3>
              <p>{b.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===== Closer ===== -->
  <section class="queso-closer">
    <div class="container closer-inner">
      <span class="eyebrow-script">Bring chips. Bring friends.</span>
      <h2>Skip the line. Order ahead.</h2>
      <p>
        Game day, movie night, kitchen table, tailgate. Grab a family
        size on the way out and the rest of the night handles itself.
      </p>
      <div class="closer-ctas">
        <a
          class="btn btn-primary"
          href="https://online.skytab.com/75fd37a0da5766d1bf27a245fba50884/order-settings"
          target="_blank"
          rel="noopener"
        >Order Online</a>
        <a class="btn btn-ghost dark" href="/menu#appetizers">See the Appetizer Menu</a>
      </div>
    </div>
  </section>
</Base>

<style>
  /* ============ Hero ============ */
  .queso-hero {
    position: relative;
    min-height: clamp(420px, 65vh, 560px);
    background:
      radial-gradient(ellipse at top, rgba(232, 106, 38, 0.35) 0%, transparent 60%),
      linear-gradient(180deg, #2a1a10 0%, #3a2418 100%);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
    isolation: isolate;
  }

  .queso-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      45deg,
      rgba(232, 106, 38, 0.06) 0,
      rgba(232, 106, 38, 0.06) 2px,
      transparent 2px,
      transparent 18px
    );
    pointer-events: none;
  }

  .queso-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.35) 0%,
      rgba(0, 0, 0, 0.7) 100%
    );
    z-index: 1;
  }

  .queso-hero-content {
    position: relative;
    z-index: 2;
    width: min(900px, 92vw);
    padding: 80px 0;
  }

  .queso-hero-content .eyebrow-script {
    color: #ffd9b8;
    font-size: clamp(1.4rem, 2.4vw, 1.9rem);
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.5);
  }

  .queso-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 0.9;
    text-transform: uppercase;
    letter-spacing: 0.005em;
    margin: 8px 0 22px;
    text-shadow: 0 6px 30px rgba(0, 0, 0, 0.5);
  }

  .hero-sub {
    font-size: clamp(1.1rem, 1.5vw, 1.35rem);
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.94);
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
    margin: 0 0 28px;
  }

  .hero-sub span {
    display: block;
  }

  .hero-ctas {
    display: inline-flex;
    gap: 14px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero-ghost {
    border-color: #fff;
    color: #fff;
    box-shadow: 0 4px 0 rgba(255, 255, 255, 0.85);
  }

  .hero-ghost:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  /* ============ Intro ============ */
  .intro-section {
    background: var(--cream);
    padding-bottom: 30px;
  }

  /* ============ Queso cards ============ */
  .queso-cards-section {
    background: var(--cream);
    padding-top: 30px;
  }

  .queso-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  @media (max-width: 1000px) {
    .queso-grid {
      grid-template-columns: 1fr;
      max-width: 600px;
      margin: 0 auto;
    }
  }

  .chips-note {
    text-align: center;
    color: var(--muted);
    margin: 36px auto 0;
    max-width: 56ch;
    line-height: 1.6;
    font-size: 1.02rem;
    font-style: italic;
  }

  .chips-note strong {
    color: var(--ink);
    font-style: normal;
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.95rem;
    margin-right: 6px;
  }

  .queso-card {
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: var(--radius);
    padding: 36px 30px 30px;
    box-shadow: var(--shadow-soft);
    position: relative;
    display: flex;
    flex-direction: column;
    transition: transform 220ms ease, box-shadow 220ms ease;
  }

  .queso-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow);
  }

  .queso-card.pop {
    background: var(--ink);
    color: var(--cream);
    border: 0;
    transform: translateY(-10px);
  }

  .queso-card.pop:hover {
    transform: translateY(-14px);
  }

  @media (max-width: 1000px) {
    .queso-card.pop {
      transform: none;
    }
    .queso-card.pop:hover {
      transform: translateY(-6px);
    }
  }

  .pop-badge {
    position: absolute;
    top: -14px;
    right: 20px;
    background: var(--lime);
    color: var(--ink);
    font-family: var(--font-display);
    font-size: 0.85rem;
    letter-spacing: 0.12em;
    padding: 6px 14px;
    border-radius: 999px;
    box-shadow: 0 4px 0 var(--lime-shadow);
  }

  .queso-tag {
    display: inline-block;
    font-family: var(--font-script);
    color: var(--orange);
    font-size: 1.2rem;
    line-height: 1;
    margin-bottom: 6px;
  }

  .queso-card.pop .queso-tag {
    color: #ffd9b8;
  }

  .queso-card h3 {
    font-family: var(--font-display);
    font-size: 1.9rem;
    text-transform: uppercase;
    letter-spacing: 0.01em;
    line-height: 1;
    margin: 0 0 16px;
    color: var(--ink);
  }

  .queso-card.pop h3 {
    color: #fff;
  }

  .queso-pitch {
    color: var(--muted);
    line-height: 1.6;
    margin: 0 0 24px;
    font-size: 1rem;
    flex: 1;
  }

  .queso-card.pop .queso-pitch {
    color: rgba(255, 247, 236, 0.82);
  }

  .size-list {
    padding-top: 20px;
    border-top: 1px dashed rgba(42, 26, 16, 0.18);
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .queso-card.pop .size-list {
    border-top-color: rgba(255, 247, 236, 0.18);
  }

  .size-list li {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 4px 0;
  }

  .size-label {
    font-family: var(--font-body);
    font-size: 0.98rem;
    color: var(--ink);
    font-weight: 500;
  }

  .queso-card.pop .size-label {
    color: rgba(255, 247, 236, 0.92);
  }

  .size-price {
    font-family: var(--font-display);
    color: var(--orange);
    font-size: 1.35rem;
    letter-spacing: 0.02em;
  }

  .queso-card.pop .size-price {
    color: var(--lime);
  }

  /* ============ Breakdown ============ */
  .breakdown-section {
    background: #fbeed8;
  }

  .breakdown-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  @media (max-width: 900px) {
    .breakdown-grid {
      grid-template-columns: 1fr;
    }
  }

  .breakdown-card {
    background: #fff;
    border-radius: var(--radius);
    padding: 32px 28px;
    border: 1px solid rgba(0, 0, 0, 0.05);
    box-shadow: var(--shadow-soft);
    transition: transform 200ms ease;
  }

  .breakdown-card:hover {
    transform: translateY(-4px);
  }

  .breakdown-card .num {
    font-family: var(--font-display);
    font-size: 2.4rem;
    color: var(--orange);
    line-height: 1;
    margin-bottom: 10px;
    letter-spacing: 0.04em;
  }

  .breakdown-card h3 {
    font-family: var(--font-display);
    font-size: 1.35rem;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--ink);
    margin: 0 0 10px;
    line-height: 1.15;
  }

  .breakdown-card p {
    color: var(--muted);
    line-height: 1.6;
    margin: 0;
    font-size: 0.98rem;
  }

  /* ============ Closer ============ */
  .queso-closer {
    background: var(--teal-dark);
    color: var(--cream);
    padding: clamp(70px, 10vw, 120px) 0;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .queso-closer::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      45deg,
      rgba(255, 247, 236, 0.04) 0,
      rgba(255, 247, 236, 0.04) 2px,
      transparent 2px,
      transparent 16px
    );
    pointer-events: none;
  }

  .closer-inner {
    position: relative;
    z-index: 1;
  }

  .queso-closer .eyebrow-script {
    color: #ffd9b8;
    font-size: clamp(1.3rem, 2vw, 1.7rem);
  }

  .queso-closer h2 {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4.5vw, 3.4rem);
    line-height: 0.95;
    text-transform: uppercase;
    letter-spacing: 0.01em;
    margin: 8px 0 18px;
    color: #fff;
  }

  .queso-closer p {
    max-width: 56ch;
    margin: 0 auto 30px;
    color: rgba(255, 247, 236, 0.85);
    font-size: 1.06rem;
    line-height: 1.6;
  }

  .closer-ctas {
    display: inline-flex;
    gap: 14px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .btn-ghost.dark {
    border-color: var(--cream);
    color: var(--cream);
    box-shadow: 0 4px 0 rgba(255, 247, 236, 0.5);
  }

  .btn-ghost.dark:hover {
    background: rgba(255, 247, 236, 0.08);
  }
</style>
