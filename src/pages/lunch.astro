const lunchMenuSchema = {
  "@context": "https://schema.org",
  "@type": "Menu",
  name: "Los Cabos Sealy Lunch Menu",
  description: "Lunch served Monday through Friday 11AM to 3PM",
  hasMenuSection: menu.map((section) => ({
    "@type": "MenuSection",
    name: section.title,
    hasMenuItem: section.items.map((item: any) => {
      const m: any = { "@type": "MenuItem", name: item.name };
      if (item.desc) m.description = item.desc;
      if (item.price && item.price !== "$—") {
        m.offers = {
          "@type": "Offer",
          price: item.price.replace("$", ""),
          priceCurrency: "USD",
        };
      }
      return m;
    }),
  })),
};
---

<Base
  title="Lunch Menu | Los Cabos Mexican Grill in Sealy, TX"
  description="Lunch at Los Cabos Sealy, 11AM to 3PM Mon-Fri. Combo plates, fajitas, enchiladas, tacos, burritos, chalupas, daily Tex Mex specials. Off I-10."
>
  <script type="application/ld+json" set:html={JSON.stringify(lunchMenuSchema)} />
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow-script">Lunch hours</span>
      <h1>The Lunch Menu</h1>
      <p class="lunch-hours">11AM — 3PM, Monday through Friday</p>
      <p>
        Plates that don't skimp. In, fed, and back to your day. The
        kind of lunch you'll be telling your coworkers about by two
        o'clock.
      </p>
    </div>
  </section>

  <nav class="menu-nav" id="menuNav" aria-label="Lunch menu sections">
    <div class="container">
      <ul>
        {menu.map((s) => <li><a href={`#${s.id}`}>{s.title}</a></li>)}
      </ul>
    </div>
  </nav>

  <script>
    // Hide on scroll down, show on scroll up — mirrors the main menu page nav.
    (() => {
      const nav = document.getElementById("menuNav");
      if (!nav) return;

      let lastY = window.scrollY;
      let ticking = false;
      const SHOW_THRESHOLD = 80;
      const DELTA = 6;

      function update() {
        const y = window.scrollY;
        const goingDown = y > lastY + DELTA;
        const goingUp = y < lastY - DELTA;

        if (y < SHOW_THRESHOLD) {
          nav.classList.remove("is-hidden");
        } else if (goingDown) {
          nav.classList.add("is-hidden");
        } else if (goingUp) {
          nav.classList.remove("is-hidden");
        }

        lastY = y;
        ticking = false;
      }

      window.addEventListener(
        "scroll",
        () => {
          if (!ticking) {
            window.requestAnimationFrame(update);
            ticking = true;
          }
        },
        { passive: true }
      );
    })();
  </script>

  {
    menu.map((section) => (
      <section class="section menu-section" id={section.id}>
        <div class="container">
          <SectionTitle eyebrow={section.eyebrow} title={section.title} />

          {section.blurb && (
            <p class="section-blurb">{section.blurb}</p>
          )}

          <ul class="menu-list">
            {section.items.map((item) => (
              <li class:list={["menu-item", { "is-addon": item.addOn }]}>
                <div class="menu-row">
                  <span class="dish-name">
                    {item.name}
                    {item.tag && <span class="dish-tag">{item.tag}</span>}
                    {item.addOn && <span class="dish-tag add">Add On</span>}
                  </span>
                  {item.price && (
                    <>
                      <span class="dots" aria-hidden="true" />
                      <span class="dish-price">{item.price}</span>
                    </>
                  )}
                </div>
                {item.desc && <p class="dish-desc">{item.desc}</p>}
                {item.variants && (
                  <ul class="dish-variants">
                    {item.variants.map((v) => (
                      <li>
                        <span class="variant-label">{v.label}</span>
                        <span class="variant-price">{v.price}</span>
                      </li>
                    ))}
                  </ul>
                )}
              </li>
            ))}
          </ul>
        </div>
      </section>
    ))
  }

  <section class="section side-swap-note">
    <div class="container">
      <div class="swap-card">
        <span class="lime-eyebrow">Heads up</span>
        <h3>Side swap on the house.</h3>
        <p>
          Any plate that comes with rice and beans? You can swap to
          green beans, broccoli, or sautéed vegetables. Just ask.
        </p>
      </div>
    </div>
  </section>

  <section class="lunch-closer">
    <div class="container closer-inner">
      <span class="eyebrow-script">Don't sleep on lunch</span>
      <h2>11AM to 3PM. Monday to Friday.</h2>
      <p>
        Tell the coworkers. Bring the team. Order ahead if you're in a
        hurry. We'll have you fed and back at your desk before anybody
        notices you left.
      </p>
      <div class="closer-ctas">
        <a
          class="btn btn-primary"
          href="https://online.skytab.com/75fd37a0da5766d1bf27a245fba50884/order-settings"
          target="_blank"
          rel="noopener"
        >Order Online</a>
        <a class="btn btn-ghost dark" href="tel:+15126076232">Call (512) 607-6232</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .lunch-hours {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--orange);
    font-size: 1.05rem;
    margin-bottom: 12px;
  }

  .menu-nav {
    background: var(--ink);
    color: var(--cream);
    position: sticky;
    top: 86px;
    z-index: 30;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.18);
    transition: transform 280ms ease;
    will-change: transform;
  }

  .menu-nav.is-hidden {
    transform: translateY(-200%);
  }

  .menu-nav ul {
    display: flex;
    justify-content: center;
    gap: 22px;
    flex-wrap: wrap;
    padding: 14px 0;
  }

  .menu-nav a {
    font-family: var(--font-display);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--cream);
    font-size: 0.9rem;
    transition: color 150ms ease;
    white-space: nowrap;
  }

  .menu-nav a:hover {
    color: var(--orange);
  }

  @media (max-width: 900px) {
    .menu-nav ul {
      flex-wrap: nowrap;
      justify-content: flex-start;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    .menu-nav ul::-webkit-scrollbar {
      display: none;
    }
  }

  .menu-section:nth-child(odd) {
    background: var(--cream);
  }
  .menu-section:nth-child(even) {
    background: #fbeed8;
  }

  .section-blurb {
    text-align: center;
    color: var(--muted);
    max-width: 70ch;
    margin: -28px auto 38px;
    font-size: 1.02rem;
    line-height: 1.6;
    font-style: italic;
  }

  .menu-list {
    display: flex;
    flex-direction: column;
    gap: 26px;
    max-width: 880px;
    margin: 0 auto;
  }

  .menu-item {
    border-bottom: 1px dashed rgba(42, 26, 16, 0.18);
    padding-bottom: 22px;
  }

  .menu-item.is-addon {
    background: rgba(232, 106, 38, 0.06);
    border: 1px solid rgba(232, 106, 38, 0.25);
    border-radius: var(--radius);
    padding: 20px 24px;
  }

  .menu-row {
    display: flex;
    align-items: baseline;
    gap: 10px;
  }

  .dish-name {
    font-family: var(--font-display);
    font-size: 1.55rem;
    text-transform: uppercase;
    color: var(--ink);
    letter-spacing: 0.02em;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .dish-tag {
    background: var(--orange);
    color: #fff;
    font-family: var(--font-display);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    padding: 3px 9px;
    border-radius: 999px;
    box-shadow: 0 2px 0 rgba(0, 0, 0, 0.15);
  }

  .dish-tag.add {
    background: var(--teal);
  }

  .dots {
    flex: 1;
    border-bottom: 2px dotted rgba(42, 26, 16, 0.4);
    transform: translateY(-6px);
  }

  .dish-price {
    font-family: var(--font-display);
    font-size: 1.45rem;
    color: var(--orange);
  }

  .dish-desc {
    color: var(--muted);
    font-size: 0.98rem;
    line-height: 1.6;
    margin: 6px 0 0;
    max-width: 70ch;
  }

  .dish-variants {
    margin-top: 12px;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 4px 22px;
    background: rgba(255, 255, 255, 0.55);
    border-radius: 8px;
    padding: 12px 16px;
    border: 1px solid rgba(42, 26, 16, 0.08);
  }

  @media (max-width: 600px) {
    .dish-variants {
      grid-template-columns: 1fr;
    }
  }

  .dish-variants li {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: baseline;
    padding: 4px 0;
    border: 0;
  }

  .variant-label {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--ink);
    font-weight: 500;
  }

  .variant-price {
    font-family: var(--font-display);
    color: var(--orange);
    font-size: 1.05rem;
    letter-spacing: 0.02em;
  }

  /* ============ Side swap note ============ */
  .side-swap-note {
    background: var(--cream);
  }

  .swap-card {
    background: #fff;
    border: 2px dashed var(--orange);
    border-radius: var(--radius);
    padding: 36px 32px;
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
  }

  .swap-card .lime-eyebrow {
    font-family: var(--font-script);
    color: var(--orange);
    font-size: 1.4rem;
    line-height: 1;
    display: inline-block;
    margin-bottom: 8px;
  }

  .swap-card h3 {
    font-family: var(--font-display);
    font-size: 1.8rem;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--ink);
    margin: 0 0 12px;
  }

  .swap-card p {
    color: var(--muted);
    line-height: 1.6;
    margin: 0;
    max-width: 56ch;
    margin-left: auto;
    margin-right: auto;
  }

  /* ============ Closer ============ */
  .lunch-closer {
    background: var(--teal-dark);
    color: var(--cream);
    padding: clamp(70px, 10vw, 120px) 0;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .lunch-closer::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      45deg,
      rgba(255, 247, 236, 0.04) 0,
      rgba(255, 247, 236, 0.04) 2px,
      transparent 2px,
      transparent 16px
    );
    pointer-events: none;
  }

  .closer-inner {
    position: relative;
    z-index: 1;
  }

  .lunch-closer .eyebrow-script {
    color: #ffd9b8;
    font-size: clamp(1.3rem, 2vw, 1.7rem);
  }

  .lunch-closer h2 {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4.5vw, 3.4rem);
    line-height: 0.95;
    text-transform: uppercase;
    letter-spacing: 0.01em;
    margin: 8px 0 18px;
    color: #fff;
  }

  .lunch-closer p {
    max-width: 56ch;
    margin: 0 auto 30px;
    color: rgba(255, 247, 236, 0.85);
    font-size: 1.06rem;
    line-height: 1.6;
  }

  .closer-ctas {
    display: inline-flex;
    gap: 14px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .btn-ghost.dark {
    border-color: var(--cream);
    color: var(--cream);
    box-shadow: 0 4px 0 rgba(255, 247, 236, 0.5);
  }

  .btn-ghost.dark:hover {
    background: rgba(255, 247, 236, 0.08);
  }
</style>
