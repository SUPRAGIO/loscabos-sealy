---
import Base from "@/layouts/Base.astro";
import SectionTitle from "@/components/SectionTitle.astro";
---

<Base
  title="Contact & Directions | Los Cabos Mexican Grill, Sealy TX"
  description="Visit Los Cabos Mexican Grill in Sealy, TX at 6027 FM 3538, just off I-10. Call (512) 607-6232. Open Sun-Wed 11AM-9PM, Thu-Sat 11AM-10PM. Find us on the map."
>
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow-script">Come say hola</span>
      <h1>Find us in Sealy.</h1>
      <p>
        We're easy to spot, easier to walk into, and we save the
        corner booth seat for whoever's brave enough to ask.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container contact-grid">
      <div class="info">
        <SectionTitle eyebrow="The basics" title="How to reach us." align="left" />
        <ul class="info-list">
          <li>
            <strong>Address</strong>
            <span>6027 FM 3538<br />Sealy, TX 77474</span>
          </li>
          <li>
            <strong>Phone</strong>
            <a href="tel:+15126076232">(512) 607-6232</a>
          </li>
          <li>
            <strong>Email</strong>
            <a href="mailto:hola@loscabossealy.com">hola@loscabossealy.com</a>
          </li>
          <li>
            <strong>Hours</strong>
            <ul class="hours-list">
              <li><span>Sun — Wed</span><span>11AM — 9PM</span></li>
              <li><span>Thu — Sat</span><span>11AM — 10PM</span></li>
            </ul>
          </li>
        </ul>

        <div class="cta-row">
          <a class="btn btn-primary" href="https://online.skytab.com/75fd37a0da5766d1bf27a245fba50884/order-settings" target="_blank" rel="noopener">Order Online</a>
          <a class="btn btn-ghost" href="/catering">Catering Inquiry</a>
        </div>
      </div>

      <div class="map-card">
        <iframe
          title="Map to Los Cabos Mexican Grill, Sealy TX"
          src="https://www.google.com/maps?q=Sealy%20TX&output=embed"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </section>
</Base>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: stretch;
  }

  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }

  .info-list {
    display: flex;
    flex-direction: column;
    gap: 22px;
  }

  .info-list > li {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 20px;
    align-items: start;
    border-bottom: 1px dashed rgba(42, 26, 16, 0.2);
    padding-bottom: 18px;
  }

  .info-list strong {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.95rem;
    color: var(--orange);
  }

  .info-list a {
    color: var(--ink);
    border-bottom: 2px solid var(--orange);
  }

  .hours-list {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .hours-list li {
    display: flex;
    justify-content: space-between;
    color: var(--muted);
    border: 0;
    padding: 0;
  }

  .cta-row {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 30px;
  }

  .map-card {
    border-radius: var(--radius);
    overflow: hidden;
    border: 6px solid #fff;
    box-shadow: var(--shadow);
    min-height: 480px;
  }

  .map-card iframe {
    width: 100%;
    height: 100%;
    min-height: 480px;
    border: 0;
  }
</style>
