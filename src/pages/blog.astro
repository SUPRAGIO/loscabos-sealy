---
import Base from "@/layouts/Base.astro";
---

<Base
  title="Blog Coming Soon | Los Cabos Mexican Grill in Sealy, TX"
  description="Stories from the kitchen and the bar in Sealy, Texas. The Los Cabos Tex Mex blog is coming soon. Sign up to get the first story."
>
  <section class="coming-soon">
    <div class="container cs-inner">
      <span class="eyebrow">El Blog</span>
      <h1>Coming Soon.</h1>
      <p class="lede">
        We're cooking up stories from the kitchen, the bar, and the
        familia behind every plate. Sign up to know when the first
        story drops.
      </p>

      <form
        name="blog-notify"
        method="POST"
        data-netlify="true"
        netlify-honeypot="hp"
        class="notify-form"
      >
        <input type="hidden" name="form-name" value="blog-notify" />
        <label class="hp" aria-hidden="true">
          Don't fill this: <input name="hp" tabindex="-1" />
        </label>
        <div class="notify-row">
          <input
            type="email"
            name="email"
            placeholder="your@email.com"
            required
            aria-label="Email address"
          />
          <button type="submit" class="btn btn-primary">Notify Me</button>
        </div>
        <p class="form-fine">No spam. Just stories. Unsubscribe anytime.</p>
      </form>

      <div class="cs-meanwhile">
        <span class="meanwhile-label">In the meantime</span>
        <div class="cs-links">
          <a href="/menu">See the Menu</a>
          <a href="/bar">The Bar</a>
          <a href="/catering">Catering</a>
          <a href="/about">Our Story</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .coming-soon {
    min-height: 70vh;
    background: var(--cream);
    display: flex;
    align-items: center;
    padding: clamp(80px, 12vw, 140px) 0;
    position: relative;
    overflow: hidden;
  }

  .coming-soon::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      45deg,
      rgba(232, 106, 38, 0.04) 0,
      rgba(232, 106, 38, 0.04) 2px,
      transparent 2px,
      transparent 18px
    );
    pointer-events: none;
  }

  .cs-inner {
    text-align: center;
    max-width: 640px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .eyebrow {
    font-family: var(--font-script);
    color: var(--orange);
    font-size: clamp(1.6rem, 2.5vw, 2rem);
    line-height: 1;
    display: inline-block;
    margin-bottom: 12px;
  }

  .coming-soon h1 {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 5.5rem);
    line-height: 0.95;
    text-transform: uppercase;
    letter-spacing: 0.005em;
    color: var(--ink);
    margin: 0 0 22px;
  }

  .lede {
    font-size: clamp(1.05rem, 1.4vw, 1.18rem);
    line-height: 1.6;
    color: var(--muted);
    margin: 0 auto 36px;
    max-width: 48ch;
  }

  /* ============ Notify form ============ */
  .notify-form {
    max-width: 460px;
    margin: 0 auto 50px;
  }

  .notify-row {
    display: flex;
    gap: 8px;
    background: #fff;
    border-radius: 999px;
    padding: 6px;
    border: 1px solid rgba(0, 0, 0, 0.08);
    box-shadow: var(--shadow-soft);
  }

  @media (max-width: 480px) {
    .notify-row {
      flex-direction: column;
      border-radius: var(--radius);
      padding: 12px;
    }
  }

  .notify-row input[type="email"] {
    flex: 1;
    border: 0;
    background: transparent;
    padding: 12px 18px;
    font: inherit;
    font-size: 1rem;
    color: var(--ink);
    outline: none;
    min-width: 0;
  }

  .notify-row input[type="email"]::placeholder {
    color: rgba(42, 26, 16, 0.4);
  }

  .notify-row .btn {
    flex-shrink: 0;
  }

  .form-fine {
    font-size: 0.82rem;
    color: var(--muted);
    margin: 12px 0 0;
    text-align: center;
  }

  .hp {
    display: none;
  }

  /* ============ Meanwhile ============ */
  .cs-meanwhile {
    padding-top: 36px;
    border-top: 1px dashed rgba(42, 26, 16, 0.18);
  }

  .meanwhile-label {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--muted);
    font-size: 0.78rem;
    display: block;
    margin-bottom: 16px;
  }

  .cs-links {
    display: inline-flex;
    gap: 8px 22px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .cs-links a {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.92rem;
    color: var(--ink);
    padding-bottom: 2px;
    border-bottom: 2px solid transparent;
    transition: border-color 150ms ease, color 150ms ease;
  }

  .cs-links a:hover {
    color: var(--orange);
    border-bottom-color: var(--orange);
  }
</style>
