---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Los Cabos Mexican Grill — Sealy, TX | Authentic Tex-Mex" description="Sizzling fajitas, hand-crafted margaritas, and scratch-made Tex-Mex in Sealy, TX. Dine in or order online. Ready in 15 minutes.">

<section class="hero">
  <video class="hero-bg" autoplay muted loop playsinline poster="/images/hero-poster.jpg">
    <source src="/video/hero.mp4" type="video/mp4" />
  </video>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <div class="hero-left">
      <h1 class="hero-headline">FAJITAS<br><em>FIX</em>EVERYTHING.</h1>
      <div class="hero-ctas">
        <a href="https://online.skytab.com/75fd37a0da5766d1bf27a245fba50884" target="_blank" rel="noopener" class="btn-primary">Order Online</a>
        <a href="#menu" class="btn-outline">View Menu</a>
        <a href="tel:+15126076232" class="btn-ghost">Call Now</a>
      </div>
      <div class="hero-proof">
        <div class="proof-item"><div class="proof-num">4.8</div><div class="proof-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div><div class="proof-label">Google Rating</div></div>
        <div class="proof-sep"></div>
        <div class="proof-item"><div class="proof-num">1,725+</div><div class="proof-label">Happy Locals</div></div>
        <div class="proof-sep"></div>
        <div class="proof-item"><div class="proof-num">15<span class="proof-unit"> min</span></div><div class="proof-label">Avg. Pickup</div></div>
      </div>
    </div>
    <div class="hero-info-card">
      <div class="info-card-row"><span class="info-label">Hours</span><span class="info-value">Sun-Wed 11AM-9PM<br>Thu-Sat 11AM-10PM</span></div>
      <div class="info-divider"></div>
      <div class="info-card-row"><span class="info-label">Address</span><span class="info-value">6027 FM 3538 Rd<br>Sealy, TX 77474</span></div>
      <div class="info-divider"></div>
      <div class="info-card-row"><span class="info-label">Phone</span><span class="info-value"><a href="tel:+15126076232">(512) 607-6232</a></span></div>
      <div class="info-divider"></div>
      <a href="https://online.skytab.com/75fd37a0da5766d1bf27a245fba50884" target="_blank" rel="noopener" class="btn-primary" style="text-align:center;">ORDER NOW &#8594;</a>
    </div>
  </div>
</section>

<section class="trust-bar">
  <div class="trust-item"><span>&#10003;</span><span>Made From Scratch</span></div>
  <div class="trust-sep"></div>
  <div class="trust-item"><span>&#10003;</span><span>Margaritas Made Right</span></div>
  <div class="trust-sep"></div>
  <div class="trust-item"><span>&#10003;</span><span>15-Minute Pickup</span></div>
  <div class="trust-sep"></div>
  <div class="trust-item"><span>&#10003;</span><span>Dine In or Carry Out</span></div>
</section>

<section class="atmosphere">
  <div class="atm-img"><img src="/images/server.jpg" alt="Los Cabos hospitality" loading="lazy" /></div>
  <div class="atm-text">
    <div class="section-eyebrow">Our Story</div>
    <h2 class="section-heading">REAL FOOD.<br>REAL HOSPITALITY.</h2>
    <p>Los Cabos has been feeding Austin County for years. From sizzling fajita platters to hand-crafted margaritas — every order comes out of a scratch kitchen that doesn't cut corners.</p>
    <p style="margin-top:16px;">No shortcuts. No frozen shortcuts. The kind of Tex-Mex Sealy has been talking about for years.</p>
    <p style="margin-top:16px;font-style:italic;color:var(--text-muted);">Serving Sealy, Austin County &amp; beyond.</p>
  </div>
</section>

<section class="menu-section" id="menu">
  <div class="menu-header">
    <div class="section-eyebrow">What We're Known For</div>
    <h2 class="section-heading">THE MENU</h2>
  </div>
  <div class="menu-tabs">
    <button class="tab-btn active" data-tab="fajitas">Fajitas</button>
    <button class="tab-btn" data-tab="plates">Plates</button>
    <button class="tab-btn" data-tab="drinks">Drinks</button>
    <button class="tab-btn" data-tab="apps">Appetizers</button>
  </div>
  <div class="menu-grid tab-content active" id="tab-fajitas">
    <div class="menu-card"><div class="menu-card-img"><img src="/images/fajitas.jpg" alt="Beef Fajitas" loading="lazy" /></div><div class="menu-card-body"><div class="menu-card-name">Beef Fajitas</div><div class="menu-card-desc">Grilled skirt steak, peppers &amp; onions, flour tortillas</div><div class="menu-card-price">$16.95</div></div></div>
    <div class="menu-card"><div class="menu-card-img"><img src="/images/fajitas.jpg" alt="Chicken Fajitas" loading="lazy" /></div><div class="menu-card-body"><div class="menu-card-name">Chicken Fajitas</div><div class="menu-card-desc">Marinated chicken breast, peppers &amp; onions</div><div class="menu-card-price">$15.95</div></div></div>
    <div class="menu-card"><div class="menu-card-img"><img src="/images/fajitas.jpg" alt="Combo Fajitas" loading="lazy" /></div><div class="menu-card-body"><div class="menu-card-name">Combo Fajitas</div><div class="menu-card-desc">Beef &amp; chicken, peppers &amp; onions, all the fixings</div><div class="menu-card-price">$18.95</div></div></div>
    <div class="menu-card"><div class="menu-card-img"><img src="/images/fajitas.jpg" alt="Shrimp Fajitas" loading="lazy" /></div><div class="menu-card-body"><div class="menu-card-name">Shrimp Fajitas</div><div class="menu-card-desc">Grilled shrimp, peppers &amp; onions, flour tortillas</div><div class="menu-card-price">$17.95</div></div></div>
    <div class="menu-card"><div class="menu-card-img"><img src="/images/fajitas.jpg" alt="Vegetable Fajitas" loading="lazy" /></div><div class="menu-card-body"><div class="menu-card-name">Vegetable Fajitas</div><div class="menu-card-desc">Seasonal veggies, peppers &amp; onions, flour tortillas</div><div class="menu-card-price">$13.95</div></div></div>
    <div class="menu-card"><div class="menu-card-img"><img src="/images/fajitas.jpg" alt="Fajitas for Two" loading="lazy" /></div><div class="menu-card-body"><div class="menu-card-name">Fajitas for Two</div><div class="menu-card-desc">Beef &amp; chicken combo, all the fixings for two</div><div class="menu-card-price">$32.95</div></div></div>
  </div>
  <div class="menu-grid tab-content" id="tab-plates">
    <div class="menu-card"><div class="menu-card-img"><img src="/images/enchiladas.jpg" alt="Enchiladas" loading="lazy" /></div><div class="menu-card-body"><div class="menu-card-name">Enchiladas</div><div class="menu-card-desc">3 enchiladas, rice &amp; beans, your choice of sauce</div><div class="menu-card-price">$12.95</div></div></div>
    <div class="menu-card"><div class="menu-card-img"><img src="/images/ribeye.jpg" alt="Ribeye Steak" loading="lazy" /></div><div class="menu-card-body"><div class="menu-card-name">Ribeye Steak</div><div class="menu-card-desc">12oz ribeye, rice, beans, and tortillas</div><div class="menu-card-price">$24.95</div></div></div>
    <div class="menu-card"><div class="menu-card-img"><img src="/images/ribeye.jpg" alt="T-Bone Steak" loading="lazy" /></div><div class="menu-card-body"><div class="menu-card-name">T-Bone Steak</div><div class="menu-card-desc">14oz T-bone, rice, beans, and tortillas</div><div class="menu-card-price">$26.95</div></div></div>
    <div class="menu-card"><div class="menu-card-img"><img src="/images/enchiladas.jpg" alt="Tamales" loading="lazy" /></div><div class="menu-card-body"><div class="menu-card-name">Tamales</div><div class="menu-card-desc">3 tamales, rice &amp; beans</div><div class="menu-card-price">$12.50</div></div></div>
    <div class="menu-card"><div class="menu-card-img"><img src="/images/enchiladas.jpg" alt="Combo Plate" loading="lazy" /></div><div class="menu-card-body"><div class="menu-card-name">Combo Plate</div><div class="menu-card-desc">Enchilada, taco, and tamale with rice &amp; beans</div><div class="menu-card-price">$13.50</div></div></div>
    <div class="menu-card"><div class="menu-card-img"><img src="/images/enchiladas.jpg" alt="Los Cabos Special" loading="lazy" /></div><div class="menu-card-body"><div class="menu-card-name">Los Cabos Special</div><div class="menu-card-desc">Chef's combination plate with rice &amp; beans</div><div class="menu-card-price">$15.95</div></div></div>
  </div>
  <div class="menu-grid tab-content" id="tab-drinks">
    <div class="menu-card"><div class="menu-card-img"><img src="/images/michelada.jpg" alt="Classic Margarita" loading="lazy" /></div><div class="menu-card-body"><div class="menu-card-name">Classic Margarita</div><div class="menu-card-desc">House tequila, triple sec, fresh lime</div><div class="menu-card-price">$8.50</div></div></div>
    <div class="menu-card"><div class="menu-card-img"><img src="/images/michelada.jpg" alt="Mango Margarita" loading="lazy" /></div><div class="menu-card-body"><div class="menu-card-name">Mango Margarita</div><div class="menu-card-desc">House tequila, mango puree, fresh lime</div><div class="menu-card-price">$9.50</div></div></div>
    <div class="menu-card"><div class="menu-card-img"><img src="/images/michelada.jpg" alt="Michelada" loading="lazy" /></div><div class="menu-card-body"><div class="menu-card-name">Michelada</div><div class="menu-card-desc">Beer, clamato, lime, hot sauce, tajin rim</div><div class="menu-card-price">$8.50</div></div></div>
    <div class="menu-card"><div class="menu-card-img"><img src="/images/michelada.jpg" alt="Strawberry Margarita" loading="lazy" /></div><div class="menu-card-body"><div class="menu-card-name">Strawberry Margarita</div><div class="menu-card-desc">House tequila, strawberry, fresh lime</div><div class="menu-card-price">$9.50</div></div></div>
    <div class="menu-card"><div class="menu-card-img"><img src="/images/michelada.jpg" alt="Sangria" loading="lazy" /></div><div class="menu-card-body"><div class="menu-card-name">Sangria</div><div class="menu-card-desc">House red wine sangria with fruit</div><div class="menu-card-price">$7.50</div></div></div>
    <div class="menu-card"><div class="menu-card-img"><img src="/images/michelada.jpg" alt="Beer" loading="lazy" /></div><div class="menu-card-body"><div class="menu-card-name">Beer</div><div class="menu-card-desc">Domestic and imported selections</div><div class="menu-card-price">$4.50</div></div></div>
  </div>
  <div class="menu-grid tab-content" id="tab-apps">
    <div class="menu-card"><div class="menu-card-img"><img src="/images/queso.jpg" alt="Queso" loading="lazy" /></div><div class="menu-card-body"><div class="menu-card-name">Queso</div><div class="menu-card-desc">House queso dip with chips (free 11AM-2PM dine-in)</div><div class="menu-card-price">$5.95</div></div></div>
    <div class="menu-card"><div class="menu-card-img"><img src="/images/queso.jpg" alt="Queso Flameado" loading="lazy" /></div><div class="menu-card-body"><div class="menu-card-name">Queso Flameado</div><div class="menu-card-desc">Sizzling skillet queso with chorizo</div><div class="menu-card-price">$13.15</div></div></div>
    <div class="menu-card"><div class="menu-card-img"><img src="/images/queso.jpg" alt="Guacamole" loading="lazy" /></div><div class="menu-card-body"><div class="menu-card-name">Guacamole</div><div class="menu-card-desc">Fresh made tableside guacamole with chips</div><div class="menu-card-price">$8.95</div></div></div>
    <div class="menu-card"><div class="menu-card-img"><img src="/images/queso.jpg" alt="Nachos" loading="lazy" /></div><div class="menu-card-body"><div class="menu-card-name">Nachos</div><div class="menu-card-desc">Chips, queso, jalapenos, sour cream</div><div class="menu-card-price">$9.95</div></div></div>
    <div class="menu-card"><div class="menu-card-img"><img src="/images/queso.jpg" alt="Nachos Supreme" loading="lazy" /></div><div class="menu-card-body"><div class="menu-card-name">Nachos Supreme</div><div class="menu-card-desc">Chips, queso, beef, beans, jalapenos, all toppings</div><div class="menu-card-price">$13.95</div></div></div>
    <div class="menu-card"><div class="menu-card-img"><img src="/images/queso.jpg" alt="Wings and Fries" loading="lazy" /></div><div class="menu-card-body"><div class="menu-card-name">Wings &amp; Fries</div><div class="menu-card-desc">Crispy wings, seasoned fries, dipping sauce</div><div class="menu-card-price">$13.95</div></div></div>
  </div>
  <div style="text-align:center;margin-top:48px;">
    <a href="https://online.skytab.com/75fd37a0da5766d1bf27a245fba50884" target="_blank" rel="noopener" class="btn-primary">Order Now &#8594;</a>
  </div>
</section>

<section class="catering-section" id="catering">
  <div class="catering-img"><img src="/images/van.jpg" alt="Los Cabos catering" loading="lazy" /></div>
  <div class="catering-text">
    <div class="section-eyebrow">Events &amp; Catering</div>
    <h2 class="section-heading">WE COME<br>TO YOU.</h2>
    <p class="catering-sub">Real Tex-Mex. Your location. We handle everything from setup to the last tortilla. You just show up hungry.</p>
    <ul class="catering-list">
      <li>Weddings, corporate events &amp; private parties</li>
      <li>Custom menus built around your event</li>
      <li>Groups of 20 to 500+</li>
      <li>Full setup and breakdown included</li>
    </ul>
    <a href="tel:+15126076232" class="btn-primary">Call to Book — (512) 607-6232</a>
  </div>
</section>

<section class="reviews-section">
  <div class="reviews-header">
    <div class="section-eyebrow">Google Reviews</div>
    <h2 class="section-heading" style="color:white;">WHAT OUR REGULARS<br>ARE SAYING</h2>
    <div class="reviews-agg">
      <span class="reviews-score">4.8</span>
      <div><div class="reviews-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div><div class="reviews-count">Based on 1,725+ reviews</div></div>
    </div>
  </div>
  <div class="reviews-grid">
    <div class="review-card"><div class="review-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div><p class="review-text">"Best fajitas in Austin County. The sizzling platter comes out perfect every time. We come here every Friday night."</p><div class="review-name">— Maria G.</div></div>
    <div class="review-card"><div class="review-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div><p class="review-text">"The margaritas are incredible and the queso is free during lunch. Can't beat that. Service is always fast and friendly."</p><div class="review-name">— James T.</div></div>
    <div class="review-card"><div class="review-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div><p class="review-text">"Catered our company party and blew everyone away. Professional, on time, and the food was outstanding."</p><div class="review-name">— Sandra R.</div></div>
  </div>
</section>

<section class="find-section" id="find-us">
  <div class="find-content">
    <div><div class="section-eyebrow">Come In</div><h2 class="section-heading">FIND US</h2></div>
    <div class="find-row"><span class="find-label">Address</span><span class="find-value">6027 FM 3538 Rd<br>Sealy, TX 77474</span></div>
    <div class="find-row"><span class="find-label">Phone</span><span class="find-value"><a href="tel:+15126076232">(512) 607-6232</a></span></div>
    <div class="find-row"><span class="find-label">Hours</span><span class="find-value">Sun-Wed: 11AM - 9PM<br>Thu-Sat: 11AM - 10PM</span></div>
    <a href="https://maps.google.com/?q=6027+FM+3538+Rd+Sealy+TX+77474" target="_blank" rel="noopener" class="btn-primary" style="width:fit-content;">Get Directions &#8594;</a>
  </div>
  <div class="map-embed">
    <iframe title="Los Cabos Mexican Grill Sealy TX" src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3467.2!2d-96.1566!3d29.7810!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!5e0!3m2!1sen!2sus!4v1" width="100%" height="100%" style="border:0;" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
  </div>
</section>

</Layout>

<style>
.hero{position:relative;min-height:100vh;display:flex;align-items:flex-end;padding-top:calc(var(--nav-h) + 38px);overflow:hidden}
.hero-bg{position:absolute;inset:0;z-index:0;width:100%;height:100%;object-fit:cover;object-position:center 40%}
.hero-overlay{position:absolute;inset:0;z-index:1;background:linear-gradient(to bottom,rgba(14,11,8,.15) 0%,rgba(14,11,8,0) 20%,rgba(14,11,8,.5) 65%,rgba(14,11,8,.97) 100%),linear-gradient(to right,rgba(14,11,8,.4) 0%,rgba(14,11,8,0) 60%)}
.hero-content{position:relative;z-index:2;width:100%;padding:0 72px 72px;display:grid;grid-template-columns:1fr auto;align-items:end;gap:40px}
.hero-left{max-width:700px}
.hero-headline{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:clamp(100px,14vw,180px);line-height:.88;text-transform:uppercase;color:white;letter-spacing:-.01em;margin-bottom:36px}
.hero-headline em{color:var(--orange);font-style:italic;display:block}
.hero-ctas{display:flex;gap:12px;margin-bottom:36px;flex-wrap:wrap}
.hero-proof{display:flex;align-items:center;gap:24px}
.proof-item{display:flex;flex-direction:column;gap:2px}
.proof-sep{width:1px;height:36px;background:rgba(255,255,255,.2);flex-shrink:0}
.proof-num{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:24px;color:white;line-height:1}
.proof-unit{font-size:15px;color:rgba(255,255,255,.5);font-weight:600}
.proof-label{font-size:10px;color:rgba(255,255,255,.45);text-transform:uppercase;letter-spacing:.1em;font-weight:600;white-space:nowrap}
.proof-stars{color:var(--gold);font-size:11px;letter-spacing:1px}
.hero-info-card{background:rgba(20,16,12,.88);border:1px solid rgba(244,98,31,.2);border-radius:10px;padding:28px 24px;min-width:230px;backdrop-filter:blur(16px);display:flex;flex-direction:column;gap:18px}
.info-card-row{display:flex;flex-direction:column;gap:3px}
.info-label{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:rgba(255,255,255,.38)}
.info-value{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:15px;color:white;line-height:1.35}
.info-value a{color:var(--orange);text-decoration:none}
.info-divider{height:1px;background:rgba(255,255,255,.07)}
.trust-bar{background:var(--nav-bg);padding:28px 72px;display:flex;align-items:center;justify-content:center;gap:0;flex-wrap:wrap}
.trust-item{display:flex;align-items:center;gap:10px;padding:8px 40px;color:rgba(255,255,255,.75);font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:14px;letter-spacing:.08em;text-transform:uppercase}
.trust-sep{width:1px;height:28px;background:rgba(255,255,255,.12)}
.atmosphere{display:grid;grid-template-columns:1fr 1fr;min-height:500px}
.atm-img img{width:100%;height:100%;object-fit:cover}
.atm-text{background:var(--bg2);padding:72px 64px;display:flex;flex-direction:column;justify-content:center}
.atm-text p{color:var(--text-body);max-width:460px}
.menu-section{padding:80px 72px;background:var(--bg)}
.menu-header{margin-bottom:40px}
.menu-tabs{display:flex;gap:4px;margin-bottom:40px;border-bottom:2px solid var(--border)}
.tab-btn{font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:14px;letter-spacing:.12em;text-transform:uppercase;padding:10px 24px;background:none;border:none;cursor:pointer;color:var(--text-muted);border-bottom:2px solid transparent;margin-bottom:-2px;transition:color .2s,border-color .2s}
.tab-btn.active,.tab-btn:hover{color:var(--orange);border-bottom-color:var(--orange)}
.tab-content{display:none;grid-template-columns:repeat(3,1fr);gap:24px}
.tab-content.active{display:grid}
.menu-card{background:white;border-radius:8px;overflow:hidden;border:1px solid var(--border);transition:transform .2s,box-shadow .2s}
.menu-card:hover{transform:translateY(-3px);box-shadow:0 8px 24px rgba(0,0,0,.08)}
.menu-card-img{height:180px;overflow:hidden;background:var(--bg2)}
.menu-card-img img{width:100%;height:100%;object-fit:cover}
.menu-card-body{padding:16px 20px 20px}
.menu-card-name{font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:18px;color:var(--text-head);margin-bottom:4px}
.menu-card-desc{font-size:13px;color:var(--text-muted);line-height:1.5;margin-bottom:12px}
.menu-card-price{font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:17px;color:var(--gold)}
.catering-section{display:grid;grid-template-columns:1fr 1fr;min-height:560px;background:var(--bg2)}
.catering-img img{width:100%;height:100%;object-fit:cover}
.catering-text{padding:72px 64px;display:flex;flex-direction:column;justify-content:center;gap:24px}
.catering-sub{font-size:18px;color:var(--text-body);line-height:1.6;max-width:460px}
.catering-list{list-style:none;display:flex;flex-direction:column;gap:12px}
.catering-list li{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:16px;letter-spacing:.04em;color:var(--text-head);padding-left:20px;position:relative}
.catering-list li::before{content:"✓";position:absolute;left:0;color:var(--orange)}
.reviews-section{padding:80px 72px;background:var(--nav-bg)}
.reviews-header{margin-bottom:48px}
.reviews-agg{display:flex;align-items:center;gap:16px;margin-top:16px}
.reviews-score{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:56px;color:white;line-height:1}
.reviews-stars{color:var(--gold);font-size:20px;letter-spacing:2px}
.reviews-count{font-size:13px;color:rgba(255,255,255,.45);margin-top:2px}
.reviews-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.review-card{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:8px;padding:28px}
.review-stars{color:var(--gold);font-size:16px;letter-spacing:2px;margin-bottom:12px}
.review-text{color:rgba(255,255,255,.8);font-size:15px;line-height:1.65;margin-bottom:16px;font-style:italic}
.review-name{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:13px;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.4)}
.find-section{display:grid;grid-template-columns:1fr 1fr;min-height:480px}
.find-content{background:var(--bg2);padding:72px 64px;display:flex;flex-direction:column;gap:24px;justify-content:center}
.find-row{display:flex;flex-direction:column;gap:4px}
.find-label{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:10px;letter-spacing:.25em;text-transform:uppercase;color:var(--text-muted)}
.find-value{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:16px;color:var(--text-head);line-height:1.4}
.find-value a{color:var(--orange);text-decoration:none}
.map-embed iframe{width:100%;height:100%;min-height:400px;border:0}
@media(max-width:768px){
  .hero{height:100svh;max-height:100svh;padding-top:calc(58px + 36px)}
  .hero-content{grid-template-columns:1fr;padding:0 20px 80px}
  .hero-info-card{display:none}
  .hero-headline{font-size:clamp(54px,14.5vw,78px);margin-bottom:24px}
  .trust-bar{padding:20px;gap:0}
  .trust-sep{display:none}
  .trust-item{padding:8px 16px;font-size:12px}
  .atmosphere{grid-template-columns:1fr}
  .atm-img{height:300px}
  .atm-text{padding:48px 24px}
  .menu-section{padding:60px 20px}
  .tab-content.active{grid-template-columns:1fr 1fr;gap:16px}
  .catering-section{grid-template-columns:1fr}
  .catering-img{height:280px}
  .catering-text{padding:48px 24px}
  .reviews-section{padding:60px 20px}
  .reviews-grid{grid-template-columns:1fr;gap:16px}
  .find-section{grid-template-columns:1fr}
  .find-content{padding:48px 24px}
  .map-embed iframe{min-height:300px}
}
@media(max-width:480px){
  .tab-content.active{grid-template-columns:1fr}
}
</style>

<script>
const tabs = document.querySelectorAll('.tab-btn');
const contents = document.querySelectorAll('.tab-content');
tabs.forEach(btn => {
  btn.addEventListener('click', () => {
    tabs.forEach(t => t.classList.remove('active'));
    contents.forEach(c => c.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('tab-' + btn.dataset.tab)?.classList.add('active');
  });
});
</script>
