---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Los Cabos Mexican Grill — Sealy, TX | Authentic Tex-Mex" description="Sizzling fajitas, hand-crafted margaritas, and scratch-made Tex-Mex in Sealy, TX.">

<section class="hero">
  <video class="hero-bg" autoplay muted loop playsinline poster="/images/hero-poster.jpg">
    <source src="/video/hero.mp4" type="video/mp4" />
  </video>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <div class="hero-left">
      <h1 class="hero-headline">FAJITA NIGHT<br><em>IS</em>HERE.</h1>
      <div class="hero-ctas">
        <a href="https://online.skytab.com/75fd37a0da5766d1bf27a245fba50884" target="_blank" rel="noopener" class="btn-primary">Order Online</a>
        <a href="#menu" class="btn-outline">View Menu</a>
        <a href="tel:+15126076232" class="btn-ghost">Call Now</a>
      </div>
      <div class="hero-proof">
        <div class="proof-item"><div class="proof-num">4.8</div><div class="proof-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div><div class="proof-label">Google Rating</div></div>
        <div class="proof-sep"></div>
        <div class="proof-item"><div class="proof-num">1,725+</div><div class="proof-label">Happy Locals</div></div>
        <div class="proof-sep"></div>
        <div class="proof-item"><div class="proof-num">15<span class="proof-unit"> min</span></div><div class="proof-label">Avg. Pickup</div></div>
      </div>
    </div>
    <div class="hero-info-card">
      <div class="info-card-row"><span class="info-label">Hours</span><span class="info-value">Sun-Wed 11AM-9PM<br>Thu-Sat 11AM-10PM</span></div>
      <div class="info-divider"></div>
      <div class="info-card-row"><span class="info-label">Address</span><span class="info-value">6027 FM 3538 Rd<br>Sealy, TX 77474</span></div>
      <div class="info-divider"></div>
      <div class="info-card-row"><span class="info-label">Phone</span><span class="info-value"><a href="tel:+15126076232">(512) 607-6232</a></span></div>
      <div class="info-divider"></div>
      <a href="https://online.skytab.com/75fd37a0da5766d1bf27a245fba50884" target="_blank" rel="noopener" class="btn-primary" style="text-align:center;">ORDER NOW &rarr;</a>
    </div>
  </div>
</section>

<section class="trust-bar">
  <div class="trust-item"><span>&#10003;</span><span>Made From Scratch</span></div>
  <div class="trust-sep"></div>
  <div class="trust-item"><span>&#10003;</span><span>Margaritas Made Right</span></div>
  <div class="trust-sep"></div>
  <div class="trust-item"><span>&#10003;</span><span>15-Minute Pickup</span></div>
  <div class="trust-sep"></div>
  <div class="trust-item"><span>&#10003;</span><span>Dine In or Carry Out</span></div>
</section>

<section class="atmosphere">
  <div class="atm-img"><img src="/images/server.jpg" alt="Los Cabos hospitality" loading="lazy" /></div>
  <div class="atm-text">
    <div class="section-eyebrow">Our Story</div>
    <h2 class="section-heading">REAL FOOD.<br>REAL HOSPITALITY.</h2>
    <p>Los Cabos has been feeding Austin County for years. From sizzling fajita platters to hand-crafted margaritas — every order comes out of a scratch kitchen that does not cut corners.</p>
    <p style="margin-top:16px;font-style:italic;color:var(--text-muted);">Serving Sealy, Austin County &amp; beyond.</p>
  </div>
</section>

<section class="menu-section" id="menu">
  <div class="menu-header">
    <div class="section-eyebrow">What We Are Known For</div>
    <h2 class="section-heading">THE MENU</h2>
  </div>
  <div class="menu-tabs">
    <button class="tab-btn active" data-tab="apps">Appetizers</button>
    <button class="tab-btn" data-tab="fajitas">Fajitas</button>
    <button class="tab-btn" data-tab="enchiladas">Enchiladas</button>
    <button class="tab-btn" data-tab="drinks">Drinks</button>
  </div>

  <div class="accordion-list tab-content active" id="tab-apps">
    <div class="acc-item"><button class="acc-trigger">Chile Con Queso <span class="acc-price">Sm $7.85 / Lg $9.25</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>Classic queso dip served with chips.</p></div></div>
    <div class="acc-item"><button class="acc-trigger">Tex-Mex Queso <span class="acc-price">Sm $8.35 / Lg $10.75</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>Chile con queso and ground beef, topped with pico de gallo and guacamole.</p></div></div>
    <div class="acc-item"><button class="acc-trigger">Seafood Queso <span class="acc-price">$11.95</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>Shrimp, crawfish and mushrooms sauteed in cream sauce, baked with Monterey Jack and Romano cheese.</p></div></div>
    <div class="acc-item"><button class="acc-trigger">Queso Flameado <span class="acc-price">$9.55</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>Casserole of melted Monterey Jack cheese with beef, chicken or Mexican sausage.</p></div></div>
    <div class="acc-item"><button class="acc-trigger">Mixed Queso Flameado <span class="acc-price">$13.95</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>Melted Monterey Jack cheese with chicken and beef fajitas sauteed with mushrooms, green and red bell peppers and poblano pepper.</p></div></div>
    <div class="acc-item"><button class="acc-trigger">Guacamole Mexicano <span class="acc-price">$10.95</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>Made to order with roasted jalapenos, tomatoes, onions, cilantro and lime juice.</p></div></div>
    <div class="acc-item"><button class="acc-trigger">Guacamole Salad <span class="acc-price">$8.00</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>Fresh guacamole salad.</p></div></div>
    <div class="acc-item"><button class="acc-trigger">Supreme Nachos <span class="acc-price">Sm $9.55 / Lg $13.15</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>Cheddar cheese, ground beef, beans, lettuce, tomatoes, sour cream, guacamole and sliced jalapenos.</p></div></div>
    <div class="acc-item"><button class="acc-trigger">El Campo Nachos <span class="acc-price">Sm $10.75 / Lg $13.95</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>Topped with chicken or beef fajitas, Monterey Jack cheese, beans, guacamole, lettuce and tomatoes. Shrimp: Sm $11.95 / Lg $15.95.</p></div></div>
    <div class="acc-item"><button class="acc-trigger">Jalapenos del Monte <span class="acc-price">$10.75</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>Four jumbo jalapenos stuffed with whole shrimp and Monterey Jack cheese, fried golden brown.</p></div></div>
    <div class="acc-item"><button class="acc-trigger">Botana Mix <span class="acc-price">$15.99</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>Cheese quesadilla, nachos, mini chalupas, stuffed shrimp jalapeno, chicken fried burrito, guacamole and sour cream.</p></div></div>
    <div class="acc-item"><button class="acc-trigger">Wings &amp; Fries <span class="acc-price">$13.95</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>Choice of chipotle, buffalo or BBQ.</p></div></div>
    <div class="acc-item"><button class="acc-trigger">Wagon Cheese Fries <span class="acc-price">$6.50</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>Fried potatoes topped with melted cheddar cheese, Monterey Jack cheese, sour cream, chives and bacon.</p></div></div>
  </div>

  <div class="accordion-list tab-content" id="tab-fajitas">
    <div class="acc-item"><button class="acc-trigger">Fajitas al Carbon <span class="acc-price">Beef Sm $16.99 / Med $19.95</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>Beef or chicken. Served with guacamole, pico, rice, charro or black beans, and fresh homemade tortillas. Chicken: Sm $15.99 / Med $18.50.</p></div></div>
    <div class="acc-item"><button class="acc-trigger">Fajitas Mexicanas <span class="acc-price">Beef Sm $17.95 / Med $19.50</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>Sizzling fajitas topped with marinated sauce of onions, tomatoes, jalapenos, cilantro and mushrooms. Chicken: Sm $16.95 / Med $18.99.</p></div></div>
    <div class="acc-item"><button class="acc-trigger">Chipotle Fajitas <span class="acc-price">Beef Sm $17.95 / Med $20.75</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>Fajitas tossed in chipotle butter sauce topped with Monterey Jack cheese. Chicken: Sm $16.95 / Med $18.50.</p></div></div>
    <div class="acc-item"><button class="acc-trigger">Fajitas Diablas <span class="acc-price">Beef Sm $17.99 / Med $20.75</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>Fajitas with diablo sauce made with tomatoes, onions, jalapenos, and buttered wine sauce. Chicken: Sm $16.50 / Med $19.50.</p></div></div>
    <div class="acc-item"><button class="acc-trigger">Fajitas Poblanas <span class="acc-price">Beef Sm $17.50 / Med $20.75</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>Fajitas with poblano peppers, onions, mushrooms, cilantro, heavy cream and parmesan cheese. Chicken: Sm $16.50 / Med $19.50.</p></div></div>
    <div class="acc-item"><button class="acc-trigger">Fajitas Rellenas <span class="acc-price">Sm $17.99 / Med $20.99</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>Beef and chicken fajitas topped with shrimp, mushrooms, pico and buttered wine sauce. For Two: $39.00.</p></div></div>
    <div class="acc-item"><button class="acc-trigger">Trio Fajitas <span class="acc-price">Sm $20.99 / Med $23.95</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>Beef, chicken, and shrimp with Veracruz sauce of onions, tomato, poblano peppers, bell peppers and jalapenos. For Two: $42.95.</p></div></div>
    <div class="acc-item"><button class="acc-trigger">Parilladas (For 2-3) <span class="acc-price">$54.00</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>Choice of 4 meats: beef or chicken fajitas, quail, carnitas, BBQ ribs, shrimp or jalapeno sausage. With guacamole, pico, rice, beans and tortillas.</p></div></div>
  </div>

  <div class="accordion-list tab-content" id="tab-enchiladas">
    <div class="acc-item"><button class="acc-trigger">Enchiladas al Carbon <span class="acc-price">$18.35</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>Two enchiladas with charbroiled beef or chicken in corn tortillas, topped with chili gravy and melted cheese. Served with guacamole and pico.</p></div></div>
    <div class="acc-item"><button class="acc-trigger">Enchiladas Poblanas <span class="acc-price">$18.99</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>Two enchiladas with charbroiled beef or chicken topped with poblano peppers, onions, mushrooms, cilantro, heavy cream and parmesan cheese.</p></div></div>
    <div class="acc-item"><button class="acc-trigger">Chipotle Enchiladas <span class="acc-price">$17.99</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>Two enchiladas with charbroiled chicken or beef, topped with chipotle sauce and Monterey Jack cheese.</p></div></div>
    <div class="acc-item"><button class="acc-trigger">Seafood Enchilada <span class="acc-price">$18.99</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>Two flour tortillas filled with shrimp and crab meat, topped with green sauce, Monterey Jack cheese, sour cream and avocado slices.</p></div></div>
    <div class="acc-item"><button class="acc-trigger">Cabos Enchiladas <span class="acc-price">$18.35</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>Two enchiladas filled with crab meat, topped with creamy seafood sauce of sauteed shrimp, crawfish, mushrooms and Monterey Jack cheese.</p></div></div>
    <div class="acc-item"><button class="acc-trigger">Nancy's Enchiladas <span class="acc-price">$17.99</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>Two flour tortillas filled with chicken, topped with sour cream sauce, parmesan cheese and Monterey Jack cheese.</p></div></div>
    <div class="acc-item"><button class="acc-trigger">Ranchero Enchiladas <span class="acc-price">$17.95</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>Two flour tortillas filled with shrimp and crab meat, topped with chili con queso and Monterey Jack cheese. Served with sour cream and avocado slices.</p></div></div>
    <div class="acc-item"><button class="acc-trigger">Spinach Enchiladas <span class="acc-price">$15.50</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>Two enchiladas filled with spinach, artichokes, mushrooms, onions and Monterey Jack cheese, topped with poblano cream sauce.</p></div></div>
    <div class="acc-item"><button class="acc-trigger">Carnitas Enchiladas <span class="acc-price">$16.95</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>Two carnitas enchiladas topped with cilantro sauce, Jack cheese and avocado slices.</p></div></div>
    <div class="acc-item"><button class="acc-trigger">Enchiladas Verdes <span class="acc-price">$13.55</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>Two chicken enchiladas topped with cilantro sauce. Served with sour cream and guacamole on the side.</p></div></div>
    <div class="acc-item"><button class="acc-trigger">Enchiladas del Mar <span class="acc-price">$18.35</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>Two flour tortillas filled with shrimp and cheese, topped with chile con queso sauce. Served with guacamole and pico.</p></div></div>
    <div class="acc-item"><button class="acc-trigger">Beef or Cheese Enchiladas <span class="acc-price">$12.95</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>Two enchiladas topped with chili gravy and cheese.</p></div></div>
  </div>

  <div class="accordion-list tab-content" id="tab-drinks">
    <div class="acc-item"><button class="acc-trigger">The Original Margarita <span class="acc-price">Reg $8.25 / Jumbo $12.95</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>House tequila plus triple sec. Frozen or on the rocks.</p></div></div>
    <div class="acc-item"><button class="acc-trigger">Flavored Margaritas <span class="acc-price">Reg $9.25 / Jumbo $13.95</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>Strawberry, mango, peach, raspberry, jalapeno cucumber, pineapple, watermelon or prickly pear. Frozen or on the rocks.</p></div></div>
    <div class="acc-item"><button class="acc-trigger">Skinny Margarita <span class="acc-price">Reg $13.95 / Jumbo $16.95</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>Patron Silver tequila, fresh lime juice and agave nectar.</p></div></div>
    <div class="acc-item"><button class="acc-trigger">Platinum Margarita <span class="acc-price">Reg $13.95 / Jumbo $16.95</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>Patron Silver tequila and Cointreau. Frozen or on the rocks.</p></div></div>
    <div class="acc-item"><button class="acc-trigger">Grand Gold Margarita <span class="acc-price">Reg $12.95 / Jumbo $15.95</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>Jose Cuervo Gold and Grand Marnier. Frozen or on the rocks.</p></div></div>
    <div class="acc-item"><button class="acc-trigger">Sangria Margarita <span class="acc-price">Reg $10.75 / Jumbo $13.95</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>Cabos margarita mix and Spanish sangria wine. Frozen or on the rocks.</p></div></div>
    <div class="acc-item"><button class="acc-trigger">Italian Margarita <span class="acc-price">Reg $9.25 / Jumbo $13.95</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>Cabos margarita mix topped with Amaretto liqueur. Frozen or on the rocks.</p></div></div>
    <div class="acc-item"><button class="acc-trigger">Ranch Water <span class="acc-price">$12.95</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>Patron Silver tequila with fresh lime and Topo Chico club soda.</p></div></div>
    <div class="acc-item"><button class="acc-trigger">Beer Rita <span class="acc-price">$17.75</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>Jumbo Cabos frozen margarita with your favorite beer.</p></div></div>
    <div class="acc-item"><button class="acc-trigger">Michelada <span class="acc-price">$6.95</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>Beer, clamato, lime, hot sauce, tajin rim.</p></div></div>
    <div class="acc-item"><button class="acc-trigger">Margarita by the Jug <span class="acc-price">Half Gal $35 / Gallon $60</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>Take it to go. Half gallon or gallon available. Only available to go.</p></div></div>
    <div class="acc-item"><button class="acc-trigger">Bottled Beer <span class="acc-price">From $4.75</span><span class="acc-arrow">&#9660;</span></button><div class="acc-body"><p>Budweiser, Bud Light, Coors Light, Michelob Ultra, Miller Lite, Shiner, Corona, Dos XX, Modelo, Tecate, Pacifico.</p></div></div>
  </div>

  <div style="text-align:center;margin-top:48px;"><a href="https://online.skytab.com/75fd37a0da5766d1bf27a245fba50884" target="_blank" rel="noopener" class="btn-primary">Order Now &rarr;</a></div>
</section>

