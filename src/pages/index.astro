<script>
let currentReview = 0;
const totalReviews = 3;
let autoTimer;
function goToReview(n) {
  currentReview = n;
  const carousel = document.getElementById('reviewsCarousel');
  if (carousel && window.innerWidth < 900) {
    carousel.style.transform = 'translateX(-' + (n * 100) + '%)';
    document.querySelectorAll('.reviews-dot').forEach((d, i) => d.classList.toggle('active', i === n));
  }
  clearInterval(autoTimer);
  startAuto();
}
function startAuto() {
  autoTimer = setInterval(() => {
    if (window.innerWidth < 900) { currentReview = (currentReview + 1) % totalReviews; goToReview(currentReview); }
  }, 4000);
}
document.addEventListener('DOMContentLoaded', function () {
  startAuto();
  const carousel = document.getElementById('reviewsCarousel');
  if (carousel) {
    let startX = 0;
    carousel.addEventListener('touchstart', e => { startX = e.touches[0].clientX; clearInterval(autoTimer); });
    carousel.addEventListener('touchend', e => {
      const diff = startX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 50) {
        currentReview = diff > 0 ? Math.min(currentReview + 1, totalReviews - 1) : Math.max(currentReview - 1, 0);
        goToReview(currentReview);
      }
    });
  }
});
</script>

<script>
document.addEventListener('DOMContentLoaded', function () {
  document.querySelectorAll('a[href*="skytab"]').forEach(function (link) {
    link.addEventListener('click', function () {
      const body = link.closest('.featured-body');
      const label = body ? body.querySelector('.featured-name')?.textContent?.trim() || 'Order Now' : link.textContent?.trim() + ' (Hero/Nav)';
      if (typeof gtag !== 'undefined') gtag('event', 'order_now_click', { event_category: 'Outbound', event_label: label, transport_type: 'beacon', value: 1 });
    });
  });
});
</script>

