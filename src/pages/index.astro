<style>
.hero{position:relative;min-height:100vh;display:flex;align-items:flex-end;padding-top:calc(var(--nav-h) + 38px);overflow:hidden}
.hero-bg{position:absolute;inset:0;z-index:0;width:100%;height:100%;object-fit:cover;object-position:center 40%}
.hero-overlay{position:absolute;inset:0;z-index:1;background:linear-gradient(to bottom,rgba(14,11,8,.15) 0%,rgba(14,11,8,0) 20%,rgba(14,11,8,.5) 65%,rgba(14,11,8,.97) 100%),linear-gradient(to right,rgba(14,11,8,.4) 0%,rgba(14,11,8,0) 60%)}
.hero-content{position:relative;z-index:2;width:100%;padding:0 72px 72px;display:grid;grid-template-columns:1fr auto;align-items:end;gap:40px}
.hero-left{max-width:700px}
.hero-headline{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:clamp(100px,14vw,180px);line-height:.88;text-transform:uppercase;color:white;letter-spacing:-.01em;margin-bottom:36px}
.hero-headline em{color:var(--orange);font-style:italic;display:block}
.hero-ctas{display:flex;gap:12px;margin-bottom:36px;flex-wrap:wrap}
.hero-proof{display:flex;align-items:center;gap:24px}
.proof-item{display:flex;flex-direction:column;gap:2px}
.proof-sep{width:1px;height:36px;background:rgba(255,255,255,.2);flex-shrink:0}
.proof-num{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:24px;color:white;line-height:1}
.proof-unit{font-size:15px;color:rgba(255,255,255,.5);font-weight:600}
.proof-label{font-size:10px;color:rgba(255,255,255,.45);text-transform:uppercase;letter-spacing:.1em;font-weight:600;white-space:nowrap}
.proof-stars{color:var(--gold);font-size:11px;letter-spacing:1px}
.hero-info-card{background:rgba(20,16,12,.88);border:1px solid rgba(244,98,31,.2);border-radius:10px;padding:28px 24px;min-width:230px;backdrop-filter:blur(16px);display:flex;flex-direction:column;gap:18px}
.info-card-row{display:flex;flex-direction:column;gap:3px}
.info-label{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:rgba(255,255,255,.38)}
.info-value{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:15px;color:white;line-height:1.35}
.info-value a{color:var(--orange);text-decoration:none}
.info-divider{height:1px;background:rgba(255,255,255,.07)}
.trust-bar{background:var(--nav-bg);padding:28px 72px;display:flex;align-items:center;justify-content:center;gap:0;flex-wrap:wrap}
.trust-item{display:flex;align-items:center;gap:10px;padding:8px 40px;color:rgba(255,255,255,.75);font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:14px;letter-spacing:.08em;text-transform:uppercase}
.trust-sep{width:1px;height:28px;background:rgba(255,255,255,.12)}
.atmosphere{display:grid;grid-template-columns:1fr 1fr;min-height:500px}
.atm-img img{width:100%;height:100%;object-fit:cover}
.atm-text{background:var(--bg2);padding:72px 64px;display:flex;flex-direction:column;justify-content:center}
.atm-text p{color:var(--text-body);max-width:460px}
.menu-section{padding:80px 72px;background:var(--bg)}
.menu-header{margin-bottom:40px}
.menu-tabs{display:flex;gap:4px;margin-bottom:40px;border-bottom:2px solid var(--border)}
.tab-btn{font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:14px;letter-spacing:.12em;text-transform:uppercase;padding:10px 24px;background:none;border:none;cursor:pointer;color:var(--text-muted);border-bottom:2px solid transparent;margin-bottom:-2px;transition:color .2s,border-color .2s}
.tab-btn.active,.tab-btn:hover{color:var(--orange);border-bottom-color:var(--orange)}
.tab-content{display:none}
.tab-content.active{display:block}
.accordion-list{border-top:1px solid var(--border)}
.acc-item{border-bottom:1px solid var(--border)}
.acc-trigger{width:100%;display:flex;align-items:center;gap:12px;padding:18px 4px;background:none;border:none;cursor:pointer;text-align:left;font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:17px;color:var(--text-head);letter-spacing:.02em;transition:color .2s}
.acc-trigger:hover{color:var(--orange)}
.acc-trigger.open{color:var(--orange)}
.acc-price{margin-left:auto;font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:15px;color:var(--gold);white-space:nowrap;flex-shrink:0}
.acc-arrow{font-size:11px;color:var(--text-muted);margin-left:8px;transition:transform .25s;flex-shrink:0}
.acc-trigger.open .acc-arrow{transform:rotate(180deg)}
.acc-body{display:none;padding:0 4px 18px;color:var(--text-body);font-size:14px;line-height:1.6;max-width:680px}
.acc-body.open{display:block}
.catering-section{display:grid;grid-template-columns:1fr 1fr;min-height:560px;background:var(--bg2)}
.catering-img img{width:100%;height:100%;object-fit:cover}
.catering-text{padding:72px 64px;display:flex;flex-direction:column;justify-content:center;gap:24px}
.catering-sub{font-size:18px;color:var(--text-body);line-height:1.6;max-width:460px}
.catering-list{list-style:none;display:flex;flex-direction:column;gap:12px}
.catering-list li{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:16px;color:var(--text-head);padding-left:20px;position:relative}
.catering-list li::before{content:"✓";position:absolute;left:0;color:var(--orange)}
.reviews-section{padding:80px 72px;background:var(--nav-bg)}
.reviews-header{margin-bottom:48px}
.reviews-agg{display:flex;align-items:center;gap:16px;margin-top:16px}
.reviews-score{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:56px;color:white;line-height:1}
.reviews-stars{color:var(--gold);font-size:20px;letter-spacing:2px}
.reviews-count{font-size:13px;color:rgba(255,255,255,.45);margin-top:2px}
.reviews-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.review-card{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:8px;padding:28px}
.review-stars{color:var(--gold);font-size:16px;letter-spacing:2px;margin-bottom:12px}
.review-text{color:rgba(255,255,255,.8);font-size:15px;line-height:1.65;margin-bottom:16px;font-style:italic}
.review-name{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:13px;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.4)}
.find-section{display:grid;grid-template-columns:1fr 1fr;min-height:480px}
.find-content{background:var(--bg2);padding:72px 64px;display:flex;flex-direction:column;gap:24px;justify-content:center}
.find-row{display:flex;flex-direction:column;gap:4px}
.find-label{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:10px;letter-spacing:.25em;text-transform:uppercase;color:var(--text-muted)}
.find-value{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:16px;color:var(--text-head);line-height:1.4}
.find-value a{color:var(--orange);text-decoration:none}
.map-embed iframe{width:100%;height:100%;min-height:400px;border:0}
@media(max-width:768px){.hero{height:100svh;max-height:100svh;padding-top:calc(58px + 36px)}.hero-content{grid-template-columns:1fr;padding:0 20px 80px}.hero-info-card{display:none}.hero-headline{font-size:clamp(54px,14.5vw,78px);margin-bottom:24px}.trust-bar{padding:20px;gap:0}.trust-sep{display:none}.trust-item{padding:8px 16px;font-size:12px}.atmosphere{grid-template-columns:1fr}.atm-img{height:300px}.atm-text{padding:48px 24px}.menu-section{padding:60px 20px}.acc-trigger{font-size:15px;padding:16px 4px}.catering-section{grid-template-columns:1fr}.catering-img{height:280px}.catering-text{padding:48px 24px}.reviews-section{padding:60px 20px}.reviews-grid{grid-template-columns:1fr;gap:16px}.find-section{grid-template-columns:1fr}.find-content{padding:48px 24px}.map-embed iframe{min-height:300px}}
</style>
<script>
const tabs=document.querySelectorAll('.tab-btn');
const contents=document.querySelectorAll('.tab-content');
tabs.forEach(btn=>{btn.addEventListener('click',()=>{tabs.forEach(t=>t.classList.remove('active'));contents.forEach(c=>c.classList.remove('active'));btn.classList.add('active');document.getElementById('tab-'+btn.dataset.tab)?.classList.add('active');});});
document.querySelectorAll('.acc-trigger').forEach(btn=>{btn.addEventListener('click',()=>{const body=btn.nextElementSibling;const isOpen=btn.classList.contains('open');btn.classList.toggle('open',!isOpen);body.classList.toggle('open',!isOpen);});});
</script>