---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Los Cabos Mexican Grill | Sealy, TX | Sizzling Fajitas & Margaritas"
  description="Full menu: fajitas, enchiladas, tacos, burritos, seafood, steaks, margaritas and more. Scratch-made Tex-Mex in Sealy, TX. Dine in or order online."
>

<!-- ===== HERO ===== -->
<section class="hero">
  <video autoplay muted loop playsinline class="hero-video" poster="/images/hero-poster.jpg">
    <source src="/video/FajitaSizzle.MOV" type="video/mp4" />
  </video>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <div class="hero-left">
      <h1 class="hero-headline">FAJITA NIGHT<br><em>IS</em> HERE</h1>
      <div class="hero-ctas">
        <a href="https://online.skytab.com/75fd37a0da5766d1bf27a245fba50884/order-settings" target="_blank" rel="noopener" class="btn-primary">Order Online</a>
        <a href="#menu" class="btn-outline">View Menu</a>
        <a href="tel:+15126076232" class="btn-ghost">Call Now</a>
      </div>
      <div class="hero-proof">
        <div class="proof-item">
          <div class="proof-num">4.8</div>
          <div class="proof-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <div class="proof-label">Google Rating</div>
        </div>
        <div class="proof-sep"></div>
        <div class="proof-item">
          <div class="proof-num">1,725+</div>
          <div class="proof-label">Happy Locals</div>
        </div>
        <div class="proof-sep"></div>
        <div class="proof-item">
          <div class="proof-num">15<span class="proof-unit"> min</span></div>
          <div class="proof-label">Avg. Pickup</div>
        </div>
      </div>
    </div>
    <aside class="hero-info-card">
      <div class="info-card-row">
        <span class="info-label">Hours</span>
        <span class="info-value">Sun&ndash;Wed 11AM&ndash;9PM<br>Thu&ndash;Sat 11AM&ndash;10PM</span>
      </div>
      <div class="info-divider"></div>
      <div class="info-card-row">
        <span class="info-label">Address</span>
        <span class="info-value">6027 FM 3538 Rd<br>Sealy, TX 77474</span>
      </div>
      <div class="info-divider"></div>
      <div class="info-card-row">
        <span class="info-label">Phone</span>
        <span class="info-value">
          <a href="tel:+15126076232">(512) 607-6232</a>
          <span class="info-phone-note">(Yes, we&rsquo;re in Sealy, TX)</span>
        </span>
      </div>
      <div class="info-divider"></div>
      <a href="https://online.skytab.com/75fd37a0da5766d1bf27a245fba50884/order-settings" target="_blank" rel="noopener" class="btn-primary" style="display:block;text-align:center;">ORDER NOW &rarr;</a>
    </aside>
  </div>
</section>

<!-- ===== TRUST BAR ===== -->
<section class="trust-bar">
  <div class="trust-item"><span class="trust-check">&#10003;</span><span>Made From Scratch</span></div>
  <div class="trust-sep"></div>
  <div class="trust-item"><span class="trust-check">&#10003;</span><span>Margaritas Made Right</span></div>
  <div class="trust-sep"></div>
  <div class="trust-item"><span class="trust-check">&#10003;</span><span>15-Minute Pickup</span></div>
  <div class="trust-sep"></div>
  <div class="trust-item"><span class="trust-check">&#10003;</span><span>Dine In or Carry Out</span></div>
</section>

<!-- ===== MENU CTA BANNER ===== -->
<section class="menu-cta-section" id="menu">
  <div class="menu-cta-bg">
    <img src="/images/Fajitas4Hero.jpg" alt="Sizzling Fajitas" class="menu-cta-img" loading="lazy" />
    <div class="menu-cta-overlay"></div>
  </div>
  <div class="menu-cta-content">
    <span class="idx-eyebrow">Fresh. Scratch-Made. Every Day.</span>
    <h2 class="menu-cta-heading">EXPLORE THE MENU</h2>
    <p class="menu-cta-sub">From sizzling fajitas to hand-crafted margaritas &mdash; something for everyone at the table.</p>
    <a href="/menu" class="btn-primary" style="display:block;max-width:280px;margin:0 auto;text-align:center;">VIEW FULL MENU &rarr;</a>
  </div>
</section>

<!-- ===== FAMILY PACKS ===== -->
<section class="featured-section">
  <div class="featured-inner">
    <span class="idx-eyebrow">Feed the Whole Crew</span>
    <h2 class="idx-heading">FAMILY PACKS<br>AVAILABLE!</h2>
    <p class="fp-intro">Bring Los Cabos home. Our family packs are packed with flavor, ready to feed 4&ndash;6 people, and perfect for any night you don&rsquo;t feel like cooking.</p>
    <div class="fp-grid">

      <article class="fp-card">
        <div class="fp-card-header">
          <div class="fp-badge">Pack #1</div>
          <div class="fp-price">$74.95</div>
        </div>
        <div class="fp-card-body">
          <h3 class="fp-name">Family Pack #1</h3>
          <p class="fp-desc">The perfect spread for your family dinner. Includes a generous portion of our tender beef and chicken fajitas, served with Mexican rice and your choice of refried, charro, or black beans. We include all the fixings: our homemade guacamole, fresh pico de gallo, sour cream, and your choice of tortillas. Finished with crispy chips, signature red and green salsas, and a bowl of our creamy chile con queso.</p>
          <div class="fp-serves">&#127858; Serves 4&ndash;6</div>
          <div class="fp-togo">&#128718; To-Go Only</div>
          <a href="tel:+15126076232" class="fp-order">Call to Order &rarr;</a>
        </div>
      </article>

      <article class="fp-card">
        <div class="fp-card-header">
          <div class="fp-badge">Pack #2</div>
          <div class="fp-price">$92.95</div>
        </div>
        <div class="fp-card-body">
          <h3 class="fp-name">Family Pack #2</h3>
          <p class="fp-desc">When you want it all! This premium feast features our sizzlin&rsquo; beef and chicken fajitas, savory ribs, and our signature shrimp brochette. Accompanied by Mexican rice and your choice of beans. Complete with homemade guacamole, pico de gallo, sour cream, and fresh tortillas. Plus plenty of chips, our signature red and green salsas, and a large helping of chile con queso for the ultimate Los Cabos experience.</p>
          <div class="fp-serves">&#127858; Serves 4&ndash;6</div>
          <div class="fp-togo">&#128718; To-Go Only</div>
          <a href="tel:+15126076232" class="fp-order">Call to Order &rarr;</a>
        </div>
      </article>

      <article class="fp-card">
        <div class="fp-card-header">
          <div class="fp-badge">Pack #3</div>
          <div class="fp-price">$53.95</div>
        </div>
        <div class="fp-card-body">
          <h3 class="fp-name">Family Pack #3</h3>
          <p class="fp-desc">Enjoy 12 of our hand-rolled enchiladas with your choice of savory ground beef, shredded chicken, or melty cheese &mdash; each topped with our rich chili gravy and extra melted cheese. Comes ready to serve with a quart of Mexican rice, a quart of your favorite beans, plenty of chips, our signature red salsa, and a large homemade chile con queso to round out the meal.</p>
          <div class="fp-serves">&#127858; Serves 4&ndash;6</div>
          <div class="fp-togo">&#128718; To-Go Only</div>
          <a href="tel:+15126076232" class="fp-order">Call to Order &rarr;</a>
        </div>
      </article>

    </div>
    <div class="featured-cta">
      <p class="fp-menu-sub">Hungry for more? Explore our full menu of fajitas, enchiladas, seafood, steaks, and hand-crafted margaritas.</p>
      <a href="/menu" class="btn-outline-dark">See Everything on the Menu &rarr;</a>
    </div>
  </div>
</section>
<!-- ===== CATERING ===== -->
<section class="cat-section" id="catering">
  <div class="cat-grid">
    <div class="cat-left">
      <span class="idx-eyebrow">Events &amp; Catering</span>
      <h2 class="cat-heading">WE COME<br>TO YOU.</h2>
      <p class="cat-desc">Los Cabos brings the full experience to your event. Sizzling fajitas, fresh sides, and everything your guests need for a meal they won&rsquo;t forget.</p>
      <div class="cat-steps">
        <div class="cat-step"><div class="cat-step-num">01</div><div><div class="cat-step-title">Tell us about your event</div><div class="cat-step-desc">Group size, date, location, and any special requests.</div></div></div>
        <div class="cat-step"><div class="cat-step-num">02</div><div><div class="cat-step-title">We build your menu</div><div class="cat-step-desc">Fajitas, enchiladas, sides &mdash; customized for your crowd.</div></div></div>
        <div class="cat-step"><div class="cat-step-num">03</div><div><div class="cat-step-title">We show up &amp; serve</div><div class="cat-step-desc">Hot, fresh, and on time. You enjoy the party.</div></div></div>
      </div>
    </div>
    <div class="cat-right">
      <img src="/images/logo.png" alt="Los Cabos Mexican Grill" class="cat-logo" loading="lazy" />
      <div class="cat-book-title">Ready to Book?</div>
      <p class="cat-book-sub">Minimum 25 guests. Call us during business hours to get started.</p>
      <a href="tel:+15126076232" class="cat-phone">(512) 607-6232</a>
      <div class="cat-hours">Sun&ndash;Wed 11AM&ndash;9PM<br>Thu&ndash;Sat 11AM&ndash;10PM</div>
      <a href="/catering" class="btn-primary" style="display:block;width:100%;max-width:280px;text-align:center;">CATERING REQUEST</a>
    </div>
  </div>
</section>

<!-- ===== REVIEWS ===== -->
<section class="reviews-section">
  <div class="reviews-inner">
    <span class="idx-eyebrow">What People Are Saying</span>
    <h2 class="idx-heading reviews-heading">REAL REVIEWS.<br>REAL PEOPLE.</h2>
    <div class="reviews-score-row">
      <div class="reviews-score">4.8</div>
      <div>
        <div class="reviews-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        <div class="reviews-count">Based on Google Reviews</div>
      </div>
    </div>
    <div class="reviews-carousel-wrap">
      <div class="reviews-carousel" id="reviewsCarousel">
        <div class="review-card">
          <div class="review-stars-row">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="review-text">&ldquo;Food was out quick and it was phenomenal. Will definitely be going back.&rdquo;</p>
          <div class="review-name">Brandin S. &mdash; <span class="review-time">19 hours ago</span></div>
        </div>
        <div class="review-card">
          <div class="review-stars-row">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="review-text">&ldquo;Best food, service, and price for a meal that I&rsquo;ve had in years. Angel was an awesome waiter and the food is really good. Surprised by how much food was served. Couldn&rsquo;t finish half.&rdquo;</p>
          <div class="review-name">Larsen Trucking &mdash; <span class="review-time">3 weeks ago</span></div>
        </div>
        <div class="review-card">
          <div class="review-stars-row">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="review-text">&ldquo;The best of the best! Best service ever and the food is always on point. The staff here are amazing beyond words! Definitely one of my favorite places to visit.&rdquo;</p>
          <div class="review-name">Lashay C. &mdash; <span class="review-time">3 weeks ago &middot; Local Guide</span></div>
        </div>
      </div>
      <div class="reviews-dots">
        <button class="reviews-dot active" onclick="goToReview(0)" aria-label="Review 1"></button>
        <button class="reviews-dot" onclick="goToReview(1)" aria-label="Review 2"></button>
        <button class="reviews-dot" onclick="goToReview(2)" aria-label="Review 3"></button>
      </div>
    </div>
    <div class="reviews-cta">
      <a href="https://www.google.com/maps/place/Los+Cabos+Mexican+Grill,+Sealy" target="_blank" rel="noopener" class="btn-outline-white">Leave Us a Review on Google</a>
    </div>
  </div>
</section>

<!-- ===== FIND US ===== -->
<section class="find-section" id="find-us">
  <div class="find-content">
    <div>
      <span class="idx-eyebrow">Come In</span>
      <h2 class="idx-heading">FIND US</h2>
    </div>
    <div class="find-row">
      <span class="find-label">Address</span>
      <span class="find-value">6027 FM 3538 Rd<br>Sealy, TX 77474</span>
    </div>
    <div class="find-row">
      <span class="find-label">Phone</span>
      <span class="find-value">
        <a href="tel:+15126076232">(512) 607-6232</a>
        <span class="info-phone-note">(Yes, we&rsquo;re in Sealy, TX)</span>
      </span>
    </div>
    <div class="find-row">
      <span class="find-label">Hours</span>
      <span class="find-value">Sun&ndash;Wed: 11AM &ndash; 9PM<br>Thu&ndash;Sat: 11AM &ndash; 10PM</span>
    </div>
    <a href="https://maps.google.com/?q=6027+FM+3538+Rd+Sealy+TX+77474" target="_blank" rel="noopener" class="btn-primary">Get Directions</a>
  </div>
  <div class="map-embed">
    <iframe title="Los Cabos Sealy TX" src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3467.2!2d-96.1566!3d29.7810!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!5e0!3m2!1sen!2sus!4v1" width="100%" height="100%" style="border:0;display:block;min-height:300px;" allowfullscreen loading="lazy"></iframe>
  </div>
</section>

<style is:global>
/* ================================================================
   INDEX.ASTRO 脙聝脗聝脙聜脗聝脙聝脗聜脙聜脗聝脙聝脗聝脙聜脗聜脙聝脗聜脙聜脗垄脙聝脗聝脙聜脗聝脙聝脗聜脙聜脗聜脙聝脗聝脙聜脗聜脙聝脗聜脙聜脗聙脙聝脗聝脙聜脗聝脙聝脗聜脙聜脗聜脙聝脗聝脙聜脗聜脙聝脗聜脙聜脗聰 MOBILE-FIRST
   Base = 320px+  |  sm = 600px+  |  lg = 900px+  |  xl = 1200px+
   Chrome mobile:  announce 32px + nav 58px = 90px total
   Chrome desktop: announce 36px + nav 78px = 114px total
   Mob-bar: 52px fixed bottom (mobile only)
   All selectors prefixed with idx- or use unique names
================================================================ */

/* ----- INDEX-SPECIFIC EYEBROW + HEADING ----- */
.idx-eyebrow {
  display: block;
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 800;
  font-size: 11px;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: #F4621F;
  margin-bottom: 8px;
}
.idx-heading {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 900;
  font-size: clamp(32px, 9vw, 54px);
  line-height: 0.95;
  text-transform: uppercase;
  color: #1C1410;
  margin-bottom: 20px;
}

/* ----- DARK OUTLINE BUTTON (index only) ----- */
.btn-outline-dark {
  display: inline-block;
  background: transparent;
  color: #1A1410;
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 800;
  font-size: 14px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  padding: 13px 32px;
  border-radius: 4px;
  text-decoration: none;
  border: 2px solid #1A1410;
  transition: background 0.2s, color 0.2s;
}
.btn-outline-dark:hover { background: #1A1410; color: #fff; }

.btn-outline-white {
  display: inline-block;
  background: transparent;
  color: #fff;
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 800;
  font-size: 13px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  padding: 12px 28px;
  border-radius: 4px;
  text-decoration: none;
  border: 2px solid rgba(255,255,255,0.35);
  transition: border-color 0.2s;
}
.btn-outline-white:hover { border-color: rgba(255,255,255,0.8); }

/* ----- HERO ----- */
.hero {
  position: relative;
  min-height: 88vh;
  display: flex;
  align-items: flex-end;
  overflow: hidden;
  padding-top: 90px; /* mobile chrome: 32px announce + 58px nav */
}
.hero-video {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center center;
  z-index: 1;
}
.hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(15,10,6,0.82) 0%, rgba(15,10,6,0.45) 50%, rgba(15,10,6,0.20) 100%);
  z-index: 2;
}
.hero-content {
  position: relative;
  z-index: 3;
  width: 100%;
  padding: 0 20px 60px; /* 60px bottom: 40px design + 20px mob-bar buffer */
  display: flex;
  flex-direction: column;
  gap: 24px;
}
.hero-left { display: flex; flex-direction: column; gap: 20px; }
.hero-headline {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 900;
  font-size: clamp(52px, 16vw, 80px);
  line-height: 0.9;
  text-transform: uppercase;
  color: #fff;
  letter-spacing: -0.01em;
}
.hero-headline em { color: #F4621F; font-style: italic; display: block; }
.hero-ctas { display: flex; flex-direction: column; gap: 10px; }
.hero-ctas .btn-primary,
.hero-ctas .btn-outline,
.hero-ctas .btn-ghost {
  width: 100%;
  text-align: center;
  display: block;
}
.hero-proof {
  display: flex;
  align-items: center;
  gap: 16px;
  flex-wrap: wrap;
}
.proof-item { display: flex; flex-direction: column; gap: 2px; }
.proof-sep { width: 1px; height: 32px; background: rgba(255,255,255,0.2); flex-shrink: 0; }
.proof-num { font-family: 'Barlow Condensed', sans-serif; font-weight: 900; font-size: 22px; color: #fff; line-height: 1; }
.proof-unit { font-size: 13px; color: rgba(255,255,255,0.5); }
.proof-label { font-size: 10px; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 0.1em; font-weight: 600; white-space: nowrap; }
.proof-stars { color: #f5c518; font-size: 11px; letter-spacing: 1px; }
.hero-info-card { display: none; } /* desktop only */

/* ----- TRUST BAR ----- */
.trust-bar {
  background: #1A1410;
  padding: 14px 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 0;
}
.trust-item {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 6px 12px;
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 700;
  font-size: 12px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #fff;
}
.trust-check { color: #F4621F; }
.trust-sep { width: 1px; height: 20px; background: rgba(255,255,255,0.15); }

/* ----- MENU CTA ----- */
.menu-cta-section {
  position: relative;
  min-height: 320px;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.menu-cta-bg { position: absolute; inset: 0; }
.menu-cta-img { width: 100%; height: 100%; object-fit: cover; }
.menu-cta-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(26,20,16,0.88) 0%, rgba(26,20,16,0.65) 100%);
}
.menu-cta-content {
  position: relative;
  z-index: 2;
  text-align: center;
  padding: 48px 24px;
  max-width: 600px;
  width: 100%;
}
.menu-cta-heading {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 900;
  font-size: clamp(40px, 12vw, 80px);
  color: #fff;
  line-height: 1;
  text-transform: uppercase;
  margin-bottom: 16px;
}
.menu-cta-sub {
  font-family: 'Barlow', sans-serif;
  font-size: 15px;
  color: rgba(255,255,255,0.75);
  margin-bottom: 28px;
  line-height: 1.5;
}


/* ----- FAMILY PACKS ----- */
.fp-intro {
  font-family: 'Barlow', sans-serif;
  font-size: 16px;
  color: #4A3728;
  line-height: 1.6;
  max-width: 680px;
  margin-bottom: 36px;
}
.fp-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 20px;
  margin-bottom: 48px;
}
.fp-card {
  background: #fff;
  border-radius: 14px;
  overflow: hidden;
  box-shadow: 0 2px 20px rgba(0,0,0,0.09);
  display: flex;
  flex-direction: column;
  transition: transform 0.2s, box-shadow 0.2s;
}
.fp-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 10px 36px rgba(0,0,0,0.13);
}
.fp-card-header {
  background: #1A1410;
  padding: 20px 24px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.fp-badge {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 800;
  font-size: 12px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.5);
  background: rgba(255,255,255,0.08);
  padding: 4px 12px;
  border-radius: 20px;
}
.fp-price {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 900;
  font-size: 30px;
  color: #F4621F;
  line-height: 1;
}
.fp-card-body {
  padding: 24px;
  display: flex;
  flex-direction: column;
  flex: 1;
}
.fp-name {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 900;
  font-size: 20px;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  color: #1C1410;
  margin-bottom: 10px;
  line-height: 1.1;
}
.fp-desc {
  font-family: 'Barlow', sans-serif;
  font-size: 14px;
  color: #4A3728;
  line-height: 1.65;
  margin-bottom: 16px;
  flex: 1;
}
.fp-serves {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 700;
  font-size: 13px;
  letter-spacing: 0.08em;
  color: #9E8472;
  text-transform: uppercase;
  margin-bottom: 16px;
}
.fp-order {
  display: block;
  text-align: center;
  background: #F4621F;
  color: #fff;
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 800;
  font-size: 13px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  padding: 12px;
  border-radius: 50px;
  text-decoration: none;
  transition: background 0.2s;
  margin-top: auto;
}
.fp-order:hover { background: #D94E0E; }
.fp-togo {
  display: inline-block;
