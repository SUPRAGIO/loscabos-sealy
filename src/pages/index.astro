<script>
let currentReview = 0;
const totalReviews = 3;
let autoTimer;

function goToReview(n) {
  currentReview = n;
  const carousel = document.getElementById('reviewsCarousel');
  if(carousel && window.innerWidth < 769) {
    carousel.style.transform = 'translateX(-' + (n * 100) + '%)';
    document.querySelectorAll('.reviews-dot').forEach((d,i) => {
      d.classList.toggle('active', i === n);
    });
  }
  clearInterval(autoTimer);
  startAuto();
}

function startAuto() {
  autoTimer = setInterval(() => {
    if(window.innerWidth < 769) {
      currentReview = (currentReview + 1) % totalReviews;
      goToReview(currentReview);
    }
  }, 4000);
}

document.addEventListener('DOMContentLoaded', function() {
  startAuto();
  
  // Touch swipe support
  const carousel = document.getElementById('reviewsCarousel');
  if(carousel) {
    let startX = 0;
    carousel.addEventListener('touchstart', e => { startX = e.touches[0].clientX; clearInterval(autoTimer); });
    carousel.addEventListener('touchend', e => {
      const diff = startX - e.changedTouches[0].clientX;
      if(Math.abs(diff) > 50) {
        if(diff > 0) currentReview = Math.min(currentReview + 1, totalReviews - 1);
        else currentReview = Math.max(currentReview - 1, 0);
        goToReview(currentReview);
      }
    });
  }
});
</script>
