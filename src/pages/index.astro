---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Los Cabos Mexican Grill | Sealy, TX | Sizzling Fajitas & Margaritas" description="Full menu: fajitas, enchiladas, tacos, burritos, seafood, steaks, margaritas and more. Scratch-made Tex-Mex in Sealy, TX. Dine in or order online.">

<section class="hero">
  
  <video autoplay muted loop playsinline style="position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;object-position:70% center;z-index:1;"><source src="/video/hero.mp4" type="video/mp4"></video><div class="hero-overlay" style="z-index:2;"></div>
  <div class="hero-content" style="position:relative;z-index:10;">
    <div class="hero-left">
      <h1 class="hero-headline">FAJITA NIGHT<br><em>IS</em> HERE.</h1>
      <div class="hero-ctas">
        <a href="https://online.skytab.com/75fd37a0da5766d1bf27a245fba50884/order-settings" target="_blank" rel="noopener" class="btn-primary">Order Online</a>
        <a href="#menu" class="btn-outline">View Menu</a>
        <a href="tel:+15126076232" class="btn-ghost">Call Now</a>
      </div>
      <div class="hero-proof">
        <div class="proof-item"><div class="proof-num">4.8</div><div class="proof-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div><div class="proof-label">Google Rating</div></div>
        <div class="proof-sep"></div>
        <div class="proof-item"><div class="proof-num">1,725+</div><div class="proof-label">Happy Locals</div></div>
        <div class="proof-sep"></div>
        <div class="proof-item"><div class="proof-num">15<span class="proof-unit"> min</span></div><div class="proof-label">Avg. Pickup</div></div>
      </div>
    </div>
    <div class="hero-info-card">
      <div class="info-card-row"><span class="info-label">Hours</span><span class="info-value">Sun-Wed 11AM-9PM<br>Thu-Sat 11AM-10PM</span></div>
      <div class="info-divider"></div>
      <div class="info-card-row"><span class="info-label">Address</span><span class="info-value">6027 FM 3538 Rd<br>Sealy, TX 77474</span></div>
      <div class="info-divider"></div>
      <div class="info-card-row"><span class="info-label">Phone</span><span class="info-value"><a href="tel:+15126076232">(512) 607-6232</a> <span style="font-family:Barlow,sans-serif;font-size:13px;color:#F4621F;font-style:italic;">(Yes, we're in Sealy, TX)</span></span></div>
      <div class="info-divider"></div>
      <a href="https://online.skytab.com/75fd37a0da5766d1bf27a245fba50884/order-settings" target="_blank" rel="noopener" class="btn-primary" style="text-align:center;">ORDER NOW &rarr;</a>
    </div>
  </div>
</section>

<section class="trust-bar">
  <div class="trust-item"><span>&#10003;</span><span>Made From Scratch</span></div>
  <div class="trust-sep"></div>
  <div class="trust-item"><span>&#10003;</span><span>Margaritas Made Right</span></div>
  <div class="trust-sep"></div>
  <div class="trust-item"><span>&#10003;</span><span>15-Minute Pickup</span></div>
  <div class="trust-sep"></div>
  <div class="trust-item"><span>&#10003;</span><span>Dine In or Carry Out</span></div>
</section>

<section class="menu-section" id="menu">
  <!-- MENU CTA BANNER -->
  <div class="menu-cta-banner">
    <div class="menu-cta-overlay"></div>
    <div class="menu-cta-content">
      <span class="menu-cta-eyebrow">Fresh. Scratch-Made. Every Day.</span>
      <h2 class="menu-cta-heading">EXPLORE THE MENU</h2>
      <p class="menu-cta-sub">From sizzling fajitas to hand-crafted margaritas &mdash; something for everyone at the table.</p>
      <a href="/menu" class="menu-cta-btn">VIEW FULL MENU &rarr;</a>
    </div>
  </div>

  <!-- FEATURED DISHES -->
  <div class="featured-section">
    <div class="section-eyebrow">House Favorites</div>
    <h2 class="section-heading">WHAT WE&rsquo;RE KNOWN FOR</h2>
    <div class="featured-grid">
      <div class="featured-card">
        <div class="featured-img" style="background:url(/images/MenuItems.jpg) center/cover no-repeat;"></div>
        <div class="featured-body">
          <div class="featured-name">Fajitas Mexicanas</div>
          <div class="featured-desc">Sizzling beef or chicken fajitas topped with our signature sauce of onions, tomatoes, jalapenos, cilantro and mushrooms. Served with all the fixings.</div>
          <div class="featured-price">From $16.95</div>
          <a href="https://online.skytab.com/75fd37a0da5766d1bf27a245fba50884/order-settings" target="_blank" rel="noopener" class="featured-order">Order Now</a>
        </div>
      </div>
      <div class="featured-card">
        <div class="featured-img" style="background:url(/images/MenuItems.jpg) center/cover no-repeat;"></div>
        <div class="featured-body">
          <div class="featured-name">Ribeye 12oz</div>
          <div class="featured-desc">Our most flavorful steak. 12oz ribeye served with your choice of side and Caesar or dinner salad. A Los Cabos classic.</div>
          <div class="featured-price">$28.99</div>
          <a href="https://online.skytab.com/75fd37a0da5766d1bf27a245fba50884/order-settings" target="_blank" rel="noopener" class="featured-order">Order Now</a>
        </div>
      </div>
      <div class="featured-card">
        <div class="featured-img" style="background:url(/images/MenuItems.jpg) center/cover no-repeat;"></div>
        <div class="featured-body">
          <div class="featured-name">Cabos Seafood Platter</div>
          <div class="featured-desc">Fried shrimp, fried catfish, stuffed jalapeno shrimp, wrapped shrimp and chicken brochette. Served with French fries. A house favorite.</div>
          <div class="featured-price">$19.50</div>
          <a href="https://online.skytab.com/75fd37a0da5766d1bf27a245fba50884/order-settings" target="_blank" rel="noopener" class="featured-order">Order Now</a>
        </div>
      </div>
    </div>
    <div style="text-align:center;margin-top:48px;">
      <a href="/menu" class="btn-secondary-menu">See Everything on the Menu &rarr;</a>
    </div>
  </div>
</section>

  <section id="catering" style="background:#f5f0ea;width:100%;box-sizing:border-box;">
  <div style="display:grid;grid-template-columns:1fr 1fr;min-height:500px;">

    <!-- LEFT: Story + Steps -->
    <div style="padding:72px 56px;display:flex;flex-direction:column;justify-content:center;gap:28px;">
      <div>
        <div style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:12px;letter-spacing:.2em;text-transform:uppercase;color:#F4621F;margin-bottom:12px;">Events &amp; Catering</div>
        <h2 style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:clamp(40px,5vw,64px);color:#1C1410;line-height:1;text-transform:uppercase;margin-bottom:16px;">WE COME<br>TO YOU.</h2>
        <p style="font-family:'Barlow',sans-serif;font-size:16px;color:#4A3728;line-height:1.7;">Los Cabos brings the full experience to your event. Sizzling fajitas, fresh sides, and everything your guests need for a meal they won&rsquo;t forget.</p>
      </div>
      <div style="display:flex;flex-direction:column;gap:16px;">
        <div style="display:flex;align-items:flex-start;gap:16px;">
          <div style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:32px;color:#F4621F;line-height:1;min-width:36px;">01</div>
          <div>
            <div style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:16px;text-transform:uppercase;letter-spacing:.06em;color:#1C1410;margin-bottom:2px;">Tell us about your event</div>
            <div style="font-family:'Barlow',sans-serif;font-size:14px;color:#4A3728;">Group size, date, location, and any special requests.</div>
          </div>
        </div>
        <div style="display:flex;align-items:flex-start;gap:16px;">
          <div style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:32px;color:#F4621F;line-height:1;min-width:36px;">02</div>
          <div>
            <div style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:16px;text-transform:uppercase;letter-spacing:.06em;color:#1C1410;margin-bottom:2px;">We build your menu</div>
            <div style="font-family:'Barlow',sans-serif;font-size:14px;color:#4A3728;">Fajitas, enchiladas, sides &mdash; customized for your crowd.</div>
          </div>
        </div>
        <div style="display:flex;align-items:flex-start;gap:16px;">
          <div style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:32px;color:#F4621F;line-height:1;min-width:36px;">03</div>
          <div>
            <div style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:16px;text-transform:uppercase;letter-spacing:.06em;color:#1C1410;margin-bottom:2px;">We show up &amp; serve</div>
            <div style="font-family:'Barlow',sans-serif;font-size:14px;color:#4A3728;">Hot, fresh, and on time. You enjoy the party.</div>
          </div>
        </div>
      </div>
    </div>

    <!-- RIGHT: Dark contact card -->
    <div style=";padding:72px 56px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:20px;text-align:center;">
      <img src="/images/logo.png" alt="Los Cabos Mexican Grill" style="height:80px;width:auto;" />
      <div style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:24px;text-transform:uppercase;letter-spacing:.04em;color:white;">Ready to Book?</div>
      <div style="font-family:'Barlow',sans-serif;font-size:14px;color:rgba(255,255,255,0.55);line-height:1.6;max-width:280px;">Minimum 25 guests. Call us during business hours to get started.</div>
      <a href="tel:+15126076232" style="font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:40px;color:#F4621F;text-decoration:none;letter-spacing:.02em;">(512) 607-6232</a>
      <div style="font-family:'Barlow',sans-serif;font-size:12px;color:rgba(255,255,255,0.4);line-height:1.8;">Sun&ndash;Wed 11AM&ndash;9PM<br>Thu&ndash;Sat 11AM&ndash;10PM</div>
      <a href="/catering" style="display:block;width:100%;max-width:280px;background:#F4621F;color:white;font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:13px;letter-spacing:.15em;text-transform:uppercase;padding:14px 24px;border-radius:4px;text-decoration:none;text-align:center;">CATERING REQUEST</a>
    </div>

  </div>
</section>

<section class="reviews-section">
  <div class="reviews-inner">
    <div class="section-eyebrow">What People Are Saying</div>
    <h2 class="section-heading">REAL REVIEWS.<br>REAL PEOPLE.</h2>
    <div class="reviews-score-row">
      <div class="reviews-score">4.8</div>
      <div>
        <div style="color:#F4621F;font-size:22px;letter-spacing:2px;">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        <div class="reviews-count">Based on Google Reviews</div>
      </div>
    </div>
    <div class="reviews-carousel-wrap">
      <div class="reviews-carousel" id="reviewsCarousel">
        <div class="review-card">
          <div style="color:#F4621F;font-size:18px;margin-bottom:12px;">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="review-text">"Food was out quick and it was phenomenal. Will definitely be going back."</p>
          <div class="review-name">Brandin S. &mdash; <span style="opacity:.5;font-size:12px;">19 hours ago</span></div>
        </div>
        <div class="review-card">
          <div style="color:#F4621F;font-size:18px;margin-bottom:12px;">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="review-text">"Best food, service, and price for a meal that I've had in years. Angel was an awesome waiter and the food is really good. Surprised by how much food was served. Couldn't finish half."</p>
          <div class="review-name">Larsen Trucking &mdash; <span style="opacity:.5;font-size:12px;">3 weeks ago</span></div>
        </div>
        <div class="review-card">
          <div style="color:#F4621F;font-size:18px;margin-bottom:12px;">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="review-text">"The best of the best! Best service ever and the food is always on point. The staff here are amazing beyond words! Definitely one of my favorite places to visit."</p>
          <div class="review-name">Lashay C. &mdash; <span style="opacity:.5;font-size:12px;">3 weeks ago &middot; Local Guide</span></div>
        </div>
      </div>
      <div class="reviews-dots">
        <span class="reviews-dot active" onclick="goToReview(0)"></span>
        <span class="reviews-dot" onclick="goToReview(1)"></span>
        <span class="reviews-dot" onclick="goToReview(2)"></span>
      </div>
    </div>
    <div style="text-align:center;margin-top:40px;">
      <a href="https://www.google.com/maps/place/Los+Cabos+Mexican+Grill,+Sealy" target="_blank" rel="noopener" style="display:inline-block;border:2px solid rgba(255,255,255,0.3);color:white;font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:13px;letter-spacing:.15em;text-transform:uppercase;padding:12px 32px;border-radius:4px;text-decoration:none;">Leave Us a Review on Google</a>
    </div>
  </div>
</section>

<section class="find-section" id="find-us">
  <div class="find-content">
    <div><div class="section-eyebrow">Come In</div><h2 class="section-heading">FIND US</h2></div>
    <div class="find-row"><span class="find-label">Address</span><span class="find-value">6027 FM 3538 Rd<br>Sealy, TX 77474</span></div>
    <div class="find-row"><span class="find-label">Phone</span><span class="find-value"><a href="tel:+15126076232">(512) 607-6232</a> <span style="font-family:Barlow,sans-serif;font-size:13px;color:#F4621F;font-style:italic;">(Yes, we're in Sealy, TX)</span></span></div>
    <div class="find-row"><span class="find-label">Hours</span><span class="find-value">Sun-Wed: 11AM - 9PM<br>Thu-Sat: 11AM - 10PM</span></div>
    <a href="https://maps.google.com/?q=6027+FM+3538+Rd+Sealy+TX+77474" target="_blank" rel="noopener" class="btn-primary" style="width:fit-content;">Get Directions</a>
  </div>
  <div class="map-embed">
    <iframe title="Los Cabos Sealy TX" src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3467.2!2d-96.1566!3d29.7810!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!5e0!3m2!1sen!2sus!4v1" width="100%" height="100%" style="border:0;" allowfullscreen loading="lazy"></iframe>
  </div>
</section>

