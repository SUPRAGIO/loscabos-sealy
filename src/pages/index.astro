  <style is:global>
/* ================================================================
   INDEX.ASTRO — MOBILE-FIRST
   Base = 320px+ | sm = 600px+ | lg = 900px+ | xl = 1200px+
================================================================ */

/* ----- HERO LOGO ----- */
.hero-logo {
  height: auto;
  width: 120px;
  margin-bottom: 16px;
  filter: drop-shadow(0 2px 12px rgba(0,0,0,0.5));
}

/* ----- SCROLLING BANNER ----- */
.scroll-banner {
  background: #F4621F;
  overflow: hidden;
  white-space: nowrap;
  padding: 10px 0;
  border-top: 1px solid rgba(255,255,255,0.15);
  border-bottom: 1px solid rgba(255,255,255,0.15);
}
.scroll-track {
  display: inline-flex;
  animation: scrollLeft 28s linear infinite;
  gap: 0;
}
.scroll-track:hover { animation-play-state: paused; }
@keyframes scrollLeft {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}
.scroll-item {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 800;
  font-size: 13px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #fff;
  padding: 0 32px;
  white-space: nowrap;
}
.scroll-dot {
  color: rgba(255,255,255,0.5);
  font-size: 10px;
}

/* ----- REVIEWS GRID (replaces carousel on mobile) ----- */
.reviews-grid-wrap { width: 100%; }
.reviews-grid-inner { display: flex; flex-direction: column; gap: 16px; }

/* ----- MENU CTA URGENCY ----- */
.menu-cta-urgency {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 700;
  font-size: 13px;
  letter-spacing: 0.1em;
  color: rgba(255,255,255,0.65);
  margin-top: -12px;
  margin-bottom: 24px;
  text-transform: uppercase;
}

/* ----- INDEX-SPECIFIC EYEBROW + HEADING ----- */
.idx-eyebrow {
  display: block;
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 800;
  font-size: 11px;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: #F4621F;
  margin-bottom: 8px;
}
.idx-heading {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 900;
  font-size: clamp(32px, 9vw, 54px);
  line-height: 0.95;
  text-transform: uppercase;
  color: #1C1410;
  margin-bottom: 20px;
}

/* ----- DARK OUTLINE BUTTON (index only) ----- */
.btn-outline-dark {
  display: inline-block;
  background: transparent;
  color: #1A1410;
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 800;
  font-size: 14px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  padding: 13px 32px;
  border-radius: 4px;
  text-decoration: none;
  border: 2px solid #1A1410;
  transition: background 0.2s, color 0.2s;
}
.btn-outline-dark:hover { background: #1A1410; color: #fff; }

.btn-outline-white {
  display: inline-block;
  background: transparent;
  color: #fff;
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 800;
  font-size: 13px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  padding: 12px 28px;
  border-radius: 4px;
  text-decoration: none;
  border: 2px solid rgba(255,255,255,0.35);
  transition: border-color 0.2s;
}
.btn-outline-white:hover { border-color: rgba(255,255,255,0.8); }

/* ----- HERO ----- */
.hero {
  position: relative;
  min-height: 88vh;
  display: flex;
  align-items: flex-end;
  overflow: hidden;
  padding-top: 90px;
}
.hero-video {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center center;
  z-index: 1;
}
.hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(15,10,6,0.82) 0%, rgba(15,10,6,0.45) 50%, rgba(15,10,6,0.20) 100%);
  z-index: 2;
}
.hero-content {
  position: relative;
  z-index: 3;
  width: 100%;
  padding: 0 20px 60px;
  display: flex;
  flex-direction: column;
  gap: 24px;
}
.hero-left { display: flex; flex-direction: column; gap: 20px; }
.hero-headline {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 900;
  font-size: clamp(52px, 16vw, 80px);
  line-height: 0.9;
  text-transform: uppercase;
  color: #fff;
  letter-spacing: -0.01em;
}
.hero-headline em { color: #F4621F; font-style: italic; display: block; }
.hero-ctas { display: flex; flex-direction: column; gap: 10px; }
.hero-ctas .btn-primary,
.hero-ctas .btn-outline,
.hero-ctas .btn-ghost {
  width: 100%;
  text-align: center;
  display: block;
}
.hero-proof {
  display: flex;
  align-items: center;
  gap: 16px;
  flex-wrap: wrap;
}
.proof-item { display: flex; flex-direction: column; gap: 2px; }
.proof-sep { width: 1px; height: 32px; background: rgba(255,255,255,0.2); flex-shrink: 0; }
.proof-num { font-family: 'Barlow Condensed', sans-serif; font-weight: 900; font-size: 22px; color: #fff; line-height: 1; }
.proof-unit { font-size: 13px; color: rgba(255,255,255,0.5); }
.proof-label { font-size: 10px; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 0.1em; font-weight: 600; white-space: nowrap; }
.proof-stars { color: #f5c518; font-size: 11px; letter-spacing: 1px; }
.hero-info-card { display: none; }

/* ----- TRUST BAR ----- */
.trust-bar {
  background: #1A1410;
  padding: 14px 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 0;
}
.trust-item {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 6px 12px;
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 700;
  font-size: 12px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #fff;
}
.trust-check { color: #F4621F; }
.trust-sep { width: 1px; height: 20px; background: rgba(255,255,255,0.15); }

/* ----- MENU CTA ----- */
.menu-cta-section {
  position: relative;
  min-height: 320px;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.menu-cta-bg { position: absolute; inset: 0; }
.menu-cta-img { width: 100%; height: 100%; object-fit: cover; }
.menu-cta-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(26,20,16,0.88) 0%, rgba(26,20,16,0.65) 100%);
}
.menu-cta-content {
  position: relative;
  z-index: 2;
  text-align: center;
  padding: 48px 24px;
  max-width: 600px;
  width: 100%;
}
.menu-cta-heading {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 900;
  font-size: clamp(40px, 12vw, 80px);
  color: #fff;
  line-height: 1;
  text-transform: uppercase;
  margin-bottom: 16px;
}
.menu-cta-sub {
  font-family: 'Barlow', sans-serif;
  font-size: 15px;
  color: rgba(255,255,255,0.75);
  margin-bottom: 28px;
  line-height: 1.5;
}

/* ----- FAMILY PACKS ----- */
.fp-intro {
  font-family: 'Barlow', sans-serif;
  font-size: 16px;
  color: #4A3728;
  line-height: 1.6;
  max-width: 680px;
  margin-bottom: 36px;
}
.fp-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 20px;
  margin-bottom: 48px;
}
.fp-card {
  background: #fff;
  border-radius: 14px;
  overflow: hidden;
  box-shadow: 0 2px 20px rgba(0,0,0,0.09);
  display: flex;
  flex-direction: column;
  transition: transform 0.2s, box-shadow 0.2s;
}
.fp-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 10px 36px rgba(0,0,0,0.13);
}
.fp-card-img {
  height: 200px;
  overflow: hidden;
}
.fp-card-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s;
}
.fp-card:hover .fp-card-img img { transform: scale(1.04); }
.fp-card-header {
  background: #1A1410;
  padding: 16px 24px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.fp-badge {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 800;
  font-size: 12px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.5);
  background: rgba(255,255,255,0.08);
  padding: 4px 12px;
  border-radius: 20px;
}
.fp-price {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 900;
  font-size: 30px;
  color: #F4621F;
  line-height: 1;
}
.fp-card-body {
  padding: 24px;
  display: flex;
  flex-direction: column;
  flex: 1;
}
.fp-name {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 900;
  font-size: 20px;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  color: #1C1410;
  margin-bottom: 10px;
  line-height: 1.1;
}
.fp-desc {
  font-family: 'Barlow', sans-serif;
  font-size: 14px;
  color: #4A3728;
  line-height: 1.65;
  margin-bottom: 16px;
  flex: 1;
}
.fp-serves {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 700;
  font-size: 13px;
  letter-spacing: 0.08em;
  color: #9E8472;
  text-transform: uppercase;
  margin-bottom: 16px;
}
.fp-order {
  display: block;
  text-align: center;
  background: #F4621F;
  color: #fff;
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 800;
  font-size: 13px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  padding: 12px;
  border-radius: 50px;
  text-decoration: none;
  transition: background 0.2s;
  margin-top: auto;
}
.fp-order:hover { background: #D94E0E; }
.fp-togo {
  display: inline-block;
  background: #1A1410;
  color: #F4621F;
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 800;
  font-size: 11px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  padding: 4px 12px;
  border-radius: 20px;
  margin-bottom: 16px;
  border: 1px solid rgba(244,98,31,0.3);
}
.fp-menu-sub {
  font-family: 'Barlow', sans-serif;
  font-size: 15px;
  color: #4A3728;
  line-height: 1.6;
  margin-bottom: 20px;
  max-width: 560px;
  margin-left: auto;
  margin-right: auto;
}

/* ----- FEATURED SECTION ----- */
.featured-section { background: #f5f0ea; padding: 52px 20px; }
.featured-inner { max-width: 1200px; margin: 0 auto; }
.featured-cta { text-align: center; margin-top: 36px; }

/* ----- CATERING ----- */
.cat-section { background: #f5f0ea; }
.cat-grid { display: flex; flex-direction: column; }
.cat-left { padding: 48px 20px; background: #f5f0ea; display: flex; flex-direction: column; gap: 24px; }
.cat-heading {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 900;
  font-size: clamp(36px, 10vw, 56px);
  color: #1C1410;
  line-height: 1;
  text-transform: uppercase;
}
.cat-desc { font-family: 'Barlow', sans-serif; font-size: 15px; color: #4A3728; line-height: 1.7; }
.cat-steps { display: flex; flex-direction: column; gap: 16px; }
.cat-step { display: flex; align-items: flex-start; gap: 14px; }
.cat-step-num { font-family: 'Barlow Condensed', sans-serif; font-weight: 900; font-size: 30px; color: #F4621F; line-height: 1; min-width: 32px; flex-shrink: 0; }
.cat-step-title { font-family: 'Barlow Condensed', sans-serif; font-weight: 800; font-size: 15px; text-transform: uppercase; letter-spacing: 0.06em; color: #1C1410; margin-bottom: 2px; }
.cat-step-desc { font-family: 'Barlow', sans-serif; font-size: 13px; color: #4A3728; line-height: 1.5; }
.cat-right { background: #1A1410; padding: 48px 20px; display: flex; flex-direction: column; align-items: center; gap: 16px; text-align: center; }
.cat-logo { height: 64px; width: auto; }
.cat-book-title { font-family: 'Barlow Condensed', sans-serif; font-weight: 900; font-size: 22px; text-transform: uppercase; letter-spacing: 0.04em; color: #fff; }
.cat-book-sub { font-family: 'Barlow', sans-serif; font-size: 14px; color: rgba(255,255,255,0.6); line-height: 1.6; max-width: 280px; margin: 0; }
.cat-phone { font-family: 'Barlow Condensed', sans-serif; font-weight: 900; font-size: 32px; color: #F4621F; text-decoration: none; letter-spacing: 0.02em; transition: color 0.2s; }
.cat-phone:hover { color: #fff; }
.cat-hours { font-family: 'Barlow', sans-serif; font-size: 12px; color: rgba(255,255,255,0.4); line-height: 1.8; }

/* ----- REVIEWS ----- */
.reviews-section { background: #110e0b; padding: 52px 20px; overflow: hidden; }
.reviews-inner { max-width: 1000px; margin: 0 auto; }
.reviews-heading { color: #fff; }
.reviews-score-row { display: flex; align-items: center; gap: 16px; margin-bottom: 32px; flex-wrap: wrap; }
.reviews-score { font-family: 'Barlow Condensed', sans-serif; font-weight: 900; font-size: 52px; color: #fff; line-height: 1; }
.reviews-stars { color: #f5c518; font-size: 20px; letter-spacing: 2px; }
.reviews-count { font-size: 13px; color: rgba(255,255,255,0.45); margin-top: 2px; }
.review-card {
  min-width: 100%;
  flex-shrink: 0;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 8px;
  padding: 24px 20px;
  box-sizing: border-box;
}
.review-stars-row { color: #f5c518; font-size: 16px; letter-spacing: 2px; margin-bottom: 12px; }
.review-text { font-family: 'Barlow', sans-serif; font-size: 15px; color: rgba(255,255,255,0.85); line-height: 1.6; margin-bottom: 14px; font-style: italic; }
.review-name { font-family: 'Barlow Condensed', sans-serif; font-weight: 700; font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(255,255,255,0.4); }
.review-time { opacity: 0.7; font-size: 11px; }
.reviews-dots { display: flex; justify-content: center; gap: 8px; margin-top: 20px; }
.reviews-dot { width: 8px; height: 8px; border-radius: 50%; background: rgba(255,255,255,0.25); border: none; cursor: pointer; padding: 0; transition: background 0.2s; }
.reviews-dot.active { background: #F4621F; }
.reviews-cta { text-align: center; margin-top: 36px; }

/* ----- FIND YOUR LOS CABOS SECTION ----- */
.find-section {
  position: relative;
  display: flex;
  flex-direction: column;
  min-height: 480px;
}
.find-bg {
  position: absolute;
  inset: 0;
}
.find-bg-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center 30%;
}
.find-bg-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(15,10,6,0.92) 0%, rgba(26,20,16,0.78) 60%, rgba(15,10,6,0.85) 100%);
}
.find-inner {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  gap: 32px;
  padding: 52px 20px 32px;
}
.find-header {}
.find-eyebrow {
  display: block;
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 800;
  font-size: 11px;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: #F4621F;
  margin-bottom: 8px;
}
.find-heading {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 900;
  font-size: clamp(40px, 13vw, 72px);
  line-height: 0.92;
  text-transform: uppercase;
  color: #fff;
  margin-bottom: 0;
}
.find-location-card {
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(244,98,31,0.3);
  border-radius: 12px;
  padding: 28px 24px;
  backdrop-filter: blur(12px);
  max-width: 420px;
}
.find-location-name {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 900;
  font-size: 20px;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: #fff;
  margin-bottom: 4px;
}
.find-location-tag {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 700;
  font-size: 11px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: #F4621F;
  margin-bottom: 20px;
}
.find-rows { display: flex; flex-direction: column; gap: 12px; margin-bottom: 24px; }
.find-row { display: flex; flex-direction: column; gap: 3px; }
.find-label {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 700;
  font-size: 10px;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.4);
}
.find-value {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 700;
  font-size: 15px;
  color: #fff;
  line-height: 1.4;
}
.find-value a { color: #F4621F; text-decoration: none; }
.find-btns {
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.map-embed {
  position: relative;
  z-index: 2;
  min-height: 280px;
  flex-shrink: 0;
}
.map-embed iframe {
  width: 100%;
  height: 100%;
  min-height: 280px;
  display: block;
  border: 0;
}

/* ----- INFO CARD ----- */
.info-phone-note { display: block; font-family: 'Barlow', sans-serif; font-size: 12px; color: #F4621F; font-style: italic; margin-top: 2px; }

/* ================================================================
   TABLET min-width: 600px
================================================================ */
@media (min-width: 600px) {
  .hero { padding-top: 114px; }
  .hero-content { padding: 0 32px 52px; }
  .hero-headline { font-size: clamp(64px, 14vw, 100px); }
  .hero-ctas { flex-direction: row; flex-wrap: wrap; }
  .hero-ctas .btn-primary,
  .hero-ctas .btn-outline,
  .hero-ctas .btn-ghost { width: auto; display: inline-block; }
  .trust-item { padding: 8px 20px; font-size: 13px; }
  .menu-cta-section { min-height: 400px; }
  .fp-grid { grid-template-columns: repeat(2, 1fr); }
  .cat-grid { flex-direction: row; }
  .cat-left { flex: 1; padding: 52px 32px; }
  .cat-right { flex: 0 0 300px; padding: 52px 32px; }
  .find-inner { flex-direction: row; align-items: flex-start; gap: 48px; padding: 72px 40px 40px; }
  .find-btns { flex-direction: row; flex-wrap: wrap; }
  .map-embed { min-height: 360px; }
}

/* ================================================================
   DESKTOP min-width: 900px
================================================================ */
@media (min-width: 900px) {
  .hero { min-height: 100vh; }
  .hero-video { object-position: 75% center; }
  .hero-content {
    padding: 0 clamp(32px, 5vw, 72px) clamp(48px, 8vh, 80px);
    flex-direction: row;
    align-items: flex-end;
    justify-content: space-between;
    gap: 40px;
  }
  .hero-left { max-width: 680px; }
  .hero-headline { font-size: clamp(80px, 10vw, 140px); }
  .hero-ctas { flex-direction: row; }
  .hero-ctas .btn-primary,
  .hero-ctas .btn-outline,
  .hero-ctas .btn-ghost { width: auto; display: inline-block; }
  .hero-info-card {
    display: flex;
    flex-direction: column;
    gap: 16px;
    background: rgba(20,16,12,0.88);
    border: 1px solid rgba(244,98,31,0.25);
    border-radius: 10px;
    padding: 28px 24px;
    min-width: 230px;
    backdrop-filter: blur(16px);
    flex-shrink: 0;
  }
  .info-card-row { display: flex; flex-direction: column; gap: 3px; }
  .info-label { font-family: 'Barlow Condensed', sans-serif; font-weight: 700; font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase; color: rgba(255,255,255,0.4); }
  .info-value { font-family: 'Barlow Condensed', sans-serif; font-weight: 700; font-size: 15px; color: #fff; line-height: 1.35; }
  .info-value a { color: #F4621F; text-decoration: none; }
  .info-divider { height: 1px; background: rgba(255,255,255,0.08); }
  .menu-cta-section { min-height: 480px; }
  .menu-cta-content { padding: 72px 40px; }
  .featured-section { padding: 80px clamp(32px, 5vw, 72px); }
  .fp-grid { grid-template-columns: repeat(3, 1fr); gap: 28px; }
  .fp-card-img { height: 220px; }
  .cat-left { padding: clamp(48px, 6vw, 72px) clamp(32px, 4vw, 56px); }
  .cat-right { flex: 0 0 340px; padding: 72px 48px; }
  .cat-heading { font-size: clamp(40px, 5vw, 64px); }
  .cat-phone { font-size: 40px; }
  .cat-logo { height: 80px; }
  .reviews-section { padding: 80px 72px; }
  .reviews-grid-inner { gap: 24px; flex-wrap: wrap; transform: none !important; }
  .review-card { min-width: 0; flex: 1 1 calc(33.333% - 16px); padding: 32px 28px; }
  .reviews-dots { display: none; }
  .find-section { flex-direction: row; min-height: 520px; }
  .find-inner { flex: 1; padding: 72px 64px; flex-direction: column; gap: 32px; }
  .find-heading { font-size: clamp(52px, 7vw, 88px); }
  .map-embed { flex: 1; min-height: 440px; }
  .find-btns { flex-direction: row; }
  .scroll-item { font-size: 14px; padding: 0 40px; }
}

/* ================================================================
   WIDE min-width: 1200px
================================================================ */
@media (min-width: 1200px) {
  .trust-item { font-size: 14px; padding: 8px 36px; }
  .trust-sep { height: 24px; }
}

/* ---- CENTERED HERO OVERRIDES ---- */
.hero-content { flex-direction: column !important; align-items: center !important; justify-content: center !important; text-align: center !important; max-width: 100% !important; }
.hero-left { display: flex !important; flex-direction: column !important; align-items: center !important; text-align: center !important; max-width: 760px !important; width: 100% !important; padding: 0 16px !important; }
.hero-right, .hero-find, .hero-info-card, .find-section { display: none !important; }
.hero-headline { display: flex !important; flex-direction: column !important; align-items: center !important; gap: 4px !important; line-height: 0.95 !important; margin: 0 0 28px !important; }
.hero-headline .hh-line { display: block; font-size: clamp(56px, 10vw, 140px); font-weight: 900; letter-spacing: 0.01em; text-transform: uppercase; color: #fff; text-shadow: 0 4px 28px rgba(0,0,0,0.6); }
.hero-headline .hh-accent { color: var(--orange); font-style: italic; }
.hero-ctas { justify-content: center !important; flex-wrap: wrap; }
.hero-proof { justify-content: center !important; }

/* ---- AUTHENTIC TEX-MEX SECTION ---- */
.auth-tx { background: #f7f1e6; padding: 96px 20px; text-align: center; color: #0f0d0b; }
.auth-tx-head { max-width: 880px; margin: 0 auto 56px; }
.auth-tx-title { font-family: 'Barlow Condensed', sans-serif; font-weight: 900; font-size: clamp(40px, 6vw, 76px); letter-spacing: 0.02em; text-transform: uppercase; margin: 0 0 14px; color: #0f0d0b; }
.auth-tx-title .dot { color: var(--orange); }
.auth-tx-sub { font-family: 'Barlow', sans-serif; font-size: clamp(16px, 1.6vw, 20px); color: rgba(15,13,11,0.72); margin: 0; }
.auth-tx-grid { display: grid; grid-template-columns: 1fr; gap: 28px; max-width: 1200px; margin: 0 auto; }
@media (min-width: 640px) { .auth-tx-grid { grid-template-columns: repeat(2, 1fr); } }
@media (min-width: 960px) { .auth-tx-grid { grid-template-columns: repeat(3, 1fr); } }
.auth-tx-card { display: block; text-decoration: none; color: inherit; transition: transform 0.25s ease; }
.auth-tx-card:hover { transform: translateY(-4px); }
.auth-tx-card img { width: 100%; aspect-ratio: 1 / 1; object-fit: cover; border-radius: 10px; box-shadow: 0 10px 28px rgba(0,0,0,0.18); display: block; }
.auth-tx-card h3 { font-family: 'Barlow Condensed', sans-serif; font-weight: 800; font-size: clamp(20px, 2vw, 26px); text-transform: uppercase; letter-spacing: 0.04em; margin: 18px 0 0; color: #0f0d0b; }

/* ===== Hero Map Icon ===== */
.hero-map-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 48px; height: 48px;
  border-radius: 50%;
  background: #E87722;
  color: #fff;
  margin: 0 auto 12px;
  box-shadow: 0 6px 18px rgba(0,0,0,0.4);
  transition: transform 0.2s ease, background 0.2s ease;
  text-decoration: none;
}
.hero-map-icon:hover { transform: scale(1.08); background: #c95e10; }
.hero-map-icon svg { width: 26px; height: 26px; }

/* ===== Hero Subheadline ===== */
.hero-subheadline {
  font-size: 1.05rem;
  line-height: 1.45;
  color: #f3ece1;
  max-width: 640px;
  margin: 10px auto 18px;
  text-align: center;
  font-weight: 500;
  letter-spacing: 0.01em;
  text-shadow: 0 2px 8px rgba(0,0,0,0.6);
}
@media (min-width: 600px) { .hero-subheadline { font-size: 1.15rem; } }
@media (min-width: 900px) { .hero-subheadline { font-size: 1.25rem; max-width: 760px; } }

/* ===== Authentic Tex-Mex Section CTA ===== */
.auth-tx-cta { text-align: center; margin: 28px auto 0; padding: 0 16px; }
.auth-tx-btn {
  display: inline-block;
  padding: 16px 36px;
  font-size: 1.05rem;
  letter-spacing: 0.06em;
  font-weight: 800;
}

/* ===== Reviews Carousel (marquee) ===== */
.reviews-grid-wrap { overflow: hidden; position: relative; margin: 24px -16px 0; padding: 0; }
.reviews-grid-wrap::before, .reviews-grid-wrap::after {
  content: ''; position: absolute; top: 0; bottom: 0; width: 60px; z-index: 2; pointer-events: none;
}
.reviews-grid-wrap::before { left: 0; background: linear-gradient(to right, #0f0d0b, transparent); }
.reviews-grid-wrap::after { right: 0; background: linear-gradient(to left, #0f0d0b, transparent); }
#reviewsCarousel { overflow: hidden; }
.reviews-track {
  display: flex;
  gap: 20px;
  width: max-content;
  animation: reviewsScroll 50s linear infinite;
}
.reviews-track:hover { animation-play-state: paused; }
.reviews-track .review-card { flex: 0 0 320px; max-width: 320px; }
@keyframes reviewsScroll {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}
@media (min-width: 900px) {
  .reviews-track .review-card { flex: 0 0 360px; max-width: 360px; }
}

/* ===== Catering Revamp ===== */
.cat-section { padding: 60px 16px; background: #faf6ef; }
.cat-grid { display: grid; grid-template-columns: 1fr; gap: 32px; max-width: 1200px; margin: 0 auto; align-items: center; }
@media (min-width: 900px) { .cat-grid { grid-template-columns: 1.1fr 1fr; gap: 56px; } }
.cat-left .idx-eyebrow { color: #E87722; }
.cat-heading { font-size: clamp(2rem, 5vw, 3.2rem); line-height: 0.95; font-weight: 900; color: #0f0d0b; margin: 8px 0 16px; letter-spacing: -0.01em; }
.cat-desc { font-size: 1.05rem; line-height: 1.55; color: #3a342c; margin: 0 0 20px; }
.cat-benefits { list-style: none; padding: 0; margin: 0 0 24px; display: grid; gap: 14px; }
.cat-benefits li { display: flex; gap: 12px; align-items: flex-start; }
.cat-ck { flex-shrink: 0; width: 36px; height: 36px; border-radius: 10px; background: rgba(232,119,34,0.12); color: #E87722; display: inline-flex; align-items: center; justify-content: center; margin-top: 2px; }
.cat-ck svg { width: 22px; height: 22px; display: block; }
