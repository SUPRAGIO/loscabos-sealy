  .menu-section{background:#f5f0ea}
  .menu-cta-banner{position:relative;min-height:480px;display:flex;align-items:center;justify-content:center;;overflow:hidden}
  .menu-cta-overlay{position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,20,16,.88) 0%,rgba(26,20,16,.65) 100%)}
  .menu-cta-content{position:relative;z-index:2;text-align:center;padding:60px 40px;max-width:720px}
  .menu-cta-eyebrow{font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:13px;letter-spacing:.2em;text-transform:uppercase;color:#F4621F;display:block;margin-bottom:16px}
  .menu-cta-heading{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:clamp(52px,8vw,96px);color:white;line-height:1;text-transform:uppercase;margin-bottom:20px}
  .menu-cta-sub{font-family:'Barlow',sans-serif;font-size:18px;color:rgba(255,255,255,.75);margin-bottom:36px;line-height:1.5}
  .menu-cta-btn{display:inline-block;background:#F4621F;color:white;font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:15px;letter-spacing:.15em;text-transform:uppercase;padding:16px 48px;border-radius:4px;text-decoration:none;transition:background .2s}
  .menu-cta-btn:hover{background:#D94E0E}
  .featured-section{padding:80px 72px;background:#f5f0ea}
  .featured-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:28px;margin-top:48px}
  .featured-card{background:white;border-radius:12px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,.08);transition:transform .2s,box-shadow .2s}
  .featured-card:hover{transform:translateY(-4px);box-shadow:0 8px 40px rgba(0,0,0,.14)}
  .featured-img{height:220px;width:100%}
  .featured-body{padding:24px}
  .featured-name{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:22px;letter-spacing:.04em;text-transform:uppercase;color:#1C1410;margin-bottom:10px}
  .featured-desc{font-family:'Barlow',sans-serif;font-size:14px;color:#4A3728;line-height:1.6;margin-bottom:16px}
  .featured-price{font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:20px;color:#F4621F;margin-bottom:16px}
  .featured-order{display:block;text-align:center;;color:white;font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:13px;letter-spacing:.12em;text-transform:uppercase;padding:12px;border-radius:4px;text-decoration:none;transition:background .2s}
  .featured-order:hover{background:#F4621F}
  .btn-secondary-menu{display:inline-block;border:2px solid #1A1410;color:#1A1410;font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:14px;letter-spacing:.15em;text-transform:uppercase;padding:14px 40px;border-radius:4px;text-decoration:none;transition:all .2s}
  .btn-secondary-menu:hover{;color:white}
  @media(max-width:768px){
    .menu-cta-banner{min-height:380px}
    .menu-cta-content{padding:40px 24px}
    .featured-section{padding:60px 20px}
    .featured-grid{grid-template-columns:1fr;gap:20px}
    .featured-img{height:180px}
  }
  .stat-num{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:48px;color:#F4621F;line-height:1}
  .stat-label{font-family:'Barlow',sans-serif;font-size:13px;color:#4A3728;margin-top:4px}
  @media(max-width:900px){.stat-num{font-size:36px}}
  .catering-header .section-eyebrow{color:#F4621F}
  .catering-header .section-heading{color:white}
  .step-num{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:48px;color:#F4621F;line-height:1;margin-bottom:12px}
  .step-title{font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:18px;text-transform:uppercase;letter-spacing:.06em;color:white;margin-bottom:10px}
  .step-desc{font-family:'Barlow',sans-serif;font-size:14px;color:rgba(255,255,255,0.55);line-height:1.6}
  @media(max-width:900px){
  }

  .catering-section{;padding:80px 40px;width:100%;box-sizing:border-box}
  .catering-inner{max-width:960px;margin:0 auto;display:flex;flex-direction:column;align-items:center;gap:56px;text-align:center}
  .catering-header{width:100%}
  .catering-header .section-eyebrow{color:#F4621F}
  .catering-header .section-heading{color:white}
  .catering-intro{font-family:'Barlow',sans-serif;font-size:17px;color:rgba(255,255,255,0.65);line-height:1.7;margin-top:16px;max-width:600px;margin-left:auto;margin-right:auto}
  .catering-steps{display:flex;align-items:flex-start;justify-content:center;gap:0;width:100%}
  .catering-step{flex:1;padding:28px 20px;text-align:center}
  .catering-step-arrow{font-size:28px;color:#F4621F;font-weight:900;padding-top:40px;flex-shrink:0}
  .step-num{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:52px;color:#F4621F;line-height:1;margin-bottom:12px}
  .step-title{font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:18px;text-transform:uppercase;letter-spacing:.06em;color:white;margin-bottom:10px}
  .step-desc{font-family:'Barlow',sans-serif;font-size:14px;color:rgba(255,255,255,0.55);line-height:1.6}
  .catering-cta-row{display:flex;justify-content:center;width:100%}
  .catering-cta-card{background:#F4621F;border-radius:16px;padding:40px 48px;text-align:center;max-width:440px;width:100%}
  .catering-cta-heading{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:28px;text-transform:uppercase;color:white;margin-bottom:10px}
  .catering-cta-sub{font-family:'Barlow',sans-serif;font-size:14px;color:rgba(255,255,255,0.85);line-height:1.6;margin-bottom:20px}
  .catering-cta-phone{display:block;font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:36px;color:white;text-decoration:none;margin-bottom:8px;letter-spacing:.04em}
