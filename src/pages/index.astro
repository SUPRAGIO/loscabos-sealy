---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Los Cabos Mexican Grill | Sealy, TX | Sizzling Fajitas & Margaritas"
  description="Full menu: fajitas, enchiladas, tacos, burritos, seafood, steaks, margaritas and more. Scratch-made Tex-Mex in Sealy, TX. Dine in or order online."
>

<!-- ===== HERO ===== -->
<section class="hero">
  <video autoplay muted loop playsinline class="hero-video" postr="/images/hero-poster.jpg">
    <source src="/video/FajitaSizzle.MOV" type="video/mp4" />
  </video>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <div class="hero-left">
      <a href="https://www.google.com/maps/dir/?api=1&destination=Los+Cabos+Mexican+Grill+Sealy+TX" target="_blank" rel="noopener" class="hero-map-icon" aria-label="Get directions to Los Cabos Mexican Grill">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="32" height="32" aria-hidden="true"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 1 1 0-5 2.5 2.5 0 0 1 0 5z"/></svg>
      </a>
      <h1 class="hero-headline"><span class="hh-line">FAJITAS</span><span class="hh-line">FIX</span><span class="hh-line hh-accent">EVERYTHING</span></h1>
      <p class="hero-subheadline">Scratch-made Tex-Mex. Sizzling fajitas fresh off the grill, hand-shaken margaritas, and the salsa you&rsquo;ll dream about. <strong>Every meal made fresh to order</strong> &mdash; right here in Sealy, Texas.</p>
      <div class="hero-ctas">
        <a href="https://online.skytab.com/75fd37a0da5766d1bf27a245fba50884/order-settings" target="_blank" rel="noopener" class="btn-primary">Order Online</a>
        <a href="#menu" class="btn-outline">View Menu</a>
        <a href="tel:+15126076232" class="btn-ghost">Call Now</a>
      </div>
      <div class="hero-proof">
        <div class="proof-item">
          <div class="proof-num">4.8</div>
          <div class="proof-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <div class="proof-label">Google Rating</div>
        </div>
        <div class="proof-sep"></div>
        <div class="proof-item">
          <div class="proof-num">1,725+</div>
          <div class="proof-label">Happy Locals</div>
        </div>
        <div class="proof-sep"></div>
        <div class="proof-item">
          <div class="proof-num">15<span class="proof-unit"> min</span></div>
          <div class="proof-label">Avg. Pickup</div>
        </div>
      </div>
    </div>
    <aside class="hero-info-card">
      <div class="info-card-row">
        <span class="info-label">Hours</span>
        <span class="info-value">Sun&ndash;Wed 11AM&ndash;9PM<br>Thu&ndash;Sat 11AM&ndash;10PM</span>
      </div>
      <div class="info-divider"></div>
      <div class="info-card-row">
        <span class="info-label">Address</span>
        <span class="info-value">6027 FM 3538 Rd<br>Sealy, TX 77474</span>
      </div>
      <div class="info-divider"></div>
      <div class="info-card-row">
        <span class="info-label">Phone</span>
        <span class="info-value">
          <a href="tel:+15126076232">(512) 607-6232</a>
          <span class="info-phone-note">(Yes, we&rsquo;re in Sealy, TX)</span>
        </span>
      </div>
      <div class="info-divider"></div>
      <a href="https://online.skytab.com/75fd37a0da5766d1bf27a245fba50884/order-settings" target="_blank" rel="noopener" class="btn-primary" style="display:block;text-align:center;">ORDER NOW &rarr;</a>
    </aside>
  </div>
</section>

<!-- ===== TRUST BAR ===== -->
<section class="trust-bar">
  <div class="trust-item"><span class="trust-check">&#10003;</span><span>Made From Scratch</span></div>
  <div class="trust-sep"></div>
  <div class="trust-item"><span class="trust-check">&#10003;</span><span>Margaritas Made Right</span></div>
  <div class="trust-sep"></div>
  <div class="trust-item"><span class="trust-check">&#10003;</span><span>15-Minute Pickup</span></div>
  <div class="trust-sep"></div>
  <div class="trust-item"><span class="trust-check">&#10003;</span><span>Dine In or Carry Out</span></div>
</section>

<!-- ===== SCROLLING BANNER ===== -->
<div class="scroll-banner">
  <div class="scroll-track">
    <span class="scroll-item"><span class="scroll-dot">&bull;</span> NOT YOUR AVERAGE TEX-MEX</span>
    <span class="scroll-item"><span class="scroll-dot">&bull;</span> SEE WHAT YOUR NEIGHBORS ARE TALKING ABOUT</span>
    <span class="scroll-item"><span class="scroll-dot">&bull;</span> WHERE FAMILY&rsquo;S COME TOGETHER</span>
    <span class="scroll-item"><span class="scroll-dot">&bull;</span> FOLLOW US @LOSCABOSSEALY</span>
    <span class="scroll-item"><span class="scroll-dot">&bull;</span> NOT YOUR AVERAGE TEX-MEX</span>
    <span class="scroll-item"><span class="scroll-dot">&bull;</span> SEE WHAT YOUR NEIGHBORS ARE TALKING ABOUT</span>
    <span class="scroll-item"><span class="scroll-dot">&bull;</span> WHERE FAMILY&rsquo;S COME TOGETHER</span>
    <span class="scroll-item"><span class="scroll-dot">&bull;</span> FOLLOW US @LOSCABOSSEALY</span>
    <span class="scroll-item"><span class="scroll-dot">&bull;</span> NOT YOUR AVERAGE TEX-MEX</span>
    <span class="scroll-item"><span class="scroll-dot">&bull;</span> SEE WHAT YOUR NEIGHBORS ARE TALKING ABOUT</span>
    <span class="scroll-item"><span class="scroll-dot">&bull;</span> WHERE FAMILY&rsquo;S COME TOGETHER</span>
    <span class="scroll-item"><span class="scroll-dot">&bull;</span> FOLLOW US @LOSCABOSSEALY</span>
  </div>
</div>

<!-- ===== MENU CTA BANNER ===== -->
<section class="menu-cta-section" id="menu">
  <div class="menu-cta-bg">
    <img src="/images/Fajitas4Hero.jpg" alt="Sizzling Fajitas" class="menu-cta-img" loading="lazy" />
    <div class="menu-cta-overlay"></div>
  </div>
  <div class="menu-cta-content">
    <span class="idx-eyebrow">Every Meal Made Fresh To Order.</span>
    <h2 class="menu-cta-heading">BIG FLAVOR.<br>NO SHORTCUTS.</h2>
    <p class="menu-cta-sub">Marinated meats, scratch salsas, and tortillas the way abuela would make them. One bite and you&rsquo;ll get why Sealy keeps coming back.</p>
    <p class="menu-cta-urgency">Order online &mdash; hot &amp; ready in 15 minutes.</p>
    <a href="/menu" class="btn-primary" style="display:block;max-width:280px;margin:0 auto;text-align:center;">VIEW FULL MENU &rarr;</a>
  </div>
</section>

<!-- ===== AUTHENTIC TEX-MEX ===== -->
<section class="auth-tx">
  <div class="auth-tx-head">
    <h2 class="auth-tx-title">Authentic Tex-Mex<span class="dot">.</span></h2>
    <p class="auth-tx-sub">Every meal made fresh to order &mdash; right here in Sealy, Texas.</p>
  </div>
  <div class="auth-tx-grid">
    <a class="auth-tx-card" href="/menu#fajitas"><img src="/images/Fajitas4Hero.jpg" alt="Sizzling Fajitas" loading="lazy" /><h3>Sizzling Fajitas</h3></a>
    <a class="auth-tx-card" href="/menu#enchiladas"><img src="/images/enchiladas.jpg" alt="Enchiladas" loading="lazy" /><h3>Enchiladas</h3></a>
    <a class="auth-tx-card" href="/menu#steaks"><img src="/images/ribeye.jpg" alt="Steaks &amp; Pasta" loading="lazy" /><h3>Steaks &amp; Pasta</h3></a>
    <a class="auth-tx-card" href="/menu#appetizers"><img src="/images/queso.jpg" alt="Appetizers" loading="lazy" /><h3>Appetizers</h3></a>
    <a class="auth-tx-card" href="/menu#drinks"><img src="/images/michelada.jpg" alt="Drinks" loading="lazy" /><h3>Drinks</h3></a>
    <a class="auth-tx-card" href="/menu"><img src="/images/MenuItems.jpg" alt="Full Menu" loading="lazy" /><h3>See Full Menu</h3></a>
  </div>
  <div class="auth-tx-cta">
    <a href="/menu" class="btn-primary auth-tx-btn">VIEW OUR FULL MENU</a>
  </div>
</section>
<!-- ===== CATERING ===== -->
<section class="cat-section" id="catering">
  <div class="cat-grid">
    <div class="cat-left">
      <span class="idx-eyebrow">Catering &amp; Events</span>
      <h2 class="cat-heading">WE BRING<br>THE FIESTA.</h2>
      <p class="cat-desc">Backyard birthdays. Corporate lunches. Weddings. We roll up, fire up the grill on-site, and hit your guests with the kind of Tex-Mex spread they&rsquo;ll be texting about for weeks. No sad trays. No cold fajitas. Just the real deal.</p>
      <ul class="cat-benefits">
        <li><span class="cat-ck">&#10003;</span><div><strong>Cooked On-Site</strong><span>We bring the grill. Your guests hear the sizzle before they taste it.</span></div></li>
        <li><span class="cat-ck">&#10003;</span><div><strong>Custom Menus</strong><span>Fajitas, enchiladas, tacos, margaritas &mdash; build a menu your crew will actually fight over.</span></div></li>
        <li><span class="cat-ck">&#10003;</span><div><strong>Delivery &amp; Full Setup</strong><span>We deliver, set up, serve, and clean up. You enjoy the party &mdash; that&rsquo;s the deal.</span></div></li>
        <li><span class="cat-ck">&#10003;</span><div><strong>Drop-Off &amp; Setup Available</strong><span>Short on time? We&rsquo;ll drop off hot trays ready to serve, plus sternos, chafers, and all the setup.</span></div></li>
        <li><span class="cat-ck">&#10003;</span><div><strong>Any Group Size</strong><span>25 guests or 500+ &mdash; if you&rsquo;re feeding &rsquo;em, we&rsquo;re cooking.</span></div></li>
      </ul>
      <div class="cat-cta-row">
        <a href="tel:+15126076232" class="btn-primary cat-cta-main">CALL (512) 607-6232</a>
        <a href="/catering" class="btn-outline-dark cat-cta-sec">Request a Quote &rarr;</a>
          <a href="/catering-menu.pdf" class="btn-outline-dark cat-cta-sec cat-cta-dl" download="Los-Cabos-Catering-Menu.pdf" aria-label="Download catering menu PDF">&darr; Download Menu (PDF)</a>
      </div>
      <p class="cat-fineprint">Serving Sealy and surrounding areas up to a 30 mile radius.</p>
    </div>
    <div class="cat-right">
      <img src="/images/cabosvan2.jpeg" alt="Los Cabos catering van at event" class="cat-img" loading="lazy" />
      <div class="cat-badge-overlay">
        <div class="cat-badge-num">500+</div>
        <div class="cat-badge-label">Events Catered</div>
      </div>
    </div>
  </div>
</section>

<!-- ===== REVIEWS ===== -->
<section class="reviews-section">
  <div class="reviews-inner">
    <span class="idx-eyebrow">See What Your Neighbors Are Talking About</span>
    <h2 class="idx-heading reviews-heading">REAL REVIEWS.<br>REAL NEIGHBORS.</h2>
    <div class="reviews-score-row">
      <div class="reviews-score">4.8</div>
      <div>
        <div class="reviews-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        <div class="reviews-count">Based on Google Reviews</div>
      </div>
    </div>
    <div class="reviews-grid-wrap">
      <div class="reviews-grid-inner" id="reviewsCarousel">
        <div class="reviews-track">
        <div class="review-card">
          <div class="review-stars-row">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="review-text">&ldquo;Food was out quick and it was phenomenal. Will definitely be going back.&rdquo;</p>
          <div class="review-name">Brandin S. &mdash; <span class="review-time">19 hours ago</span></div>
        </div>
        <div class="review-card">
          <div class="review-stars-row">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="review-text">&ldquo;Best food, service, and price for a meal that I&rsquo;ve had in years. Angel was an awesome waiter and the food is really good. Surprised by how much food was served. Couldn&rsquo;t finish half.&rdquo;</p>
          <div class="review-name">Larsen Trucking &mdash; <span class="review-time">3 weeks ago</span></div>
        </div>
        <div class="review-card">
          <div class="review-stars-row">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="review-text">&ldquo;The best of the best! Best service ever and the food is always on point. The staff here are amazing beyond words! Definitely one of my favorite places to visit.&rdquo;</p>
          <div class="review-name">Lashay C. &mdash; <span class="review-time">3 weeks ago &middot; Local Guide</span></div>
        </div>
      
        <div class="review-card">
          <div class="review-stars-row">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="review-text">&ldquo;Food was out quick and it was phenomenal. Will definitely be going back.&rdquo;</p>
          <div class="review-name">Brandin S. &mdash; <span class="review-time">19 hours ago</span></div>
        </div>
        <div class="review-card">
          <div class="review-stars-row">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="review-text">&ldquo;Best food, service, and price for a meal that I&rsquo;ve had in years. Angel was an awesome waiter and the food is really good. Surprised by how much food was served. Couldn&rsquo;t finish half.&rdquo;</p>
          <div class="review-name">Larsen Trucking &mdash; <span class="review-time">3 weeks ago</span></div>
        </div>
        <div class="review-card">
          <div class="review-stars-row">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="review-text">&ldquo;The best of the best! Best service ever and the food is always on point. The staff here are amazing beyond words! Definitely one of my favorite places to visit.&rdquo;</p>
          <div class="review-name">Lashay C. &mdash; <span class="review-time">3 weeks ago &middot; Local Guide</span></div>
        </div>
      </div>
      </div>
      <div class="reviews-dots" style="display:none;">
        <button class="reviews-dot active" onclick="goToReview(0)" aria-label="Review 1"></button>
        <button class="reviews-dot" onclick="goToReview(1)" aria-label="Review 2"></button>
        <button class="reviews-dot" onclick="goToReview(2)" aria-label="Review 3"></button>
      </div>
    </div>
    <div class="reviews-cta">
      <a href="https://www.google.com/maps/place/Los+Cabos+Mexican+Grill,+Sealy" target="_blank" rel="noopener" class="btn-outline-white">Leave Us a Review on Google</a>
    </div>
  </div>
</section>

<!-- ===== FIND YOUR LOS CABOS ===== -->
<section class="find-section" id="find-us">
  <div class="find-bg">
    <img src="/images/MenuItems.jpg" alt="Los Cabos Mexican Grill" class="find-bg-img" loading="lazy" />
    <div class="find-bg-overlay"></div>
  </div>
  <div class="find-inner">
    <div class="find-header">
      <span class="find-eyebrow">Come Find Us</span>
      <h2 class="find-heading">FIND YOUR<br>LOS CABOS.</h2>
    </div>
    <div class="find-location-card">
      <div class="find-location-name">Los Cabos Mexican Grill</div>
      <div class="find-location-tag">Sealy, TX</div>
