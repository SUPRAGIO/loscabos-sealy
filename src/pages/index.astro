---
import Base from "@/layouts/Base.astro";
import Hero from "@/components/Hero.astro";
import Features from "@/components/Features.astro";
import Bienvenidos from "@/components/Bienvenidos.astro";
import FajitaPromo from "@/components/FajitaPromo.astro";
import LocalFavorites from "@/components/LocalFavorites.astro";
import Reviews from "@/components/Reviews.astro";
import CateringCta from "@/components/CateringCta.astro";
import FindUs from "@/components/FindUs.astro";
---

<Base
  title="Los Cabos Mexican Grill | Tex Mex Restaurant in Sealy, TX"
  description="Family owned Tex Mex in Sealy, TX off I-10. Sizzling fajitas, hand shaken margaritas, fresh salsa daily, lunch specials, family packs, and catering. Open daily 11AM."
>
  <Hero />
  <Features />
  <Bienvenidos />
  <FajitaPromo />
  <LocalFavorites />
  <Reviews />
  <CateringCta />
  <FindUs />
</Base>
