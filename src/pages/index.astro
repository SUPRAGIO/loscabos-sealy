.tc-body{padding:16px 18px 18px;display:flex;flex-direction:column;flex:1}
.tc-name{font-family:"Barlow Condensed",sans-serif;font-weight:900;font-size:19px;color:#1A1008;margin-bottom:6px;line-height:1.1}
.tc-desc{font-size:13px;color:#555;line-height:1.5;margin-bottom:12px;flex:1}
.tc-price{font-family:"Barlow Condensed",sans-serif;font-weight:800;font-size:17px;color:#1A1008;margin-bottom:10px}
.tc-select{width:100%;padding:7px 10px;border:2px solid #e0d8d0;border-radius:6px;font-family:"Barlow Condensed",sans-serif;font-weight:700;font-size:13px;color:#1A1008;background:#fff;cursor:pointer;margin-bottom:10px}
.tc-select:focus{outline:none;border-color:#F4621F}
.tc-order{display:block;background:#F4621F;color:#fff;text-align:center;padding:11px 18px;border-radius:50px;font-family:"Barlow Condensed",sans-serif;font-weight:900;font-size:13px;letter-spacing:.12em;text-transform:uppercase;text-decoration:none;transition:background .2s;margin-top:auto}
.tc-order:hover{background:#d4521a}
.catering-section{display:grid;grid-template-columns:1fr 1fr;min-height:520px;background:#F5EFE6}
.catering-img img{width:100%;height:100%;object-fit:cover}
.catering-text{padding:72px 64px;display:flex;flex-direction:column;justify-content:center;gap:20px}
.catering-sub{font-size:17px;color:#4A3728;line-height:1.6;max-width:460px}
.catering-list{list-style:none;display:flex;flex-direction:column;gap:10px}
.catering-list li{font-family:"Barlow Condensed",sans-serif;font-weight:700;font-size:16px;color:#1A1008;padding-left:20px;position:relative}
.reviews-section{padding:80px 72px;background:#1A1410}
.reviews-section .section-heading{color:#fff}
.reviews-header{margin-bottom:40px}
.reviews-agg{display:flex;align-items:center;gap:16px;margin-top:16px}
.reviews-score{font-family:"Barlow Condensed",sans-serif;font-weight:900;font-size:56px;color:#fff;line-height:1}
.reviews-stars{color:#f5c518;font-size:20px;letter-spacing:2px}
.reviews-count{font-size:13px;color:rgba(255,255,255,.5);margin-top:2px}
.reviews-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.review-card{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:8px;padding:24px}
.review-stars{color:#f5c518;font-size:15px;letter-spacing:2px;margin-bottom:10px}
.review-text{color:rgba(255,255,255,.85);font-size:15px;line-height:1.6;margin-bottom:14px;font-style:italic}
.review-name{font-family:"Barlow Condensed",sans-serif;font-weight:700;font-size:13px;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.45)}
.find-section{display:grid;grid-template-columns:1fr 1fr;min-height:440px}
.find-content{background:#F5EFE6;padding:72px 64px;display:flex;flex-direction:column;gap:20px;justify-content:center}
.find-row{display:flex;flex-direction:column;gap:4px}
.find-label{font-family:"Barlow Condensed",sans-serif;font-weight:700;font-size:10px;letter-spacing:.25em;text-transform:uppercase;color:#9E8472}
.find-value{font-family:"Barlow Condensed",sans-serif;font-weight:700;font-size:16px;color:#1A1008;line-height:1.4}
.find-value a{color:#F4621F;text-decoration:none}
.map-embed iframe{width:100%;height:100%;min-height:400px;border:0}
@media(max-width:1100px){.tc-grid{grid-template-columns:repeat(3,1fr)}}
@media(max-width:768px){
  .hero-content{grid-template-columns:1fr;padding:0 20px 60px}
  .hero-info-card{display:none}
  .hero-headline{font-size:clamp(52px,14vw,76px)}
  .trust-bar{padding:16px}
  .trust-sep{display:none}
  .trust-item{padding:6px 12px;font-size:12px}
  .menu-section{padding:60px 20px}
  .tab-btn{font-size:11px;padding:8px 10px}
  .tc-grid{grid-template-columns:repeat(2,1fr);gap:14px}
  .catering-section{grid-template-columns:1fr}
  .catering-img{height:260px}
  .catering-text{padding:40px 24px}
  .reviews-section{padding:60px 20px}
  .reviews-grid{grid-template-columns:1fr;gap:16px}
  .find-section{grid-template-columns:1fr}
  .find-content{padding:40px 24px}
  .map-embed iframe{min-height:280px}
}
@media(max-width:480px){.tc-grid{grid-template-columns:1fr}}
</style>

<script>
const tabs=document.querySelectorAll('.tab-btn');
const contents=document.querySelectorAll('.tab-content');
tabs.forEach(btn=>{btn.addEventListener('click',()=>{tabs.forEach(t=>t.classList.remove('active'));contents.forEach(c=>c.classList.remove('active'));btn.classList.add('active');document.getElementById('tab-'+btn.dataset.tab)?.classList.add('active');});});
</script>