---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Menu — Los Cabos Mexican Grill | Sealy, TX" description="Full menu for Los Cabos Mexican Grill in Sealy, TX. Fajitas, enchiladas, seafood, steaks, drinks and more.">

<style>

.hero{position:relative;min-height:100vh;display:flex;align-items:flex-end;overflow:hidden;padding-top:114px}
.hero-bg{position:absolute;inset:0;z-index:0;width:100%;height:100%;object-fit:cover;object-position:85% center;inset:0;z-index:1;background:linear-gradient(to bottom,rgba(14,11,8,.1) 0%,rgba(14,11,8,0) 20%,rgba(14,11,8,.6) 65%,rgba(14,11,8,.97) 100%)}
.hero-content{position:relative;z-index:2;width:100%;padding:0 72px 72px;display:grid;grid-template-columns:1fr auto;align-items:end;gap:40px}
.hero-left{max-width:700px}
.hero-headline{font-family:"Barlow Condensed",sans-serif;font-weight:900;font-size:clamp(80px,12vw,160px);line-height:.9;text-transform:uppercase;color:#fff;letter-spacing:-.01em;margin-bottom:32px}
.hero-headline em{color:#F4621F;font-style:italic;display:block}
.hero-ctas{display:flex;gap:12px;margin-bottom:32px;flex-wrap:wrap}
.hero-proof{display:flex;align-items:center;gap:24px}
.proof-item{display:flex;flex-direction:column;gap:2px}
.proof-sep{width:1px;height:36px;background:rgba(255,255,255,.2);flex-shrink:0}
.proof-num{font-family:"Barlow Condensed",sans-serif;font-weight:900;font-size:24px;color:#fff;line-height:1}
.proof-unit{font-size:14px;color:rgba(255,255,255,.5)}
.proof-label{font-size:10px;color:rgba(255,255,255,.5);text-transform:uppercase;letter-spacing:.1em;font-weight:600;white-space:nowrap}
.proof-stars{color:#f5c518;font-size:11px;letter-spacing:1px}
.hero-info-card{background:rgba(20,16,12,.9);border:1px solid rgba(244,98,31,.25);border-radius:10px;padding:28px 24px;min-width:230px;backdrop-filter:blur(16px);display:flex;flex-direction:column;gap:16px}
.info-card-row{display:flex;flex-direction:column;gap:3px}
.info-label{font-family:"Barlow Condensed",sans-serif;font-weight:700;font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:rgba(255,255,255,.4)}
.info-value{font-family:"Barlow Condensed",sans-serif;font-weight:700;font-size:15px;color:#fff;line-height:1.35}
.info-value a{color:#F4621F;text-decoration:none}
.info-divider{height:1px;background:rgba(255,255,255,.08)}
.trust-bar{background:#1A1410;padding:24px 72px;display:flex;align-items:center;justify-content:center;flex-wrap:wrap}
.trust-item{display:flex;align-items:center;gap:10px;padding:8px 36px;color:#fff;font-family:"Barlow Condensed",sans-serif;font-weight:700;font-size:14px;letter-spacing:.08em;text-transform:uppercase}
.trust-sep{width:1px;height:24px;background:rgba(255,255,255,.15)}
.section-eyebrow{font-family:"Barlow Condensed",sans-serif;font-weight:700;font-size:12px;letter-spacing:.25em;text-transform:uppercase;color:#F4621F;display:block;margin-bottom:8px}
.section-heading{font-family:"Barlow Condensed",sans-serif;font-weight:900;font-size:clamp(36px,5vw,54px);line-height:1;text-transform:uppercase;color:#1A1008;margin-bottom:0}
.menu-section{padding:80px 72px;background:#f5f0ea}
.menu-header{margin-bottom:36px}
.menu-tabs{display:flex;gap:0;margin-bottom:48px;flex-wrap:wrap;border-bottom:none}
.tab-btn{font-family:"Barlow Condensed",sans-serif;font-weight:900;font-size:16px;letter-spacing:.08em;text-transform:uppercase;padding:14px 24px;background:none;border:none;cursor:pointer;color:#bbb;border-bottom:4px solid transparent;transition:all .2s;white-space:nowrap;line-height:1}
.tab-btn.active{color:#1A1008;border-bottom:4px solid #F4621F;background:rgba(244,98,31,.06)}.tab-btn:hover{color:#F4621F;border-bottom:4px solid rgba(244,98,31,.3)}
.tc-grid{display:none;grid-template-columns:repeat(4,1fr);gap:24px}
.tab-content.active{display:grid}
.tc-card{background:#fff;border-radius:12px;overflow:hidden;box-shadow:0 2px 12px rgba(0,0,0,.08);display:flex;flex-direction:column}
.tc-img{height:200px;overflow:hidden;background:#e8e0d8}
.tc-img img{width:100%;height:100%;object-fit:cover;transition:transform .3s}
.tc-card:hover .tc-img img{transform:scale(1.04)}
.tc-body{padding:16px 18px 18px;display:flex;flex-direction:column;flex:1}
.tc-name{font-family:"Barlow Condensed",sans-serif;font-weight:900;font-size:19px;color:#1A1008;margin-bottom:6px;line-height:1.1}
.tc-desc{font-size:13px;color:#555;line-height:1.5;margin-bottom:12px;flex:1}
.tc-price{font-family:"Barlow Condensed",sans-serif;font-weight:800;font-size:17px;color:#1A1008;margin-bottom:10px}
.tc-select{width:100%;padding:7px 10px;border:2px solid #e0d8d0;border-radius:6px;font-family:"Barlow Condensed",sans-serif;font-weight:700;font-size:13px;color:#1A1008;background:#fff;cursor:pointer;margin-bottom:10px}
.tc-select:focus{outline:none;border-color:#F4621F}
.tc-order{display:block;background:#F4621F;color:#fff;text-align:center;padding:11px 18px;border-radius:50px;font-family:"Barlow Condensed",sans-serif;font-weight:900;font-size:13px;letter-spacing:.12em;text-transform:uppercase;text-decoration:none;transition:background .2s;margin-top:auto}
.tc-order:hover{background:#d4521a}
.catering-section{display:grid;grid-template-columns:1fr 1fr;min-height:520px;background:#F5EFE6}
.catering-img img{width:100%;height:100%;object-fit:cover}
.catering-text{padding:72px 64px;display:flex;flex-direction:column;justify-content:center;gap:20px}
.catering-sub{font-size:17px;color:#4A3728;line-height:1.6;max-width:460px}
.catering-list{list-style:none;display:flex;flex-direction:column;gap:10px}
.catering-list li{font-family:"Barlow Condensed",sans-serif;font-weight:700;font-size:16px;color:#1A1008;padding-left:20px;position:relative}
.reviews-section{padding:80px 72px;background:#1A1410}
.reviews-section .section-heading{color:#fff}
.reviews-header{margin-bottom:40px}
.reviews-agg{display:flex;align-items:center;gap:16px;margin-top:16px}
.reviews-score{font-family:"Barlow Condensed",sans-serif;font-weight:900;font-size:56px;color:#fff;line-height:1}
.reviews-stars{color:#f5c518;font-size:20px;letter-spacing:2px}
.reviews-count{font-size:13px;color:rgba(255,255,255,.5);margin-top:2px}
.reviews-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.review-card{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:8px;padding:24px}
.review-stars{color:#f5c518;font-size:15px;letter-spacing:2px;margin-bottom:10px}
.review-text{color:rgba(255,255,255,.85);font-size:15px;line-height:1.6;margin-bottom:14px;font-style:italic}
.review-name{font-family:"Barlow Condensed",sans-serif;font-weight:700;font-size:13px;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.45)}
.find-section{display:grid;grid-template-columns:1fr 1fr;min-height:440px}
.find-content{background:#F5EFE6;padding:72px 64px;display:flex;flex-direction:column;gap:20px;justify-content:center}
.find-row{display:flex;flex-direction:column;gap:4px}
.find-label{font-family:"Barlow Condensed",sans-serif;font-weight:700;font-size:10px;letter-spacing:.25em;text-transform:uppercase;color:#9E8472}
.find-value{font-family:"Barlow Condensed",sans-serif;font-weight:700;font-size:16px;color:#1A1008;line-height:1.4}
.find-value a{color:#F4621F;text-decoration:none}
.map-embed iframe{width:100%;height:100%;min-height:400px;border:0}
@media(max-width:1100px){.tc-grid{grid-template-columns:repeat(3,1fr)}}
@media(max-width:768px){
  .hero-content{grid-template-columns:1fr;padding:0 20px 60px}
  .hero-info-card{display:none}
  .hero-headline{font-size:clamp(52px,14vw,76px)}
  .trust-bar{padding:16px}
  .trust-sep{display:none}
  .trust-item{padding:6px 12px;font-size:12px}
  .menu-section{padding:60px 20px}
  .tab-btn{font-size:11px;padding:8px 10px}
  .tc-grid{grid-template-columns:repeat(2,1fr);gap:14px}
  .catering-section{grid-template-columns:1fr}
  .catering-img{height:260px}
  .catering-text{padding:40px 24px}
  .reviews-section{padding:60px 20px}
  .reviews-grid{grid-template-columns:1fr;gap:16px}
  .find-section{grid-template-columns:1fr}
  .find-content{padding:40px 24px}
  .map-embed iframe{min-height:280px}
}
@media(max-width:480px){.tc-grid{grid-template-columns:1fr}}

.menu-page-header{text-align:center;padding:60px 72px 0;background:#f5f0ea}
.menu-page-header .section-eyebrow{color:#F4621F;font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:13px;letter-spacing:.2em;text-transform:uppercase;display:block;margin-bottom:12px}
.menu-page-header h1{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:clamp(48px,6vw,80px);color:#1C1410;line-height:1;text-transform:uppercase;margin-bottom:16px}
.menu-page-header p{font-family:'Barlow',sans-serif;font-size:16px;color:#4A3728;margin-bottom:24px}
.menu-page-header .btn-order{display:inline-block;background:#F4621F;color:white;font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:14px;letter-spacing:.12em;text-transform:uppercase;padding:14px 36px;border-radius:4px;text-decoration:none;margin-bottom:48px}
</style>

<div style="padding-top:114px;background:#f5f0ea;min-height:100vh;">
  <div class="menu-page-header">
    <span class="section-eyebrow">Los Cabos Mexican Grill &mdash; Sealy, TX</span>
    <h1>Our Full Menu</h1>
    <p>Dine in or order online &mdash; ready in 15 minutes.</p>
    <a href="https://online.skytab.com/75fd37a0da5766d1bf27a245fba50884/order-settings" target="_blank" rel="noopener" class="btn-order">Order Online Now</a>
  </div>

  <div class="menu-section" style="padding-top:0;">
    <div class="menu-tabs">
    <button class="tab-btn active" data-tab="apps">Appetizers</button>
    <button class="tab-btn" data-tab="soups">Soups &amp; Salads</button>
    <button class="tab-btn" data-tab="fajitas">Sizzling Fajitas</button>
    <button class="tab-btn" data-tab="enchiladas">Enchiladas</button>
    <button class="tab-btn" data-tab="tacos">Tacos, Burritos &amp; Burgers</button>
    
    
    <button class="tab-btn" data-tab="seafood">Seafood Specialties</button>
    <button class="tab-btn" data-tab="chicken">Chicken Delicioso</button>
    <button class="tab-btn" data-tab="rancho">Special Combinations</button>
    <button class="tab-btn" data-tab="steaks">Steaks &amp; Pasta</button>
    
    <button class="tab-btn" data-tab="drinks">Drinks</button>
    <button class="tab-btn" data-tab="desserts">Desserts</button><button class="tab-btn" data-tab="kids">Kids Menu</button><button class="tab-btn" data-tab="sides">Sides</button>
  </div>
    <div class="tc-grid tab-content active" id="tab-apps">
    <div class="tc-card"><div class="tc-img"><img src="/images/queso.jpg" alt="Botana Mix" loading="lazy"/></div><div class="tc-body"><div class="tc-name">Botana Mix</div><div class="tc-desc">Cheese quesadilla, nachos, mini chalupas, stuffed shrimp jalapeno, chicken fried burrito, guacamole and sour cream.</div><div class="tc-price">$15.99</div><a href="https://online.skytab.com/75fd37a0da5766d1bf27a245fba50884/order-settings" target="_blank" rel="noopener" class="tc-order">ORDER NOW</a></div></div>
<div class="tc-grid tab-content" id="tab-soups">
    <div class="tc-card"><div class="tc-img"><img src="/images/queso.jpg" alt="Tortilla Soup" loading="lazy"/></div><div class="tc-body"><div class="tc-name">Tortilla Soup</div><div class="tc-desc">Vegetables, tortilla strips, mushrooms, cheese, and avocado slices.</div><div class="tc-price">$11.95</div><a href="https://online.skytab.com/75fd37a0da5766d1bf27a245fba50884/order-settings" target="_blank" rel="noopener" class="tc-order">ORDER NOW</a></div></div>
<div class="tc-grid tab-content" id="tab-fajitas">
    <div class="tc-card"><div class="tc-img"><img src="/images/fajitas.jpg" alt="Fajitas Mexicanas" loading="lazy"/></div><div class="tc-body"><div class="tc-name">Fajitas Mexicanas</div><div class="tc-desc">All sizzling fajitas served with guacamole, pico, rice, charro or black beans, and fresh homemade tortillas. Roll your own tacos and garnish to your liking. Sizzling fajitas topped with marinated sauce of onions, tomatoes, jalapenos, cilantro and mushrooms.</div><select class="tc-select"><option>Beef Small - $17.95</option><option>Beef Medium - $19.50</option><option>Beef For Two - $38.00</option><option>Chicken Small - $16.95</option><option>Chicken Medium - $18.99</option><option>Chicken For Two - $36.00</option></select><a href="https://online.skytab.com/75fd37a0da5766d1bf27a245fba50884/order-settings" target="_blank" rel="noopener" class="tc-order">ORDER NOW</a></div></div>
<div class="tc-grid tab-content" id="tab-enchiladas">
    <div class="tc-card"><div class="tc-img"><img src="/images/enchiladas.jpg" alt="Enchiladas Poblanas" loading="lazy"/></div><div class="tc-body"><div class="tc-name">Enchiladas Poblanas</div><div class="tc-desc">Two enchiladas with charbroiled beef or chicken fajitas in corn tortillas, topped with poblano peppers, onions, mushrooms, cilantro, heavy cream, parmesan, and cheddar. Served with guacamole and pico.</div><select class="tc-select"><option>Beef - $18.99</option><option>Chicken - $18.99</option></select><a href="https://online.skytab.com/75fd37a0da5766d1bf27a245fba50884/order-settings" target="_blank" rel="noopener" class="tc-order">ORDER NOW</a></div></div>
<div class="tc-grid tab-content" id="tab-tacos">
    <div class="tc-card"><div class="tc-img"><img src="/images/fajitas.jpg" alt="El Mariachi Tacos" loading="lazy"/></div><div class="tc-body"><div class="tc-name">El Mariachi Tacos</div><div class="tc-desc">Two tacos filled with shrimp, chicken and beef fajitas sauteed with pico, topped with chile con queso. Served with rice and charro or black beans.</div><div class="tc-price">$17.15</div><a href="https://online.skytab.com/75fd37a0da5766d1bf27a245fba50884/order-settings" target="_blank" rel="noopener" class="tc-order">ORDER NOW</a></div></div>
<div class="tc-grid tab-content" id="tab-seafood">
    <div class="tc-card"><div class="tc-img"><img src="/images/michelada.jpg" alt="Cabos Seafood Platter" loading="lazy"/></div><div class="tc-body"><div class="tc-name">Cabos Seafood Platter</div><div class="tc-desc">Fried shrimp, fried catfish, stuffed jalapeno shrimp, wrapped shrimp and chicken brochette. Served with French fries.</div><div class="tc-price">$19.50</div><a href="https://online.skytab.com/75fd37a0da5766d1bf27a245fba50884/order-settings" target="_blank" rel="noopener" class="tc-order">ORDER NOW</a></div></div>
<div class="tc-grid tab-content" id="tab-chicken">
    <div class="tc-card"><div class="tc-img"><img src="/images/server.jpg" alt="Pollo Relleno" loading="lazy"/></div><div class="tc-body"><div class="tc-name">Pollo Relleno</div><div class="tc-desc">Chicken breast stuffed with shrimp, tomatoes, cilantro and onions, topped with buttered wine sauce of mushrooms, tomatoes, jalapenos and onions. Served with rice, charro or black beans, guacamole and pico.</div><div class="tc-price">$19.95</div><a href="https://online.skytab.com/75fd37a0da5766d1bf27a245fba50884/order-settings" target="_blank" rel="noopener" class="tc-order">ORDER NOW</a></div></div>
<div class="tc-grid tab-content" id="tab-rancho">
    <div class="tc-card"><div class="tc-img"><img src="/images/server.jpg" alt="Plato Tulum" loading="lazy"/></div><div class="tc-body"><div class="tc-name">Plato Tulum</div><div class="tc-desc">3 shrimp brochettes, beef enchilada poblana, and a beef fajita taco. Served with rice and beans.</div><div class="tc-price">$17.99</div><a href="https://online.skytab.com/75fd37a0da5766d1bf27a245fba50884/order-settings" target="_blank" rel="noopener" class="tc-order">ORDER NOW</a></div></div>
<div class="tc-grid tab-content" id="tab-steaks">
    <div class="tc-card"><div class="tc-img"><img src="/images/server.jpg" alt="Nancy's Pasta" loading="lazy"/></div><div class="tc-body"><div class="tc-name">Nancy's Pasta</div><div class="tc-desc">Served with Caesar salad or dinner salad, and garlic bread. Fettucine tossed with crawfish, jalapeno sausage and mushrooms in a marinara cream sauce, topped with grilled shrimp.</div><div class="tc-price">$18.99</div><a href="https://online.skytab.com/75fd37a0da5766d1bf27a245fba50884/order-settings" target="_blank" rel="noopener" class="tc-order">ORDER NOW</a></div></div>
<div class="tc-grid tab-content" id="tab-drinks">
    <div class="tc-card" style="background:#1A1410;grid-column:1/-1;border-radius:8px;padding:16px 24px;display:flex;align-items:center;"><div class="tc-name" style="color:#F4621F;font-size:20px;letter-spacing:.1em;margin:0;">NON-ALCOHOLIC</div></div>
<div class="tc-grid tab-content" id="tab-desserts">
    <div class="tc-card"><div class="tc-img"><img src="/images/server.jpg" alt="Cheesecake" loading="lazy"/></div><div class="tc-body"><div class="tc-name">Cheesecake</div><div class="tc-desc">Topped with strawberries.</div><div class="tc-price">$6.95</div><a href="https://online.skytab.com/75fd37a0da5766d1bf27a245fba50884/order-settings" target="_blank" rel="noopener" class="tc-order">ORDER NOW</a></div></div>
<div class="tc-grid tab-content" id="tab-kids">
    <div class="tc-card"><div class="tc-img"><img src="/images/server.jpg" alt="Kids Plate" loading="lazy"/></div><div class="tc-body"><div class="tc-name">Kids Plate</div><div class="tc-desc">Choice of: Taco, Enchilada, Burrito, or Chile Con Queso Puff. Served with rice and beans. Adults add $3.00.</div><div class="tc-price">$3.99</div><a href="https://online.skytab.com/75fd37a0da5766d1bf27a245fba50884/order-settings" target="_blank" rel="noopener" class="tc-order">ORDER NOW</a></div></div>
<div class="tc-grid tab-content" id="tab-sides">
    <div class="tc-card"><div class="tc-img"><img src="/images/server.jpg" alt="Taco" loading="lazy"/></div><div class="tc-body"><div class="tc-name">Taco</div><div class="tc-desc">Beef or chicken.</div><select class="tc-select"><option>Beef - $4.00</option><option>Chicken - $4.00</option></select><a href="https://online.skytab.com/75fd37a0da5766d1bf27a245fba50884/order-settings" target="_blank" rel="noopener" class="tc-order">ORDER NOW</a></div></div>
  </div>
</div>

<script>

const tabs=document.querySelectorAll('.tab-btn');
const contents=document.querySelectorAll('.tab-content');
tabs.forEach(btn=>{btn.addEventListener('click',()=>{tabs.forEach(t=>t.classList.remove('active'));contents.forEach(c=>c.classList.remove('active'));btn.classList.add('active');document.getElementById('tab-'+btn.dataset.tab)?.classList.add('active');});});

// GA4 outbound click tracking for all Order Now links
document.addEventListener('DOMContentLoaded',function(){
  const skytabUrl = 'skytab.com';
  document.querySelectorAll('a[href*="skytab"]').forEach(function(link){
    link.addEventListener('click',function(){
      const label = link.closest('.tc-card') 
        ? link.closest('.tc-body')?.querySelector('.tc-name')?.textContent?.trim() 
        : link.textContent?.trim();
      if(typeof gtag !== 'undefined'){
        gtag('event','order_now_click',{
          'event_category':'Outbound',
          'event_label': label || 'Order Now',
          'transport_type':'beacon',
          'value':1
        });
      }
    });
  });

  // Also track hero CTA buttons
  document.querySelectorAll('.btn-primary, .btn-nav-order').forEach(function(btn){
    btn.addEventListener('click',function(){
      if(typeof gtag !== 'undefined'){
        gtag('event','order_now_click',{
          'event_category':'Outbound',
          'event_label': btn.textContent?.trim() + ' (Hero/Nav)',
          'transport_type':'beacon',
          'value':1
        });
      }
    });
  });
});

</script>

</Layout>
