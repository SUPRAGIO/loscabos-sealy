>
  <script type="application/ld+json" set:html={JSON.stringify(menuSchema)} />
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow-script">Buen provecho</span>
      <h1>The whole menu</h1>
      <p>
        Sizzling fajitas, hand shaken margs, salsa pressed fresh every
        morning, and the family favorites Sealy keeps coming back for.
      </p>
    </div>
  </section>

  <nav class="menu-nav" id="menuNav" aria-label="Menu sections">
    <div class="container">
      <ul>
        {menu.map((s) => <li><a href={`#${s.id}`}>{s.title}</a></li>)}
      </ul>
    </div>
  </nav>

  <script>
    // Hide menu-nav on scroll down, show on scroll up.
    // Mirrors the main site header behavior so both bars feel consistent.
    (() => {
      const nav = document.getElementById("menuNav");
      if (!nav) return;

      let lastY = window.scrollY;
      let ticking = false;
      const SHOW_THRESHOLD = 80;
      const DELTA = 6;

      function update() {
        const y = window.scrollY;
        const goingDown = y > lastY + DELTA;
        const goingUp = y < lastY - DELTA;

        if (y < SHOW_THRESHOLD) {
          nav.classList.remove("is-hidden");
        } else if (goingDown) {
          nav.classList.add("is-hidden");
        } else if (goingUp) {
          nav.classList.remove("is-hidden");
        }

        lastY = y;
        ticking = false;
      }

      window.addEventListener(
        "scroll",
        () => {
          if (!ticking) {
            window.requestAnimationFrame(update);
            ticking = true;
          }
        },
        { passive: true }
      );
    })();
  </script>

  {
    menu.map((section) => (
      <section class="section menu-section" id={section.id}>
        <div class="container">
          <SectionTitle eyebrow={section.eyebrow} title={section.title} />

          {section.blurb && (
            <p class="section-blurb">{section.blurb}</p>
          )}

          <ul class="menu-list">
            {section.items.map((item) => (
              <li class="menu-item">
                <div class="menu-row">
                  <span class="dish-name">
                    {item.name}
                    {item.tag && <span class="dish-tag">{item.tag}</span>}
                  </span>
                  {item.price && (
                    <>
                      <span class="dots" aria-hidden="true" />
                      <span class="dish-price">{item.price}</span>
                    </>
                  )}
                </div>
                {item.desc && <p class="dish-desc">{item.desc}</p>}
                {item.variants && (
                  <ul class="dish-variants">
                    {item.variants.map((v) => (
                      <li>
                        <span class="variant-label">{v.label}</span>
                        <span class="variant-price">{v.price}</span>
                      </li>
                    ))}
                  </ul>
                )}
              </li>
            ))}
          </ul>
        </div>
      </section>
    ))
  }
</Base>

