const menuSchema = {
  "@context": "https://schema.org",
  "@type": "Menu",
  name: "Los Cabos Mexican Grill Full Menu",
  hasMenuSection: menu.map((section) => ({
    "@type": "MenuSection",
    name: section.title,
    hasMenuItem: section.items.map((item) => {
      const m: any = {
        "@type": "MenuItem",
        name: item.name,
      };
      if (item.desc) m.description = item.desc;
      if (item.price && item.price !== "$—") {
        m.offers = {
          "@type": "Offer",
          price: item.price.replace("$", ""),
          priceCurrency: "USD",
        };
      }
      return m;
    }),
  })),
};
